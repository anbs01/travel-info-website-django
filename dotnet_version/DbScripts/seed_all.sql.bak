(15, '周村古商城', '齐鲁第一古商街', '旱码头', '历史街区', '热门景点', 'AAAA级', '明清古建筑保存完整，被誉为“中国活着的古商业街”。', '<p>周村古商城历史悠久。</p>', '古迹,商业,齐文化', 'https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=800', 14, '旅游局', 0, 0, 0, 0, 1800, 90, NOW(), NOW()),
(16, '台儿庄古城', '台儿庄', '中华古水城', '历史街区', '知名景区', 'AAAAA级', '运河遗迹，二战名城。', '<p>台儿庄古城是中国规模最大的古城之一。</p>', '运河,红色,古城', 'https://images.unsplash.com/photo-1544391682-178c6a583bbd?w=800', 2, '旅游局', 0, 1, 0, 0, 4200, 89, NOW(), NOW()),

SELECT '✅ 数据初始化完成！' AS 结果;
SELECT '热词' AS 表名, COUNT(*) AS 数量 FROM tp_hot_words
UNION ALL SELECT '地理', COUNT(*) FROM tp_geo
UNION ALL SELECT '交通', COUNT(*) FROM tp_transports
UNION ALL SELECT '打卡地', COUNT(*) FROM tp_scenic_spots
UNION ALL SELECT '纪行攻略', COUNT(*) FROM tp_travelogues
UNION ALL SELECT '行业资讯', COUNT(*) FROM tp_news
UNION ALL SELECT '特产美食', COUNT(*) FROM tp_foods
UNION ALL SELECT '文创商品', COUNT(*) FROM tp_creative_products
UNION ALL SELECT '首页推荐', COUNT(*) FROM tp_recommendations;


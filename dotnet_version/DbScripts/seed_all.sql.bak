INSERT INTO tp_travelogues (Id, Title, Classification, SubTitle, Summary, Content, Tags, MainImage, GeoId, Author, Source, CopyrightType, IsSticky, IsHome, IsHidden, ShowWatermark, Views, SortOrder, CreatedAt, UpdatedAt) VALUES
(1, '烟台长岛三日游，遇见最美海岸线', '纪行', '海岛之旅', '走进烟台长岛，感受仙山海岛的魅力。', '<p>第一天：从烟台港乘船前往长岛...</p>', '海岛,自驾,深度游', 'https://images.unsplash.com/photo-1540660290370-8af90a454417?w=800', 10, '徐霞客', '原创', '原创版权', 1, 1, 0, 0, 5600, 100, NOW(), NOW()),
(2, '蓬莱阁攻略：寻访八仙过海的传说', 'guide', '寻仙问药', '蓬莱阁作为中国四大名楼之一，历史悠久。', '<p>蓬莱阁景区游玩路线全解析。</p>', '攻略,古建筑,名胜', 'https://images.unsplash.com/photo-1527685238219-c81b3dd33021?w=800', 10, '旅游达人', '原创', '原创版权', 0, 1, 0, 0, 890, 99, NOW(), NOW()),
(3, '威海环海路自驾记', '纪行', '最美公路', '随手一拍都是大片。', '<p>从威海市区出发，沿着环海路一路向东。</p>', '自驾,海景,摄影', 'https://images.unsplash.com/photo-1516245556?w=800', 13, '老司机', '原创', '原创版权', 1, 0, 0, 0, 2300, 98, NOW(), NOW()),
(4, '青岛八大关秋色', '纪行', '异国情调', '感受欧式风情的浪漫。', '<p>八大关的秋天是青岛最有味道的时候。</p>', '秋季,建筑,浪漫', 'https://images.unsplash.com/photo-1540660290370-8af90a454417?w=800', 12, '摄影师', '原创', '原创版权', 0, 1, 0, 0, 1560, 97, NOW(), NOW()),
(5, '泰山日出观赏指南', 'guide', '巅峰时刻', '不看日出枉上泰山。', '<p>泰山日出观赏时间表及地点推荐。</p>', '泰山,日出,登山', 'https://images.unsplash.com/photo-1544391682-178c6a583bbd?w=800', 11, '爬山王', '原创', '原创版权', 1, 1, 0, 0, 3400, 96, NOW(), NOW()),
(6, '杭州西湖环湖徒步攻略', 'guide', '步履天堂', '西湖最全徒步路线，带你看不一样的风景。', '<p>从断桥出发，绕湖一周约10公里。</p>', '徒步,西湖,户外', 'https://images.unsplash.com/photo-1525640788966-69bdb028aa73?w=800', 18, '徒步者', '原创', '原创版权', 0, 1, 0, 0, 1200, 95, NOW(), NOW()),
(7, '成都美食地图：三天吃遍锦里宽窄', 'guide', '味蕾盛宴', '麻辣鲜香，这是成都的味道。', '<p>第一站：陈麻婆豆腐...</p>', '成都,美食,攻略', 'https://images.unsplash.com/photo-1527685238219-c81b3dd33021?w=800', 19, '美食家', '原创', '原创版权', 0, 1, 0, 0, 2800, 94, NOW(), NOW()),
(8, '北京故宫半日深度游', 'guide', '皇家足迹', '避开人流，高效游故宫。', '<p>建议从中轴线两侧的东六宫开始。</p>', '故宫,历史,北京', 'https://images.unsplash.com/photo-1508804185872-d7badad00f7d?w=800', 7, '历史迷', '原创', '原创版权', 0, 1, 0, 0, 4100, 93, NOW(), NOW()),
(9, '上海武康路漫步记', '纪行', '老上海风情', '梧桐树下的洋房记忆。', '<p>武康大楼是必去打卡点。</p>', '上海,街拍,历史建筑', 'https://images.unsplash.com/photo-1474181487882-5abf3f0ba6c2?w=800', 8, '城市漫游者', '原创', '原创版权', 0, 0, 0, 0, 950, 92, NOW(), NOW()),
(10, '苏州平江路：寻觅姑苏慢生活', '纪行', '水乡情怀', '撑一把油纸伞，走在青石板路上。', '<p>平江路是苏州保存最完整的古街。</p>', '苏州,古街,慢生活', 'https://images.unsplash.com/photo-1525640788966-69bdb028aa73?w=800', 21, '小资青年', '原创', '原创版权', 0, 1, 0, 0, 1100, 91, NOW(), NOW()),
(11, '南京明孝陵石象路秋景', '纪行', '最美600米', '金秋时节，神道色彩斑斓。', '<p>石象路是明孝陵最著名的地段。</p>', '南京,秋天,古迹', 'https://images.unsplash.com/photo-1540660290370-8af90a454417?w=800', 20, '摄影爱好者', '原创', '原创版权', 0, 1, 0, 0, 1300, 90, NOW(), NOW()),
(12, '广州早茶红黑榜', 'guide', '叹茶时光', '一盅两件，哪家最正宗？', '<p>白天鹅宾馆、广州酒家大测评。</p>', '广州,美食,早茶', 'https://images.unsplash.com/photo-1541849546-216549ae216d?w=800', 22, '吃货团', '原创', '原创版权', 0, 0, 0, 0, 2500, 89, NOW(), NOW()),
(13, '深圳人才公园夜景拍摄指南', 'guide', '极客城市', '春笋下，看灯光秀的最佳角度。', '<p>建议在晚上7点到达湖边。</p>', '深圳,夜景,摄影', 'https://images.unsplash.com/photo-1523301343968-6a6ebf63c672?w=800', 9, '极客', '原创', '原创版权', 0, 0, 0, 0, 800, 88, NOW(), NOW()),
(14, '济南趵突泉赏泉记', '纪行', '天下第一', '三股泉水腾空而起。', '<p>老舍笔下的济南春天。</p>', '济南,泉水,散文', 'https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=800', 11, '文学青年', '原创', '原创版权', 0, 0, 0, 0, 750, 87, NOW(), NOW()),
(15, '威海那香海：不出国门看马尔代夫', '纪行', '蓝冰沙滩', '这里有最干净的海和最美的落日。', '<p>那香海的沙子很细。</p>', '威海,海滩,度假', 'https://images.unsplash.com/photo-1516245556?w=800', 13, '旅游小姐', '原创', '原创版权', 0, 1, 0, 0, 2200, 86, NOW(), NOW()),
(16, '淄博烧烤特种兵式打卡', '纪行', '进淄赶烤', '为了这一口卷饼，我坐了十小时高铁。', '<p>牧羊村、八大局全体验。</p>', '淄博,烧烤,特种兵旅行', 'https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=800', 14, '特种兵', '原创', '原创版权', 0, 1, 0, 0, 4800, 85, NOW(), NOW()),
(17, '日照万平口赶海记', '纪行', '大海的馈赠', '带上小铲子，出发！', '<p>退潮时分，是赶海的最好时机。</p>', '日照,赶海,亲子', 'https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=800', 16, '宝妈', '原创', '原创版权', 0, 0, 0, 0, 600, 84, NOW(), NOW()),

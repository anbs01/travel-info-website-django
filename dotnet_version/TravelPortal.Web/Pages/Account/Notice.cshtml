@page
@{
    ViewData["Title"] = "会员中心 - 功能完善中";
    Layout = "_SubPageLayout";
}

<div class="container-1200" style="padding: 60px 0; text-align: center;">
    
    <!-- 大标题 -->
    <h1 style="font-size: 32px; color: #333; font-weight: normal; margin-bottom: 40px; letter-spacing: 2px;">功能完善中，敬请期待</h1>

    <!-- 告知文案 -->
    <div style="max-width: 800px; margin: 0 auto; text-align: left; color: #666; font-size: 14px; line-height: 2; padding: 0 40px;">
        <p>亲爱的用户：</p>
        <p style="margin-top: 15px;">大家好～</p>
        <p>目前，网站会员功能正处于紧张完善中，各项核心权益与操作细节都在逐一打磨、优化，只为给大家带来更流畅、更贴心的使用体验。</p>
        <p>待完善完成后，会员将解锁更多专属权益。</p>
        <p style="margin-top: 20px;">我们不追求速度，只愿把每一处细节都做到稳妥，不辜负大家的期待。</p>
        <p>愿每一份真诚的创作都有回响，每一次温柔的表达都被看见，期待与你一起慢慢成长！</p>
        
        <p style="text-align: right; margin-top: 40px; color: #999;">网站运营团队</p>
    </div>

    <!-- 返回首页按钮 -->
    <div style="margin-top: 30px;">
        <a href="/" style="display: inline-block; padding: 6px 40px; border: 1px solid #c3a277; color: #c3a277; text-decoration: none; font-size: 16px; border-radius: 6px; transition: all 0.3s;">
            返回首页
        </a>
    </div>

</div>

<style>
    /* 按钮悬停效果 */
    a[href="/"]:hover {
        background: #fbf7f1;
        box-shadow: 0 2px 8px rgba(195,162,119,0.2);
    }
</style>

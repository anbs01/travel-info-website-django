@page
@{
    ViewData["Title"] = "会员登录 / 注册";
}

<div class="container-1200" style="padding: 80px 0; display: flex; justify-content: center;">
    <div style="width: 1000px; height: 550px; background: #fff; border: 1px solid #ebe2cf; display: flex; box-shadow: 0 10px 30px rgba(181,140,94,0.1); border-radius: 8px; overflow: hidden;">
        
        <!-- 左侧：品牌展示区 -->
        <div style="width: 450px; background: #fbf7f1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; border-right: 1px solid #ebe2cf;">
            <div style="width: 180px; height: 60px; border: 1px solid #c3a277; display: flex; align-items: center; justify-content: center; margin-bottom: 30px;">
                <span style="font-size: 24px; color: #6f4e37; font-weight: bold; letter-spacing: 4px;">网站LOGO</span>
            </div>
            <h2 style="font-size: 24px; color: #333; margin-bottom: 20px;">开启您的文化之旅</h2>
            <p style="color: #999; font-size: 16px; line-height: 1.8; text-align: center;">探索城乡街巷的韵味<br/>品鉴地道美食的醇香<br/>记录每一段珍贵的行走时光</p>
        </div>

        <!-- 右侧：表单区 -->
        <div style="flex: 1; padding: 50px 80px; display: flex; flex-direction: column; justify-content: center;">
            <div style="display: flex; gap: 40px; margin-bottom: 40px; border-bottom: 1px solid #eee;">
                <span id="tab-login" style="font-size: 20px; color: #b58c5e; font-weight: bold; padding-bottom: 15px; border-bottom: 3px solid #b58c5e; cursor: pointer;">会员登录</span>
                <span id="tab-reg" style="font-size: 20px; color: #999; padding-bottom: 15px; cursor: pointer;">立即注册</span>
            </div>

            <!-- 登录表单 -->
            <div id="form-login">
                <div style="margin-bottom: 25px;">
                    <input type="text" placeholder="手机号 / 账号" style="width: 100%; height: 50px; border: 1px solid #ddd; padding: 0 15px; font-size: 16px; outline: none; border-radius: 4px; box-sizing: border-box;" />
                </div>
                <div style="margin-bottom: 15px;">
                    <input type="password" placeholder="请输入密码" style="width: 100%; height: 50px; border: 1px solid #ddd; padding: 0 15px; font-size: 16px; outline: none; border-radius: 4px; box-sizing: border-box;" />
                </div>
                <div style="text-align: right; margin-bottom: 30px;">
                    <a href="#" style="color: #999; font-size: 14px; text-decoration: none;">忘记密码？</a>
                </div>
                <button style="width: 100%; height: 50px; background: #b58c5e; color: #fff; border: none; font-size: 18px; font-weight: bold; border-radius: 4px; cursor: pointer;">登 录</button>
            </div>
        </div>

    </div>
</div>

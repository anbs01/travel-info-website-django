@page "{id:int?}"
@model TravelPortal.Web.Pages.Travelogues.DetailsModel
@{
    ViewData["Title"] = "攻略详情";
    Layout = "_SubPageLayout";
}

<style>
    @@media (max-width: 1199px) {
        .detail-container { padding: 30px 15px !important; }
        .detail-info { flex-direction: column !important; gap: 10px !important; }
        .related-grid { grid-template-columns: 1fr !important; }
        #reportModal > div { width: 90% !important; padding: 20px !important; }
    }
</style>

<div class="bg-gray-50 pb-20">
    <!-- 1. 面包屑导航 (y: 140 - 192) -->
    <div style="background: #fff; border-top: 1px solid #b58c5e; border-bottom: 1px solid rgba(0,0,0,0.1); margin-bottom: 40px;">
        <div class="container-1200" style="height: 52px; display: flex; align-items: center; font-size: 12px; color: #676767;">
            你的位置：<a href="/" style="color: #676767;">首页</a> > <a href="/Travelogues" style="color: #676767;">纪行·攻略</a> > @Model.Travelogue?.Title
        </div>
    </div>

    <div class="container-1200 detail-container" style="background: #fff; padding: 60px 50px; min-height: 1000px; box-shadow: 0 0 20px rgba(0,0,0,0.05);">
        
        <!-- 2. 文章头部 (y: 280) -->
        <div style="margin-bottom: 40px;">
            <h1 style="font-size: 28px; font-weight: bold; color: #000; margin: 0 0 20px 0;">@Model.Travelogue?.Title</h1>
            <div class="detail-info" style="font-size: 12px; color: #999; display: flex; gap: 30px; padding-bottom: 20px; border-bottom: 1px solid #eee;">
                <span>来源：@(Model.Travelogue?.Source ?? "原创")</span>
                <span>作者：@(Model.Travelogue?.Author ?? "管理员")</span>
                <span>发布日期：@(Model.Travelogue?.PublishDate?.ToString("yyyy-MM-dd HH:mm:ss") ?? Model.Travelogue?.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss"))</span>
                <span>阅读：@Model.Travelogue?.Views</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Travelogue?.Summary))
        {
            <!-- 3. 概述模块 (y: 440) -->
            <div style="background: #f9f9f9; border: 1px solid #eee; padding: 20px 25px; border-radius: 4px; margin-bottom: 40px;">
                <p style="font-size: 13px; color: #555; line-height: 1.8; margin: 0;">
                    <strong style="color: #333;">概述 ：</strong> @Model.Travelogue.Summary
                </p>
            </div>
        }

        <!-- 4. 正文内容 -->
        <div style="font-size: 15px; color: #333; line-height: 2; letter-spacing: 0.5px;">
            @Html.Raw(Model.Travelogue?.Content)
        </div>

        <!-- 5. 底部版权与按钮 -->
        <div style="background: #fdfdfd; border: 1px dashed #ddd; padding: 20px; margin-top: 60px; font-size: 12px; color: #888; line-height: 1.6;">
            版权声明：本站内容部分来源于网络，如有侵权请联系删除。转载请注明出处。
        </div>

        <div style="margin-top: 40px; display: flex; justify-content: flex-end; gap: 15px;">
            <button onclick="document.getElementById('reportModal').style.display='flex'" style="background: #ff6600; color: #fff; border: none; padding: 6px 20px; border-radius: 2px; font-size: 12px; cursor: pointer;">我要揪错</button>
            <button onclick="window.close()" style="background: #666; color: #fff; border: none; padding: 6px 20px; border-radius: 2px; font-size: 12px; cursor: pointer;">关闭窗口</button>
        </div>

        <!-- 6. 相关推荐 -->
        @if (Model.Related.Any())
        {
            <div style="margin-top: 80px; padding-top: 40px; border-top: 1px solid #eee;">
                <h4 style="font-size: 16px; font-weight: bold; margin-bottom: 25px;">相关推荐</h4>
                <div class="related-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px 40px;">
                    @foreach (var r in Model.Related)
                    {
                        <div style="display: flex; align-items: center; font-size: 13px; color: #444; line-height: 2.2;">
                            <span style="width: 5px; height: 5px; background: #ccc; border-radius: 50%; margin-right: 10px; flex-shrink: 0;"></span>
                            <a asp-page="./Details" asp-route-id="@r.Id"
                               style="color: #444; text-decoration: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                               title="@r.Title">@r.Title</a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- 报错弹窗 -->
<div id="reportModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center;">
    <div style="width: 480px; background: #fff; padding: 30px; border-radius: 4px; position: relative;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h5 style="margin: 0; font-size: 16px; font-weight: bold;">我要报错</h5>
            <span onclick="document.getElementById('reportModal').style.display='none'" style="cursor: pointer; font-size: 20px; color: #999;">&times;</span>
        </div>
        <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 12px; color: #666; margin-bottom: 8px;">标题</label>
            <input type="text" style="width: 100%; height: 36px; border: 1px solid #ddd; padding: 0 10px; border-radius: 2px;" value="@Model.Travelogue?.Title" readonly />
        </div>
        <div style="margin-bottom: 30px;">
            <label style="display: block; font-size: 12px; color: #666; margin-bottom: 8px;">内容</label>
            <textarea style="width: 100%; height: 180px; border: 1px solid #ddd; padding: 10px; border-radius: 2px; resize: none;" placeholder="请描述您发现的错误..."></textarea>
        </div>
        <div style="display: flex; justify-content: center; gap: 15px;">
            <button style="background: #b58c5e; color: #fff; border: none; padding: 8px 30px; border-radius: 2px; cursor: pointer;">确定提交</button>
            <button onclick="document.getElementById('reportModal').style.display='none'" style="background: #eee; color: #666; border: none; padding: 8px 30px; border-radius: 2px; cursor: pointer;">取消提交</button>
        </div>
    </div>
</div>

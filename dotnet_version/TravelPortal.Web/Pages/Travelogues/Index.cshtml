@page
@model TravelPortal.Web.Pages.Travelogues.IndexModel
@{
    ViewData["Title"] = "纪行·攻略";
    Layout = "_SubPageLayout";
    var currentCategory = Model.Category ?? "travelogue";
    var categoryLabel = currentCategory == "guide" ? "攻略" : "纪行";
}

<div class="pb-20">
    <div class="container-1200" style="margin-top: 40px;">

        <!-- 1. 标题条 + 搜索 -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div style="width: 130px; height: 36px; background: #b58c5e; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 16px; font-weight: bold; border-radius: 2px;">
                纪行·攻略
            </div>
            <form method="get" style="display: flex; height: 30px; border: 1px solid #ddd; border-radius: 2px; overflow: hidden;">
                <input type="hidden" name="category" value="@currentCategory" />
                <input type="text" name="keyword" value="@Model.Keyword" style="width: 220px; border: none; outline: none; padding: 0 10px; font-size: 12px;" placeholder="输入关键字" />
                <button type="submit" style="width: 40px; background: #eee; border: none; border-left: 1px solid #ddd; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                    <svg style="width: 16px; height: 16px; color: #666;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </form>
        </div>

        <!-- 2. 分类筛选条 -->
        <div style="display: flex; align-items: center; border-bottom: 1px solid #f0f0f0; padding-bottom: 15px; margin-bottom: 40px; font-size: 12px;">
            <!-- 主分类 -->
            <div style="display: flex; gap: 10px; margin-right: 30px; flex-shrink: 0;">
                <a href="?category=travelogue"
                   style="padding: 4px 10px; border-radius: 2px; cursor: pointer; text-decoration: none; @(currentCategory == "travelogue" ? "background:#b58c5e;color:#fff;" : "background:#eee;color:#666;")">纪行</a>
                <a href="?category=guide"
                   style="padding: 4px 10px; border-radius: 2px; cursor: pointer; text-decoration: none; @(currentCategory == "guide" ? "background:#b58c5e;color:#fff;" : "background:#eee;color:#666;")">攻略</a>
            </div>
            <!-- 子类别 -->
            @if (Model.SubCategories.Any())
            {
                <div style="display: flex; flex-wrap: wrap; gap: 0 24px; color: #666;">
                    <a href="?category=@currentCategory"
                       style="cursor: pointer; text-decoration: none; color: @(string.IsNullOrEmpty(Model.Tag) ? "#000" : "#666"); font-weight: @(string.IsNullOrEmpty(Model.Tag) ? "bold" : "normal");">全部</a>
                    @foreach (var tag in Model.SubCategories)
                    {
                        <a href="?category=@currentCategory&tag=@Uri.EscapeDataString(tag)"
                           style="cursor: pointer; text-decoration: none; color: @(Model.Tag == tag ? "#000" : "#666"); font-weight: @(Model.Tag == tag ? "bold" : "normal");">@tag</a>
                    }
                </div>
            }
        </div>

        <!-- 3. 内容列表 -->
        <div style="display: flex; flex-direction: column; gap: 50px;">
            @if (Model.Travelogues.Items.Any())
            {
                foreach (var item in Model.Travelogues.Items)
                {
                    <div>
                        <!-- 标题 -->
                        <div style="display: flex; align-items: center; margin-bottom: 16px;">
                            <span style="width: 8px; height: 8px; background: #b58c5e; margin-right: 12px; border-radius: 1px; flex-shrink: 0;"></span>
                            <h2 style="font-size: 16px; font-weight: bold; color: #333; margin: 0;">
                                <a asp-page="./Details" asp-route-id="@item.Id" style="color: inherit; text-decoration: none;">@item.Title</a>
                            </h2>
                        </div>

                        <div style="display: flex;">
                            @if (!string.IsNullOrEmpty(item.MainImage))
                            {
                                <div style="width: 360px; height: 220px; flex-shrink: 0; overflow: hidden; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                                    <a asp-page="./Details" asp-route-id="@item.Id">
                                        <img src="@item.MainImage" style="width: 100%; height: 100%; object-fit: cover;" alt="@item.Title" />
                                    </a>
                                </div>
                            }
                            <div style="margin-left: @(!string.IsNullOrEmpty(item.MainImage) ? "36px" : "0"); flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
                                <p style="font-size: 13px; color: #666; line-height: 1.9; margin: 0; display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden;">
                                    @item.Summary
                                </p>
                                <div style="font-size: 12px; color: #999; display: flex; gap: 20px; margin-top: 16px;">
                                    @if (!string.IsNullOrEmpty(item.Author)) { <span>@item.Author</span> }
                                    <span>@(item.PublishDate?.ToString("yyyy-MM-dd") ?? item.CreatedAt.ToString("yyyy-MM-dd"))</span>
                                    <span>阅读 @item.Views</span>
                                    @if (!string.IsNullOrEmpty(item.Classification))
                                    {
                                        <span style="color: #b58c5e;">[@(item.Classification == "guide" ? "攻略" : "纪行")]</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div style="height: 1px; background: #f0f0f0; margin-top: 40px;"></div>
                    </div>
                }
            }
            else
            {
                <div style="padding: 100px 0; text-align: center; color: #999; font-size: 14px;">
                    暂无相关@categoryLabel内容
                </div>
            }
        </div>

        <!-- 4. 分页 -->
        <partial name="_FrontPagination" model="Model.Travelogues.Metadata" />

    </div>
</div>

@page
@model TravelPortal.Web.Pages.Places.IndexModel
@{
    ViewData["Title"] = "城乡 · 街巷";
    Layout = "_SubPageLayout";
}

<style>
    .filter-section { font-size: 14px; color: #666; margin-bottom: 40px; }
    .filter-row { display: flex; flex-wrap: wrap; gap: 10px 25px; padding: 15px 0; border-bottom: 1px solid #f2f2f2; }
    .filter-row a { text-decoration: none; color: #666; transition: color 0.2s; }
    .filter-row a:hover { color: #b58c5e; }
    .filter-row a.active { color: #b58c5e; font-weight: bold; }
    
    .spot-grid { 
        display: grid; 
        grid-template-columns: repeat(3, 1fr); 
        gap: 40px 30px; 
        margin-bottom: 50px;
    }
    
    .spot-card { display: flex; flex-direction: column; }
    .spot-card .card-img { 
        width: 100%; 
        aspect-ratio: 370 / 240; 
        overflow: hidden; 
        border-radius: 2px;
        background: #f8f8f8;
    }
    .spot-card .card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
    .spot-card:hover .card-img img { transform: scale(1.05); }
    
    .spot-card .card-title { 
        font-size: 18px; 
        font-weight: bold; 
        color: #333; 
        margin: 18px 0 10px 0; 
        text-decoration: none;
    }
    .spot-card .card-summary { 
        font-size: 14px; 
        color: #777; 
        line-height: 1.7; 
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    @@media (max-width: 991px) {
        .spot-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 575px) {
        .spot-grid { grid-template-columns: 1fr; }
        .list-header { flex-direction: column; gap: 15px; align-items: flex-start !important; }
    }
</style>

<div class="pb-20">
    <div class="container-1200" style="margin-top: 40px;">

        <!-- 标题与搜索 -->
        <div class="list-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div style="width: 125px; height: 33px; background: #b58c5e; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24px; font-weight: normal; font-family: 'Microsoft YaHei', sans-serif; border-radius: 2px; flex-shrink: 0; line-height: 1;">
                城乡 · 街巷
            </div>
            <partial name="_SearchBar" model='new { CurrentModule = "places", Keyword = Model.Keyword }' />
        </div>

        <!-- 过滤器 -->
        <div class="filter-section">
            <div class="filter-row">
                <a href="?geoId=@Model.GeoId" class="@(string.IsNullOrEmpty(Model.Category) ? "active" : "")">全部类别</a>
                @foreach (var cat in Model.Categories)
                {
                    <a href="?category=@Uri.EscapeDataString(cat)&geoId=@Model.GeoId" class="@(Model.Category == cat ? "active" : "")">@cat</a>
                }
            </div>
            <div class="filter-row" style="border-bottom: none;">
                <a href="?category=@Model.Category" class="@(!Model.GeoId.HasValue ? "active" : "")">全国范围</a>
                @foreach (var prov in Model.Provinces)
                {
                    <a href="?geoId=@prov.Id&category=@Model.Category" class="@(Model.GeoId == prov.Id ? "active" : "")">@prov.Title</a>
                }
            </div>
        </div>

        <!-- 网格列表 -->
        <div class="spot-grid">
            @foreach (var item in Model.SpotList.Items)
            {
                <div class="spot-card">
                    <a asp-page="./Details" asp-route-id="@item.Id" class="card-img">
                        @if (!string.IsNullOrEmpty(item.MainImage))
                        {
                            <img src="@item.MainImage" alt="@item.Title" />
                        }
                        else
                        {
                            <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#ccc;">暂无图片</div>
                        }
                    </a>
                    <a asp-page="./Details" asp-route-id="@item.Id" class="card-title">@item.Title</a>
                    <p class="card-summary">@item.Summary</p>
                </div>
            }
        </div>

        @if (!Model.SpotList.Items.Any())
        {
            <div style="padding:100px 0; text-align:center; color:#999; font-size:15px;">
                <div style="font-size: 40px; margin-bottom: 20px;">🏜️</div>
                此区域暂无城乡数据，请尝试切换其他分类或地区。
            </div>
        }

        <partial name="_FrontPagination" model="Model.SpotList.Metadata" />
    </div>
</div>

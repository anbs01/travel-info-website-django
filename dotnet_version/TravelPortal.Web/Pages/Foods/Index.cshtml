@page
@model TravelPortal.Web.Pages.Foods.IndexModel
@{
    ViewData["Title"] = "特产 · 美食";
    Layout = "_SubPageLayout";
    var currentType = Model.ProductType ?? "";
}

<style>
    @@media (max-width: 1199px) {
        .list-header { flex-direction: column !important; gap: 15px; align-items: flex-start !important; }
        .list-header > div:first-child { width: auto !important; height: 40px !important; padding: 0 15px; font-size: 20px !important; }
        .item-row { flex-direction: column !important; }
        .item-image { width: 100% !important; height: auto !important; aspect-ratio: 200/130; margin-bottom: 15px; }
        .item-content { margin-left: 0 !important; }
    }
</style>

<div class="pb-20">
    <div class="container-1200" style="margin-top: 40px;">

        <div class="list-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div style="width: 125px; height: 33px; background: #b58c5e; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24px; font-weight: normal; font-family: 'Microsoft YaHei', sans-serif; border-radius: 2px; flex-shrink: 0; line-height: 1;">
                特产 · 美食
            </div>
            <partial name="_SearchBar" model='new { CurrentModule = "foods", Keyword = Model.Keyword }' />
        </div>

        <!-- 主分类 + 子类别 -->
        <div style="display:flex; align-items:center; border-bottom:1px solid #f0f0f0; padding-bottom:15px; margin-bottom:40px; font-size:12px; flex-wrap:wrap; gap:10px 0;">
            <div style="display:flex; gap:8px; margin-right:24px; flex-shrink:0;">
                <a href="?" style="padding:3px 10px; border-radius:2px; text-decoration:none; @(string.IsNullOrEmpty(currentType)?"background:#b58c5e;color:#fff;":"background:#eee;color:#666;")">全部</a>
                <a href="?productType=特产" style="padding:3px 10px; border-radius:2px; text-decoration:none; @(currentType == "特产" ? "background:#b58c5e;color:#fff;" : "background:#eee;color:#666;")">特产</a>
                <a href="?productType=美食" style="padding:3px 10px; border-radius:2px; text-decoration:none; @(currentType == "美食" ? "background:#b58c5e;color:#fff;" : "background:#eee;color:#666;")">美食</a>
            </div>
            @{
                var subCats = currentType == "特产" ? Model.SpecialtyCategories : Model.CuisineCategories;
            }
            @if (subCats.Any())
            {
                <div style="display:flex; flex-wrap:wrap; gap:0 20px; color:#666;">
                    <a href="?productType=@currentType" style="text-decoration:none; color:@(string.IsNullOrEmpty(Model.Category)?"#000":"#666"); font-weight:@(string.IsNullOrEmpty(Model.Category)?"bold":"normal");">全部</a>
                    @foreach (var cat in subCats)
                    {
                        <a href="?productType=@currentType&category=@Uri.EscapeDataString(cat)"
                           style="text-decoration:none; color:@(Model.Category==cat?"#000":"#666"); font-weight:@(Model.Category==cat?"bold":"normal");">@cat</a>
                    }
                </div>
            }
        </div>

        <!-- 列表 -->
        <div style="display:flex; flex-direction:column; gap:40px;">
            @foreach (var item in Model.FoodList.Items)
            {
                <div>
                    <div style="display:flex; align-items:center; margin-bottom:12px;">
                        <span style="width:8px; height:8px; background:#b58c5e; margin-right:12px; border-radius:1px; flex-shrink:0;"></span>
                        <h2 style="font-size:16px; font-weight:bold; color:#333; margin:0;">
                            <a asp-page="./Details" asp-route-id="@item.Id" target="_blank" style="color:inherit; text-decoration:none;">@item.Title</a>
                        </h2>
                    </div>
                    <div class="item-row" style="display:flex;">
                        @if (!string.IsNullOrEmpty(item.MainImage))
                        {
                            <div class="item-image" style="width: 225px; height: 150px; flex-shrink: 0; overflow: hidden; border-radius: 3px;">
                                <a asp-page="./Details" asp-route-id="@item.Id" target="_blank">
                                    <img src="@item.MainImage" style="width: 100%; height: 100%; object-fit: cover;" alt="@item.Title" />
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="item-image" style="width: 225px; height: 150px; flex-shrink: 0; overflow: hidden; border-radius: 3px; background: #f0f0f0; display: flex; align-items: center; justify-content: center;">
                                <img src="/images/noimage.png" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="暂无图片" />
                            </div>
                        }
                        <div class="item-content" style="margin-left:20px; flex:1; display:flex; flex-direction:column; justify-content:space-between;">
                            <p style="font-size:13px; color:#666; line-height:1.9; margin:0; display:-webkit-box; -webkit-line-clamp:4; -webkit-box-orient:vertical; overflow:hidden;">@item.Summary</p>
                            <div style="font-size:12px; color:#999; display:flex; gap:16px; margin-top:12px;">
                                @if (!string.IsNullOrEmpty(item.ProductType)) { <span>@item.ProductType</span> }
                                @if (!string.IsNullOrEmpty(item.NonLegacyLevel)) { <span>@item.NonLegacyLevel</span> }
                                <span>@item.CreatedAt.ToString("yyyy-MM-dd")</span>
                            </div>
                        </div>
                    </div>
                    <div style="height:1px; background:#f0f0f0; margin-top:30px;"></div>
                </div>
            }
            @if (!Model.FoodList.Items.Any())
            {
                <div style="padding:80px 0; text-align:center; color:#999; font-size:14px;">暂无相关数据</div>
            }
        </div>

        <partial name="_FrontPagination" model="Model.FoodList.Metadata" />
    </div>
</div>

@page
@model TravelPortal.Web.Pages.News.IndexModel
@{
    ViewData["Title"] = "资讯 · 动态";
    Layout = "_SubPageLayout";
}

<style>
    @@media (max-width: 1199px) {
        .item-row { flex-direction: column !important; }
        .item-image { width: 100% !important; height: auto !important; aspect-ratio: 180/120; margin-bottom: 15px; }
        .item-content { margin-left: 0 !important; }
    }
</style>

<div class="pb-20">
    <div class="container-1200" style="margin-top: 40px;">

        <div class="list-header">
            <div class="title-block">资讯 · 动态</div>
            <partial name="_SearchBar" model='new { CurrentModule = "news", Keyword = Model.Keyword }' />
        </div>

        <!-- 子类别筛选 -->
        @if (Model.Categories.Any())
        {
            <div style="display: flex; flex-wrap: wrap; gap: 0 20px; border-bottom: 1px solid #f0f0f0; padding-bottom: 15px; margin-bottom: 40px; font-size: 12px;">
                <a href="?" style="text-decoration:none; color:@(string.IsNullOrEmpty(Model.Category)?"#000":"#666"); font-weight:@(string.IsNullOrEmpty(Model.Category)?"bold":"normal");">全部</a>
                @foreach (var cat in Model.Categories)
                {
                    <a href="?category=@Uri.EscapeDataString(cat)"
                       style="text-decoration:none; color:@(Model.Category==cat?"#000":"#666"); font-weight:@(Model.Category==cat?"bold":"normal");">@cat</a>
                }
            </div>
        }

        <!-- 列表 -->
        <div style="display: flex; flex-direction: column; gap: 40px;">
            @foreach (var item in Model.NewsList.Items)
            {
                <div>
                    <div style="display: flex; align-items: center; margin-bottom: 12px;">
                        <span style="width: 8px; height: 8px; background: #b58c5e; margin-right: 12px; border-radius: 1px; flex-shrink: 0;"></span>
                        <h2 style="font-size: 16px; font-weight: bold; color: #333; margin: 0;">
                            <a asp-page="./Details" asp-route-id="@item.Id" target="_blank" style="color: inherit; text-decoration: none;">@item.Title</a>
                        </h2>
                    </div>
                    <div class="item-row" style="display: flex;">
                        @if (!string.IsNullOrEmpty(item.MainImage))
                        {
                            <div class="item-image" style="width: 180px; height: 120px; flex-shrink: 0; overflow: hidden; border-radius: 3px;">
                                <a asp-page="./Details" asp-route-id="@item.Id" target="_blank">
                                    <img src="@item.MainImage" style="width: 100%; height: 100%; object-fit: cover;" alt="@item.Title" />
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="item-image" style="width: 180px; height: 120px; flex-shrink: 0; overflow: hidden; border-radius: 3px; background: #f0f0f0; display: flex; align-items: center; justify-content: center;">
                                <img src="/images/noimage.png" style="max-width: 60%; max-height: 60%; object-fit: contain; opacity: 0.5;" alt="暂无图片" />
                            </div>
                        }
                        <div class="item-content" style="margin-left: 24px; flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
                            <p style="font-size:13px; color:#666; line-height:1.9; margin:0; display:-webkit-box; -webkit-line-clamp:4; -webkit-box-orient:vertical; overflow:hidden;">@item.Summary</p>
                            <div style="font-size:12px; color:#999; display:flex; gap:20px; margin-top:12px;">
                                @if (!string.IsNullOrEmpty(item.Source)) { <span>来源：@item.Source</span> }
                                @if (!string.IsNullOrEmpty(item.Author)) { <span>作者：@item.Author</span> }
                                <span>@(item.PublishDate?.ToString("yyyy-MM-dd") ?? item.CreatedAt.ToString("yyyy-MM-dd"))</span>
                            </div>
                        </div>
                    </div>
                    <div style="height:1px; background:#f0f0f0; margin-top:30px;"></div>
                </div>
            }
            @if (!Model.NewsList.Items.Any())
            {
                <div style="padding:80px 0; text-align:center; color:#999; font-size:14px;">暂无相关资讯</div>
            }
        </div>

        <partial name="_FrontPagination" model="Model.NewsList.Metadata" />
    </div>
</div>

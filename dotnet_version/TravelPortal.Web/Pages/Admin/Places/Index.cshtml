@page "/Admin/Places"
@model TravelPortal.Web.Pages.Admin.Places.IndexModel
@{
    ViewData["Title"] = "目的地管理";
    Layout = "../Shared/_AdminLayout";
}

<div class="flex justify-between items-center mb-6">
    <div class="text-sm text-gray-500">共 @Model.PlaceList.Count 条记录</div>
    <a href="/Admin/Places/Create" class="bg-design-primary text-white px-4 py-2 rounded shadow hover:bg-blue-700 transition-colors">
        + 新增目的地
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">主图</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">名称</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">English Code</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">操作</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @foreach (var item in Model.PlaceList)
            {
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4">
                        <img src="@item.MainImage" class="w-12 h-12 rounded object-cover" onerror="this.src='/images/noimage.png'" />
                    </td>
                    <td class="px-6 py-4 font-medium">@item.Name</td>
                    <td class="px-6 py-4 text-gray-500">@item.EnglishCode</td>
                    <td class="px-6 py-4 space-x-3">
                        <a href="/Admin/Places/Edit/@item.Id" class="text-blue-600 hover:underline text-sm">编辑</a>
                        <button class="text-red-600 hover:underline text-sm">删除</button>
                    </td>
                </tr>
            }
            @if (!Model.PlaceList.Any())
            {
                <tr>
                    <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic">暂无数据，请点击“新增目的地”开始录入。</td>
                </tr>
            }
        </tbody>
    </table>
</div>

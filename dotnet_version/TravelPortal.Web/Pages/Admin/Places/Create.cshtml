@page "/Admin/Places/Create"
@model TravelPortal.Web.Pages.Admin.Places.CreateModel
@{
    ViewData["Title"] = "新增城镇目的地";
    Layout = "../Shared/_AdminLayout";
}

<form method="post" class="space-y-8">
    <div class="flex items-center justify-between border-b border-gray-100 pb-4">
        <div class="text-sm text-gray-500">基础信息设置</div>
        <div class="space-x-3">
            <a href="/Admin/Places" class="text-gray-400 hover:text-gray-600 text-sm">取消</a>
            <button type="submit" class="bg-brand text-white px-6 py-2 rounded-xl font-bold shadow-lg shadow-brand/20">保存目的地</button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- 左侧：核心标题 -->
        <div class="space-y-6">
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase mb-2">目的地简称 (Title)</label>
                <input asp-for="Input.Title" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all" placeholder="如：乌镇" />
                <span asp-validation-for="Input.Title" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase mb-2">英文代码 (URL Slug)</label>
                <input asp-for="Input.EnglishCode" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all" placeholder="用于URL，如：wuzhen" />
                <p class="mt-1 text-[10px] text-gray-400">一旦设定不可修改，影响SEO路径</p>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase mb-2">级别/品别标签</label>
                <input asp-for="Input.LevelTag" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl" placeholder="如：5A级景区 / 历史名镇" />
            </div>
        </div>

        <!-- 右侧：配置项 -->
        <div class="space-y-6">
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase mb-2">所属地区 (Region)</label>
                <select asp-for="Input.RegionId" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl outline-none">
                    <option value="">-- 请选择省份/国家 --</option>
                    @foreach (var r in Model.RegionOptions)
                    {
                        <option value="@r.Id">@r.FullName</option>
                    }
                </select>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase mb-2">特色标签 (逗号隔开)</label>
                <input asp-for="Input.FeatureTags" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl" placeholder="如：亲子,观海,小火车" />
            </div>

            <div class="flex items-center space-x-6 pt-4">
                <label class="flex items-center space-x-2 cursor-pointer">
                    <input type="checkbox" asp-for="Input.IsHome" class="w-4 h-4 text-brand rounded focus:ring-brand" />
                    <span class="text-sm font-medium text-gray-700">首页推荐</span>
                </label>
                <label class="flex items-center space-x-2 cursor-pointer">
                    <input type="checkbox" asp-for="Input.IsSticky" class="w-4 h-4 text-brand rounded focus:ring-brand" />
                    <span class="text-sm font-medium text-gray-700">置顶显示</span>
                </label>
            </div>
        </div>
    </div>

    <!-- 详情导语 -->
    <div>
        <label class="block text-xs font-bold text-gray-400 uppercase mb-2">详情页导语 (Summary)</label>
        <textarea asp-for="Input.Summary" rows="3" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl outline-none" placeholder="一两句话简述该目的地的特色..."></textarea>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

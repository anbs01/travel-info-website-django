@page
@model TravelPortal.Web.Pages.Admin.HotWords.IndexModel
@{
    ViewData["Title"] = "类别热词管理";
    var currentTabName = IndexModel.Tabs.FirstOrDefault(t => t.Id == Model.Module).Name ?? "热词";
}

<div x-data="{ showModal: false }" class="space-y-6">

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

        <!-- Tab 选项卡 -->
        <div class="flex flex-wrap border-b border-gray-50 bg-gray-50/30">
            @foreach (var tab in IndexModel.Tabs)
            {
                <a asp-route-module="@tab.Id"
                   class="px-5 py-4 text-sm font-bold transition-all @(Model.Module == tab.Id ? "bg-white text-brand border-t-2 border-brand" : "text-gray-400 hover:text-gray-600")">
                    @tab.Name
                </a>
            }
        </div>

        <!-- 操作栏 -->
        <div class="p-6 flex items-center justify-between bg-white border-b border-gray-50">
            <span class="text-sm text-gray-500">当前：<span class="font-bold text-gray-700">@currentTabName</span></span>
            <button @@click="showModal = true"
                    class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 active:scale-95 transition-all">
                + 添加热词
            </button>
        </div>

        <!-- 数据列表 -->
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-6 py-4">热词名称</th>
                        <th class="px-6 py-4 w-24 text-center">排序</th>
                        <th class="px-6 py-4 w-24 text-center">状态</th>
                        <th class="px-6 py-4 w-32 text-right">操作</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.HotWords.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="font-medium text-gray-700 group-hover:text-brand transition-colors">@item.Name</span>
                            </td>
                            <td class="px-6 py-4 text-center text-xs text-gray-400 font-mono">@item.SortOrder</td>
                            <td class="px-6 py-4 text-center">
                                @if (item.IsHidden)
                                {
                                    <span class="px-2 py-0.5 bg-red-50 text-red-500 rounded-full text-[10px] font-bold">已屏蔽</span>
                                }
                                else
                                {
                                    <span class="px-2 py-0.5 bg-green-50 text-green-500 rounded-full text-[10px] font-bold">正常</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <form method="post" asp-page-handler="ToggleHidden" class="inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="Module" value="@Model.Module" />
                                        <button type="submit" class="px-3 py-1 text-[10px] font-bold rounded-lg @(item.IsHidden ? "bg-green-50 text-green-600 hover:bg-green-100" : "bg-gray-100 text-gray-500 hover:bg-gray-200") transition-all">
                                            @(item.IsHidden ? "恢复" : "屏蔽")
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" class="inline"
                                          onsubmit="return confirm('确定删除「@item.Name」吗？')">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="Module" value="@Model.Module" />
                                        <button type="submit" class="px-3 py-1 text-[10px] font-bold bg-red-50 text-red-500 hover:bg-red-100 rounded-lg transition-all">删除</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.HotWords.Items.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-16 text-center text-gray-400 text-sm">
                                暂无数据，点击右上角添加热词
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model.HotWords.Metadata" />
    </div>

    <!-- 添加弹窗 -->
    <div x-show="showModal" x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm"
         x-transition:enter="ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0">
        <div @@click.away="showModal = false"
             class="bg-white rounded-2xl w-full max-w-md shadow-2xl overflow-hidden"
             x-transition:enter="ease-out duration-200" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100">

            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                <h3 class="font-bold text-gray-800">添加「@currentTabName」热词</h3>
                <button @@click="showModal = false" class="text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <form method="post" asp-page-handler="Add" class="p-6 space-y-5">
                <input type="hidden" name="Module" value="@Model.Module" />

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">热词名称 <span class="text-red-500">*</span></label>
                    <input asp-for="NewHotWord.Name" required placeholder="例如：深度游、鲁菜、工艺礼品..."
                           class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm" />
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">排序权重</label>
                    <input asp-for="NewHotWord.SortOrder" type="number" value="0"
                           class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm" />
                    <p class="text-[10px] text-gray-400 mt-1">数字越小越靠前</p>
                </div>

                <div class="pt-2 flex justify-end gap-3">
                    <button type="button" @@click="showModal = false"
                            class="px-6 py-2.5 text-sm font-bold text-gray-500 hover:bg-gray-100 rounded-xl transition-all">取消</button>
                    <button type="submit"
                            class="px-8 py-2.5 bg-brand text-white rounded-xl text-sm font-bold shadow-lg shadow-brand/20 hover:opacity-90 transition-all">确认添加</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>[x-cloak] { display: none !important; }</style>

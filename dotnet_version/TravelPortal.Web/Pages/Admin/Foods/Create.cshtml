@page
@model TravelPortal.Web.Pages.Admin.Foods.CreateModel
@{
    ViewData["Title"] = "添加美食";
}

<div class="max-w-6xl mx-auto bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden mb-20">
    <!-- 头部 -->
    <div class="px-10 py-6 border-b border-gray-50 bg-gray-50/50">
        <h1 class="text-xl font-bold text-gray-800">添加特色美食</h1>
        <div class="flex space-x-4 mt-2 text-xs text-gray-400">
            <span>特色美食</span>
            <span>&gt;</span>
            <span class="text-brand font-bold">发布产品</span>
        </div>
    </div>

    <form method="post" class="p-10 space-y-10">

        <!-- 1. 名称组 -->
        <div class="space-y-6">
            <!-- 产品名称 -->
            <div class="flex items-start space-x-6">
                <label class="w-24 pt-3 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>产品名称</label>
                <div class="flex-1 space-y-2">
                    <input asp-for="Food.Title" class="w-full px-5 py-3 bg-gray-50 border border-gray-100 rounded-xl focus:ring-2 focus:ring-brand/20 transition-all font-bold text-lg" placeholder="美食/特产简称，用于列表显示" required />
                </div>
            </div>
        </div>

        <!-- 2. 产品分类 -->
        <div class="flex items-center space-x-6">
            <label class="w-24 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>产品分类</label>
            <div class="flex items-center space-x-6" id="categoryContainer">
                @foreach (var cat in new[] { "美食", "特产" })
                {
                    <label class="flex items-center space-x-2 cursor-pointer group">
                        <input type="radio" asp-for="Food.Category" value="@cat" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand category-radio" />
                        <span class="text-sm text-gray-600 group-hover:text-brand">@cat</span>
                    </label>
                }
            </div>
        </div>

        <!-- 3. 联动属性区域 -->
        <div id="dynamicFields" class="space-y-10">
            <!-- 美食特定字段 -->
            <div id="foodFields" class="hidden space-y-6 border-l-4 border-brand/10 pl-6">
                <div class="flex items-center space-x-6">
                    <label class="w-24 text-sm font-bold text-gray-700 text-right">美食菜系</label>
                    <select asp-for="Food.Cuisine" class="w-64 px-4 py-2 bg-gray-50 border border-gray-100 rounded-lg text-sm appearance-none">
                        <option value="">-- 请选择菜系（从热词加载） --</option>
                        <option value="鲁菜">鲁菜</option>
                        <option value="川菜">川菜</option>
                        <option value="粤菜">粤菜</option>
                        <option value="苏菜">苏菜</option>
                    </select>
                </div>
            </div>

            <!-- 特产特定字段 -->
            <div id="specialtyFields" class="hidden space-y-10 border-l-4 border-brand/10 pl-6">
                <div class="flex items-center space-x-6">
                    <label class="w-24 text-sm font-bold text-gray-700 text-right">特产分类</label>
                    <select asp-for="Food.SpecialtyCategory" class="w-64 px-4 py-2 bg-gray-50 border border-gray-100 rounded-lg text-sm appearance-none">
                        <option value="">-- 请选择特产细分（从特产数据加载） --</option>
                        <option value="水果蔬菜">水果蔬菜</option>
                        <option value="干货调料">干货调料</option>
                        <option value="传统工艺">传统工艺</option>
                    </select>
                </div>

                <div class="flex items-center space-x-6">
                    <label class="w-24 text-sm font-bold text-gray-700 text-right">特产级别</label>
                    <div class="flex items-center space-x-6">
                        @foreach (var level in new[] { "无公害产品", "绿色产品", "有机产品", "地理标志产品" })
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Food.SpecialtyLevel" value="@level" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand" />
                                <span class="text-sm text-gray-600 group-hover:text-brand">@level</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="flex items-center space-x-6">
                    <label class="w-24 text-sm font-bold text-gray-700 text-right">非遗级别</label>
                    <div class="flex items-center space-x-6">
                        @foreach (var level in new[] { "国际家非遗", "省级非遗", "市级非遗", "县级非遗" })
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Food.IntangibleHeritageLevel" value="@level" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand" />
                                <span class="text-sm text-gray-600 group-hover:text-brand">@level</span>
                            </label>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. 发布日期 -->
        <div class="flex items-center space-x-6">
            <label class="w-24 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>发布日期</label>
            <div class="flex-1">
                <input asp-for="Food.PublishDate" type="date" class="px-4 py-2 bg-gray-50 border border-gray-100 rounded-lg text-sm focus:ring-1 focus:ring-brand/20 w-64" required />
            </div>
        </div>

        <!-- 5. 产品介绍 -->
        <div class="flex items-start space-x-6">
            <label class="w-24 pt-3 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>产品介绍</label>
            <div class="flex-1 space-y-3">
                <textarea asp-for="Food.Content" rows="12" class="w-full p-6 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-brand/20 transition-all text-sm leading-relaxed" placeholder="请输入美食/特产详细介绍、口感、制作方法等..." required></textarea>
                <p class="text-[10px] text-red-400">产品编辑器，支持上传图片、视频等</p>
            </div>
        </div>

        <!-- 6. 焦点图 -->
        <div class="flex items-start space-x-6">
            <label class="w-24 pt-8 text-sm font-bold text-gray-700 text-right">焦点图</label>
            <div class="flex items-center space-x-6">
                <div class="w-32 h-32 bg-gray-50 border-2 border-dashed border-gray-100 rounded-2xl flex flex-col items-center justify-center text-gray-300 hover:border-brand/30 cursor-pointer transition-all">
                    <span class="text-xs font-medium">上传图片</span>
                    <span class="text-lg">+</span>
                </div>
                <div class="flex-1">
                    <p class="text-[10px] text-red-400 max-w-md leading-relaxed">前台列表显示的焦点封面图，建议比例 4:3</p>
                </div>
            </div>
        </div>

        <!-- 7. 关联城乡 -->
        <div class="flex items-center space-x-6">
            <label class="w-24 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>关联城乡</label>
            <div class="flex-1">
                <select asp-for="Food.PlaceId" asp-items="Model.PlaceList" class="w-64 px-4 py-2 bg-gray-50 border border-gray-100 rounded-lg text-sm focus:ring-1 focus:ring-brand/20 appearance-none">
                    <option value="">-- 请选择所属城镇 --</option>
                </select>
            </div>
        </div>

        <!-- 9. 作者与来源 -->
        <div class="space-y-6">
            <div class="flex items-center space-x-6">
                <label class="w-24 text-sm font-bold text-gray-700 text-right">美食作者</label>
                <input asp-for="Food.Author" class="w-64 px-4 py-2 bg-gray-50 border border-gray-100 rounded-lg text-sm" />
            </div>
            <div class="flex items-center space-x-6">
                <label class="w-24 text-sm font-bold text-gray-700 text-right">美食来源</label>
                <input asp-for="Food.Source" class="w-64 px-4 py-2 bg-gray-50 border border-gray-100 rounded-lg text-sm" />
            </div>
        </div>

        <!-- 10. 版权与水印 -->
        <div class="space-y-6 pt-6 border-t border-gray-50">
            <div class="flex items-center space-x-6">
                <label class="w-24 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>版权选择</label>
                <div class="flex items-center space-x-6">
                    @foreach (var cp in new[] { "原创版权", "转载声明", "商家授权" })
                    {
                        <label class="flex items-center space-x-2 cursor-pointer group">
                            <input type="radio" asp-for="Food.CopyrightType" value="@cp" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand" />
                            <span class="text-sm text-gray-600 group-hover:text-brand">@cp</span>
                        </label>
                    }
                    <span class="text-[10px] text-red-400">(引用在前台显示的内容，在综里有管理)</span>
                </div>
            </div>

            <div class="flex items-center space-x-6">
                <label class="w-24 text-sm font-bold text-gray-700 text-right">图片水印</label>
                <div class="flex items-center space-x-8">
                    <label class="flex items-center space-x-2 cursor-pointer group">
                        <input type="checkbox" asp-for="Food.ShowWatermark" class="w-4 h-4 rounded text-brand border-gray-300 focus:ring-brand" />
                        <span class="text-sm text-gray-600 group-hover:text-brand">显示水印</span>
                    </label>
                    <div class="flex items-center space-x-4 border-l pl-8 border-gray-100">
                        <span class="text-xs text-gray-400">水印位置</span>
                        @foreach (var pos in new[] { "中正", "中下", "右下" })
                        {
                                                <label class="flex items-center space-x-2 cursor-pointer group">
                                                    <input type="radio" asp-for="Food.WatermarkPos" value="@pos" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand" />
                                                    <span class="text-sm text-gray-600 group-hover:text-brand">@pos</span>
                                                </label>
                        }
                    </div>
                    <span class="text-[10px] text-red-400">(指详情页里的图片，在前台显示时，是否显示网的站水印)</span>
                </div>
            </div>

            <div class="flex items-center space-x-6">
                <label class="w-24 text-sm font-bold text-gray-700 text-right">显示设置</label>
                <div class="flex items-center space-x-4">
                    <label class="flex items-center space-x-2 cursor-pointer group">
                        <input type="checkbox" asp-for="Food.IsHome" class="w-4 h-4 rounded text-brand border-gray-300 focus:ring-brand" />
                        <span class="text-sm text-gray-600 group-hover:text-brand">显示网站首页</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- 11. 提交 -->
        <div class="flex items-center space-x-6 pt-10 border-t border-gray-50">
            <div class="w-24"></div>
            <div class="flex space-x-4">
                <button type="submit" class="px-10 py-2.5 bg-brand text-white rounded shadow-sm hover:shadow-md transition-all text-sm font-bold">提交产品</button>
                <button type="reset" class="px-10 py-2.5 bg-gray-100 text-gray-600 rounded hover:bg-gray-200 transition-all text-sm font-bold">重置</button>
            </div>
        </div>

    </form>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const foodFields = document.getElementById('foodFields');
        const specialtyFields = document.getElementById('specialtyFields');
        const radios = document.querySelectorAll('.category-radio');

        function toggleFields(value) {
            if (value === '美食') {
                foodFields.classList.remove('hidden');
                specialtyFields.classList.add('hidden');
            } else if (value === '特产') {
                foodFields.classList.add('hidden');
                specialtyFields.classList.remove('hidden');
            } else {
                foodFields.classList.add('hidden');
                specialtyFields.classList.add('hidden');
            }
        }

        radios.forEach(radio => {
            radio.addEventListener('change', (e) => toggleFields(e.target.value));
            if (radio.checked) toggleFields(radio.value);
        });
    });
</script>
}

<style>
    textarea { resize: none; }
    input:focus, textarea:focus, select:focus { outline: none; border-color: #A67C52; }
    .hidden { display: none; }
</style>

@page
@model TravelPortal.Web.Pages.Admin.Foods.CreateModel
@{
    ViewData["Title"] = "发布特色美食";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]" x-data="foodForm()">
    <partial name="_AdminPageHeader" model='new { 
        Title = "发布特色美食", 
        Subtitle = "Regional Specialty & Food Management",
        Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4\"></path></svg>",
        Tabs = new[] {
            new { Name = "美食列表", Url = Url.Page("Index"), IsActive = false },
            new { Name = "发布产品", Url = Url.Page("Create"), IsActive = true }
        }
    }' />

    <form method="post" enctype="multipart/form-data" class="p-8 space-y-10">
        <!-- Basic Info Section -->
        <section class="space-y-6">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">基本信息</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-gray-700 mb-2">产品名称 <span class="text-red-500">*</span></label>
                    <input type="text" asp-for="Food.Title" required placeholder="例如：鲅鱼饺子、海参、红烧狮子头..."
                           class="w-full px-5 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-lg font-medium">
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-gray-700 mb-3">选择类别 <span class="text-red-500">*</span></label>
                    <div class="flex items-center space-x-8 p-4 bg-gray-50 rounded-xl border border-gray-100">
                        @foreach (var cat in new[] { "美食", "特产" })
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Food.ProductType" value="@cat" x-model="category"
                                       class="w-5 h-5 text-brand border-gray-300 focus:ring-brand transition-all">
                                <span class="text-sm font-medium text-gray-600 group-hover:text-brand transition-colors">@cat</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- 美食菜系 (仅美食) -->
                <div x-show="category === '美食'" x-cloak x-transition class="md:col-span-2">
                    <label class="block text-sm font-bold text-gray-700 mb-3">美食菜系</label>
                    <div class="flex flex-wrap gap-4 p-4 bg-blue-50/30 rounded-xl border border-blue-100">
                        @foreach (var cat in Model.CuisineCategories)
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Food.Classification" value="@cat"
                                       class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500">
                                <span class="text-sm text-gray-600 group-hover:text-blue-600">@cat</span>
                            </label>
                        }
                        @if (!Model.CuisineCategories.Any())
                        {
                            <span class="text-xs text-gray-400 italic">请在“综合管理”中添加“美食菜系”热词</span>
                        }
                    </div>
                </div>

                <!-- 特产分类 (仅特产) -->
                <div x-show="category === '特产'" x-cloak x-transition class="md:col-span-2">
                    <label class="block text-sm font-bold text-gray-700 mb-3">特产分类</label>
                    <div class="flex flex-wrap gap-4 p-4 bg-orange-50/30 rounded-xl border border-orange-100">
                        @foreach (var cat in Model.SpecialtyCategories)
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Food.Classification" value="@cat"
                                       class="w-4 h-4 text-orange-600 border-gray-300 focus:ring-orange-500">
                                <span class="text-sm text-gray-600 group-hover:text-orange-600">@cat</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- 特产级别 (仅特产) -->
                <div x-show="category === '特产'" x-cloak x-transition class="md:col-span-2">
                    <label class="block text-sm font-bold text-gray-700 mb-3">特产级别</label>
                    <div class="flex flex-wrap gap-3">
                        @foreach (var level in new[] { "无公害产品", "绿色产品", "有机产品", "地理标志产品" })
                        {
                            <label class="relative flex items-center group cursor-pointer">
                                <input type="radio" asp-for="Food.SpecialtyLevel" value="@level" class="peer sr-only">
                                <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-orange-50 peer-checked:border-orange-600 peer-checked:text-orange-700 transition-all group-hover:border-orange-300">
                                    @level
                                </div>
                            </label>
                        }
                    </div>
                </div>

                <!-- 非遗级别 -->
                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-gray-700 mb-3">非遗级别</label>
                    <div class="flex flex-wrap gap-3">
                        @foreach (var level in new[] { "国家级非遗", "省级非遗", "市级非遗", "县级非遗" })
                        {
                            <label class="relative flex items-center group cursor-pointer">
                                <input type="radio" asp-for="Food.NonLegacyLevel" value="@level" class="peer sr-only">
                                <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-indigo-50 peer-checked:border-indigo-600 peer-checked:text-indigo-700 transition-all group-hover:border-indigo-300">
                                    @level
                                </div>
                            </label>
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- Media Section -->
        <section class="space-y-6 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">焦点图片与摘要</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-4">
                    <label class="block text-sm font-bold text-gray-700">焦点图</label>
                    <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden bg-gray-50 border-2 border-dashed border-gray-200 group hover:border-brand transition-all cursor-pointer"
                         @@click="$refs.fileInput.click()">
                        <template x-if="imageUrl">
                            <img :src="imageUrl" class="w-full h-full object-cover" />
                        </template>
                        <template x-if="!imageUrl">
                            <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-400">
                                <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
                                <span class="text-xs font-medium">上传封面图</span>
                            </div>
                        </template>
                        <input type="file" x-ref="fileInput" name="MainImageFile" class="hidden" @@change="previewImage" accept="image/*">
                    </div>
                </div>

                <div class="space-y-4">
                    <label class="block text-sm font-bold text-gray-700">口味特色 <span class="text-red-500">*</span></label>
                    <textarea asp-for="Food.Summary" rows="8" maxlength="120" x-ref="tasteText"
                              class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm"
                              placeholder="请输入口味特色，建议120字以内..."></textarea>
                    <div class="flex justify-between items-center">
                         <span class="text-[10px] text-gray-400 font-medium">要求120汉字以内</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Content Section -->
        <section class="space-y-6 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">详细正文</h2>
            </div>
            <div class="rounded-xl overflow-hidden border border-gray-100">
                <textarea id="editor" asp-for="Food.Content"></textarea>
            </div>
            <partial name="_TinyMCE" model='new { Selector = "#editor", Height = 600 }' />
        </section>

        <!-- Extra Info Section -->
        <section class="space-y-6 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">扩展信息</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">选择地区 <span class="text-red-500">*</span></label>
                    <select asp-for="Food.GeoId" asp-items="Model.GeoList" required
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl text-sm focus:ring-2 focus:ring-brand/20 transition-all">
                        <option value="">-- 请选择所属地区 --</option>
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">文章作者</label>
                        <input type="text" asp-for="Food.Author" class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 transition-all text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">文章来源</label>
                        <input type="text" asp-for="Food.Source" class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 transition-all text-sm">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">原文链接</label>
                    <input type="url" asp-for="Food.OriginUrl" placeholder="https://..."
                           class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 transition-all text-sm">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">跳转链接</label>
                    <input type="url" asp-for="Food.RedirectUrl" placeholder="不填写则显示默认详情页"
                           class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 transition-all text-sm">
                </div>
            </div>
        </section>

        <!-- Settings Section -->
        <section class="space-y-6 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">发布设置</h2>
            </div>

            <div class="flex flex-wrap gap-12 items-center bg-gray-50/50 p-8 rounded-2xl border border-gray-100">
                <div class="flex items-center gap-8">
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="checkbox" asp-for="Food.ShowWatermark" class="w-6 h-6 rounded text-brand border-gray-300 focus:ring-brand transition-all">
                        <span class="text-sm font-bold text-gray-700">显示图片水印</span>
                    </label>
                    <div class="flex items-center gap-4 bg-white px-4 py-2 rounded-lg border border-gray-100">
                        @foreach (var pos in new[] { (v:"Center", n:"中正"), (v:"Bottom", n:"中下"), (v:"BottomRight", n:"右下") })
                        {
                            <label class="flex items-center gap-1.5 cursor-pointer">
                                <input type="radio" asp-for="Food.WatermarkPos" value="@pos.v" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand">
                                <span class="text-xs text-gray-500 font-medium">@pos.n</span>
                            </label>
                        }
                    </div>
                </div>
                <label class="flex items-center gap-3 cursor-pointer group">
                    <input type="checkbox" asp-for="Food.IsHome" class="w-6 h-6 rounded text-brand border-gray-300 focus:ring-brand transition-all">
                    <span class="text-sm font-bold text-gray-700">推荐到首页</span>
                </label>
            </div>
        </section>

        <!-- Actions -->
        <div class="px-8 py-6 bg-gray-50 border-t border-gray-100 flex items-center justify-end gap-4">
            <button type="button" onclick="history.back()" class="px-8 py-3 rounded-xl text-sm font-bold text-gray-500 hover:bg-gray-200 transition-all">取消</button>
            <button type="submit" class="px-12 py-3 bg-brand text-white rounded-xl font-bold shadow-xl shadow-brand/30 hover:-translate-y-0.5 active:scale-95 transition-all">确认发布产品</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    function foodForm() {
        return {
            category: '美食',
            imageUrl: '',
            previewImage(e) {
                const file = e.target.files[0];
                if (file) {
                    this.imageUrl = URL.createObjectURL(file);
                }
            }
        }
    }
</script>
}

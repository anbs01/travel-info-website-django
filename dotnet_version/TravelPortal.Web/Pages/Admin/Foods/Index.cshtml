@page
@model TravelPortal.Web.Pages.Admin.Foods.IndexModel
@{
    ViewData["Title"] = "特色美食";
}

<div class="space-y-6">
    <!-- 1. 标题与操作栏 -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-8 py-4 border-b border-gray-50 flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <h1 class="text-lg font-bold text-gray-800">特色美食</h1>
                <div class="flex rounded-lg bg-gray-100 p-1">
                    <a asp-page="Index" class="px-4 py-1.5 text-xs font-bold bg-white text-brand rounded-md shadow-sm">美食列表</a>
                    <a asp-page="Create" class="px-4 py-1.5 text-xs font-bold text-gray-500 hover:text-gray-700">发布产品</a>
                </div>
            </div>
        </div>

        <!-- 2. 筛选栏 -->
        <form method="get" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white border-b border-gray-50">
            <div class="flex items-center space-x-2">
                <button type="submit" asp-page-handler="ToggleSticky" formmethod="post" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">置顶</button>
                <button type="button" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">屏蔽</button>
                <button type="button" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">编辑</button>
                <button type="submit" asp-page-handler="Delete" formmethod="post" onclick="return confirm('确定删除选中项吗？')" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">删除</button>
            </div>
            
            <div class="flex items-center space-x-3">
                <select asp-for="Category" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                    <option value="">全部类别</option>
                    <option value="美食">美食</option>
                    <option value="特产">特产</option>
                </select>

                <select asp-for="SpecialtyCategory" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                    <option value="">特产类别</option>
                    @foreach(var cat in Model.SpecialtyCategories) {
                        <option value="@cat">@cat</option>
                    }
                </select>
                
                <div class="relative">
                    <input type="text" asp-for="Keyword" placeholder="关键字" class="pl-4 pr-10 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs w-48 focus:ring-1 focus:ring-brand/20" />
                    <button type="submit" class="absolute right-2 top-1.5 text-gray-400 hover:text-brand transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </button>
                </div>
                
                <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 transition-all">搜索</button>
            </div>
        </form>

        <!-- 3. 数据列表 -->
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded text-brand border-gray-200" /></th>
                        <th class="px-6 py-4">标题</th>
                        <th class="px-6 py-4 w-32">类别</th>
                        <th class="px-6 py-4 w-48">地区</th>
                        <th class="px-6 py-4 w-24 text-center">浏览</th>
                        <th class="px-8 py-4 w-40 text-right">添加日期</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.FoodList.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="px-8 py-4"><input type="checkbox" name="ids" value="@item.Id" class="rounded text-brand border-gray-200" /></td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <div class="flex items-center space-x-2">
                                        <a asp-page="./Edit" asp-route-id="@item.Id" class="text-gray-700 font-medium group-hover:text-brand transition-colors">@item.Title</a>
                                        @if (item.IsSticky)
                                        {
                                            <span class="text-[10px] text-red-500 font-bold">已置顶</span>
                                        }
                                        @if (item.IsHidden)
                                        {
                                            <span class="text-[10px] text-gray-400 font-bold">已屏蔽</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-0.5 rounded text-[10px] font-bold @(item.Category == "特产" ? "bg-orange-50 text-orange-600" : "bg-blue-50 text-blue-600")">
                                    @item.Category
                                </span>
                            </td>
                            <td class="px-6 py-4 text-xs text-gray-500">
                                @(item.Region?.Name ?? "未设置")
                            </td>
                            <td class="px-6 py-4 text-center text-gray-400 font-mono">@item.Views</td>
                            <td class="px-8 py-4 text-right text-xs text-gray-400 font-mono">
                                @item.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 4. 分页组件 -->
        <partial name="_Pagination" model="Model.FoodList.Metadata" />
    </div>
</div>

<script>
    document.getElementById('selectAll').addEventListener('change', function() {
        const checkboxes = document.querySelectorAll('input[name="ids"]');
        checkboxes.forEach(cb => cb.checked = this.checked);
    });
</script>

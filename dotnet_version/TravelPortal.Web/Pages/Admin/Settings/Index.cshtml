@page
@model TravelPortal.Web.Pages.Admin.Settings.IndexModel
@{
    ViewData["Title"] = "基本信息设置";
}

<!-- 引入 Alpine.js 用于选项卡切换 -->
<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

<div x-data="{ activeTab: 'about' }" class="space-y-6">
    
    <!-- 头部卡片 -->
    <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-50 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">基本信息</h1>
            <p class="text-gray-400 text-sm mt-1">管理网站的核心描述内容与服务协议</p>
        </div>
        <div class="flex space-x-2 bg-gray-50 p-1.5 rounded-2xl">
            <button @@click="activeTab = 'about'" :class="activeTab === 'about' ? 'bg-white shadow-sm text-brand' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all">关于我们</button>
            <button @@click="activeTab = 'service'" :class="activeTab === 'service' ? 'bg-white shadow-sm text-brand' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all">服务协议</button>
            <button @@click="activeTab = 'coop'" :class="activeTab === 'coop' ? 'bg-white shadow-sm text-brand' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all">合作事宜</button>
            <button @@click="activeTab = 'contact'" :class="activeTab === 'contact' ? 'bg-white shadow-sm text-brand' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all">联系我们</button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-6 py-4 rounded-2xl flex items-center">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
            @TempData["SuccessMessage"]
        </div>
    }

    <form method="post">
        <input type="hidden" asp-for="SiteInfo.Id" />
        
        <!-- 关于我们 -->
        <div x-show="activeTab === 'about'" x-transition class="bg-white rounded-3xl p-10 shadow-sm border border-gray-50">
            <div class="mb-6 flex items-center justify-between">
                <h3 class="text-xl font-bold text-gray-800">关于我们</h3>
                <span class="px-3 py-1 bg-blue-50 text-blue-500 text-[10px] font-bold rounded-full uppercase tracking-widest">About Us</span>
            </div>
            <textarea asp-for="SiteInfo.About" rows="15" class="w-full p-8 bg-gray-50 border-none rounded-3xl text-gray-700 focus:ring-2 focus:ring-brand/20 transition-all leading-relaxed" placeholder="请在这里输入品牌故事与关于我们的详细介绍..."></textarea>
        </div>

        <!-- 服务协议 -->
        <div x-show="activeTab === 'service'" x-transition class="bg-white rounded-3xl p-10 shadow-sm border border-gray-50">
            <div class="mb-6 flex items-center justify-between">
                <h3 class="text-xl font-bold text-gray-800">服务协议</h3>
                <span class="px-3 py-1 bg-purple-50 text-purple-500 text-[10px] font-bold rounded-full uppercase tracking-widest">Service Agreement</span>
            </div>
            <textarea asp-for="SiteInfo.ServiceAgreement" rows="15" class="w-full p-8 bg-gray-50 border-none rounded-3xl text-gray-700 focus:ring-2 focus:ring-brand/20 transition-all leading-relaxed" placeholder="请在这里输入用户服务协议与隐私政策条款..."></textarea>
        </div>

        <!-- 合作事宜 -->
        <div x-show="activeTab === 'coop'" x-transition class="bg-white rounded-3xl p-10 shadow-sm border border-gray-50">
            <div class="mb-6 flex items-center justify-between">
                <h3 class="text-xl font-bold text-gray-800">合作事宜</h3>
                <span class="px-3 py-1 bg-orange-50 text-orange-500 text-[10px] font-bold rounded-full uppercase tracking-widest">Cooperation</span>
            </div>
            <textarea asp-for="SiteInfo.Cooperation" rows="15" class="w-full p-8 bg-gray-50 border-none rounded-3xl text-gray-700 focus:ring-2 focus:ring-brand/20 transition-all leading-relaxed" placeholder="请在这里输入商务合作、招商引资等相关信息..."></textarea>
        </div>

        <!-- 联系我们 -->
        <div x-show="activeTab === 'contact'" x-transition class="bg-white rounded-3xl p-10 shadow-sm border border-gray-50">
            <div class="mb-6 flex items-center justify-between">
                <h3 class="text-xl font-bold text-gray-800">联系我们</h3>
                <span class="px-3 py-1 bg-green-50 text-green-500 text-[10px] font-bold rounded-full uppercase tracking-widest">Contact Us</span>
            </div>
            <textarea asp-for="SiteInfo.ContactUs" rows="15" class="w-full p-8 bg-gray-50 border-none rounded-3xl text-gray-700 focus:ring-2 focus:ring-brand/20 transition-all leading-relaxed" placeholder="请在这里输入联系电话、地址、电子邮箱等联系方式..."></textarea>
        </div>

        <!-- 底部提交栏 -->
        <div class="mt-8 flex items-center justify-between bg-white p-6 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xs text-gray-400 ml-4">提示：所有内容均支持 HTML 格式，请谨慎编辑。</p>
            <div class="flex space-x-4">
                <button type="reset" class="px-8 py-3 rounded-2xl text-sm font-bold text-gray-400 hover:text-gray-600 transition-all">重置修改</button>
                <button type="submit" class="px-10 py-3 bg-brand text-white rounded-2xl text-sm font-bold shadow-lg shadow-brand/20 hover:scale-105 active:scale-95 transition-all">确认保存</button>
            </div>
        </div>
    </form>
</div>

<style>
    textarea { resize: none; }
    [x-cloak] { display: none !important; }
</style>

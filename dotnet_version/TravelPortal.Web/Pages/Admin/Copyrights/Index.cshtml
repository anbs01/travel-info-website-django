@page
@model TravelPortal.Web.Pages.Admin.Copyrights.IndexModel
@{
    ViewData["Title"] = "版权引用配置";
}

<div class="space-y-8">
    <!-- 头部说明 -->
    <div class="bg-brand/5 border-l-4 border-brand p-6 rounded-r-2xl shadow-sm">
        <h2 class="text-lg font-bold text-brand flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            操作说明
        </h2>
        <p class="text-sm text-gray-600 mt-2">如果没有内容时，在前台提交信息或展示时将不显示该项。所有配置即时生效。</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-6 py-4 rounded-2xl flex items-center animate-fade-in-down">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
            @TempData["SuccessMessage"]
        </div>
    }

    <form method="post" class="space-y-6">
        <input type="hidden" asp-for="SiteInfo.Id" />
        
        <!-- 配置项卡片 -->
        <div class="grid grid-cols-1 gap-6">
            
            <!-- 原创版权 -->
            <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center text-blue-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A3.332 3.332 0 0018 14.018V5a2 2 0 00-2-2H6a2 2 0 00-2 2v11a2 2 0 002 2h2"></path></svg>
                        </div>
                        <h3 class="font-bold text-gray-800">原创版权</h3>
                    </div>
                    <span class="text-[10px] font-bold text-gray-300 uppercase tracking-widest">Original Copyright</span>
                </div>
                <textarea asp-for="SiteInfo.OriginalCopyright" rows="4" class="w-full px-5 py-4 bg-gray-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-brand/20 transition-all placeholder-gray-400" placeholder="请输入原创内容版权声明..."></textarea>
            </div>

            <!-- 转载声明 -->
            <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center text-purple-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"></path></svg>
                        </div>
                        <h3 class="font-bold text-gray-800">转载声明</h3>
                    </div>
                    <span class="text-[10px] font-bold text-gray-300 uppercase tracking-widest">Reprint Statement</span>
                </div>
                <textarea asp-for="SiteInfo.ReprintStatement" rows="4" class="w-full px-5 py-4 bg-gray-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-brand/20 transition-all placeholder-gray-400" placeholder="请输入转载文章说明..."></textarea>
            </div>

            <!-- 广告提示 -->
            <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-orange-50 rounded-xl flex items-center justify-center text-orange-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.167a2.405 2.405 0 010-1.512l2.147-6.167a1.76 1.76 0 013.417.592zm3.67 1.18a4.5 4.5 0 010 5.908m3.21-8.12a9 9 0 010 10.334"></path></svg>
                        </div>
                        <h3 class="font-bold text-gray-800">广告提示</h3>
                    </div>
                    <span class="text-[10px] font-bold text-gray-300 uppercase tracking-widest">AD Disclaimer</span>
                </div>
                <textarea asp-for="SiteInfo.AdDisclaimer" rows="4" class="w-full px-5 py-4 bg-gray-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-brand/20 transition-all placeholder-gray-400" placeholder="请输入广告推广相关说明..."></textarea>
            </div>

            <!-- 风险提示 -->
            <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-red-50 rounded-xl flex items-center justify-center text-red-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        </div>
                        <h3 class="font-bold text-gray-800">风险提示</h3>
                    </div>
                    <span class="text-[10px] font-bold text-gray-300 uppercase tracking-widest">Risk Warning</span>
                </div>
                <textarea asp-for="SiteInfo.RiskWarning" rows="4" class="w-full px-5 py-4 bg-gray-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-brand/20 transition-all placeholder-gray-400" placeholder="请输入旅游风险及免责声明..."></textarea>
            </div>

        </div>

        <!-- 提交按钮 -->
        <div class="sticky bottom-8 flex justify-center mt-10">
            <button type="submit" class="bg-brand text-white px-12 py-4 rounded-2xl font-bold shadow-xl shadow-brand/20 hover:scale-105 active:scale-95 transition-all flex items-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                保存所有版权配置
            </button>
        </div>
    </form>
</div>

<style>
    textarea { resize: none; }
    .animate-fade-in-down { animation: fadeInDown 0.5s ease-out; }
    @@keyframes fadeInDown {
        0% { opacity: 0; transform: translateY(-10px); }
        100% { opacity: 1; transform: translateY(0); }
    }
</style>

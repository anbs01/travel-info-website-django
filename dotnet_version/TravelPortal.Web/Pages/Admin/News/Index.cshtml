@page
@model TravelPortal.Web.Pages.Admin.News.IndexModel
@{
    ViewData["Title"] = "行业资讯";
}

<div class="space-y-6">
    <!-- 1. 标题与选项卡 -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-8 py-4 border-b border-gray-50 flex items-center justify-between">
            <h1 class="text-lg font-bold text-gray-800">行业资讯</h1>
        </div>
        <div class="flex border-b border-gray-50 bg-gray-50/30">
            <a asp-page="Index" class="px-8 py-4 text-sm font-bold border-t-2 border-brand bg-white text-brand transition-all">资讯列表</a>
            <a asp-page="Create" class="px-8 py-4 text-sm font-bold text-gray-400 hover:text-gray-600 transition-all">发布资讯</a>
        </div>

        <!-- 2. 操作与筛选栏 -->
        <form method="get" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white">
            <div class="flex items-center space-x-2">
                <button type="submit" asp-page-handler="ToggleSticky" formmethod="post" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">置顶</button>
                <button type="button" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">编辑</button>
                <button type="submit" asp-page-handler="Delete" formmethod="post" onclick="return confirm('确定删除选中项吗？')" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">删除</button>
            </div>
            
            <div class="flex items-center space-x-3">
                <select asp-for="Category" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                    <option value="">全部类别</option>
                    <option value="news">行业资讯</option>
                    <option value="notice">官方公告</option>
                </select>
                
                <div class="relative">
                    <input type="text" asp-for="Keyword" placeholder="标题关键字" class="pl-4 pr-10 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs w-48 focus:ring-1 focus:ring-brand/20" />
                    <button type="submit" class="absolute right-2 top-1.5 text-gray-400 hover:text-brand transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </button>
                </div>
                
                <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 transition-all">查询</button>
            </div>
        </form>

        <!-- 3. 数据列表 -->
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded text-brand border-gray-200" /></th>
                        <th class="px-6 py-4">资讯标题</th>
                        <th class="px-6 py-4 w-32">类别</th>
                        <th class="px-6 py-4 w-24 text-center">点击量</th>
                        <th class="px-8 py-4 w-40 text-right">添加日期</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @if (Model.NewsList.Any())
                    {
                        foreach (var item in Model.NewsList)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors group">
                                <td class="px-8 py-4"><input type="checkbox" name="ids" value="@item.Id" class="rounded text-brand border-gray-200" /></td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-2">
                                        <span class="text-gray-700 font-medium group-hover:text-brand transition-colors">@item.Title</span>
                                        @if (item.IsSticky)
                                        {
                                            <span class="px-2 py-0.5 bg-red-50 text-red-500 text-[10px] font-bold rounded">置顶</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-xs text-gray-500">
                                    @(item.Category == "news" ? "行业资讯" : "官方公告")
                                </td>
                                <td class="px-6 py-4 text-center text-gray-400 font-mono">@item.Views</td>
                                <td class="px-8 py-4 text-right text-xs text-gray-400 font-mono">
                                    @item.CreatedAt.ToString("yyyy-MM-dd")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-8 py-20 text-center text-gray-400">
                                <div class="flex flex-col items-center">
                                    <svg class="w-12 h-12 mb-4 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                    暂无相关数据
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 4. 分页 -->
        <div class="p-8 flex items-center justify-center space-x-4 border-t border-gray-50 bg-gray-50/10">
             <span class="text-xs text-gray-400">共 @Model.NewsList.Count 条记录</span>
             <div class="flex space-x-2">
                 <span class="w-8 h-8 flex items-center justify-center rounded bg-brand text-white text-xs font-bold shadow-md shadow-brand/20">1</span>
             </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('selectAll').addEventListener('change', function() {
        const checkboxes = document.querySelectorAll('input[name="ids"]');
        checkboxes.forEach(cb => cb.checked = this.checked);
    });
</script>

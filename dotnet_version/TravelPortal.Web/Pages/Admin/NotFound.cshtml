@page "{handler?}"
@{
    Layout = "Shared/_AdminLayout";
    ViewData["Title"] = "页面开发中";
    var moduleName = Request.Query["module"].ToString() ?? "当前功能";
}

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="relative mb-8">
        <!-- 404 大数字背景 -->
        <h1 class="text-[120px] font-black text-gray-100 leading-none">404</h1>
        <!-- 插画/图标 -->
        <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-24 h-24 bg-brand/10 rounded-full flex items-center justify-center animate-pulse">
                <svg class="w-12 h-12 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
            </div>
        </div>
    </div>

    <h2 class="text-2xl font-bold text-gray-800 mb-2">抱歉，【@moduleName】正在开发中...</h2>
    <p class="text-gray-500 max-w-md mb-8">
        该模块的功能逻辑正在紧急接入中，目前仅开放了 UI 框架演示。请稍后再试，或联系技术团队获取进度。
    </p>

    <div class="flex space-x-4">
        <a href="/Admin" class="px-6 py-2.5 bg-brand text-white rounded-xl text-sm font-medium shadow-lg shadow-brand/20 hover:scale-105 transition-all">
            返回控制台
        </a>
        <button onclick="history.back()" class="px-6 py-2.5 bg-white text-gray-600 border border-gray-200 rounded-xl text-sm font-medium hover:bg-gray-50 transition-all">
            返回上一页
        </button>
    </div>

    <!-- 装饰性元素 -->
    <div class="mt-16 grid grid-cols-3 gap-8 opacity-40">
        <div class="h-2 w-24 bg-gray-200 rounded-full"></div>
        <div class="h-2 w-24 bg-gray-200 rounded-full"></div>
        <div class="h-2 w-24 bg-gray-200 rounded-full"></div>
    </div>
</div>

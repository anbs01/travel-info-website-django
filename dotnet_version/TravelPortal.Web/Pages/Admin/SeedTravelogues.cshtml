@page
@using SqlSugar
@using TravelPortal.Web.Models
@inject ISqlSugarClient db
@{
    Layout = null;
    var result = "正在准备填充数据...";
    
    try {
        // 1. 获取一个有效的 PlaceId
        var firstPlace = db.Queryable<Place>().First();
        int placeId = firstPlace?.Id ?? 1; // 如果没有城镇数据，默认设为 1

        // 0. 先清空旧数据 (避免重复叠加)
        db.Deleteable<Travelogue>().ExecuteCommand();

        var testData = new List<Travelogue>
        {
            new Travelogue {
                PlaceId = placeId,
                Title = "收藏!五莲“中秋游玩超全攻略”来啦!",
                Summary = "此次惠游措施惠及所有从浙江出发到贵州游玩的游客:9月1日至7日，贵州省内各收费旅游景区(点)对由浙江赴黔的境内外游客实行门票全免优惠...",
                MainImage = "/travel_thumb_1.png",
                Author = "张苏苏",
                Source = "百度",
                Views = 1250,
                IsSticky = true,
                PublishDate = DateTime.Now,
                Category = "guide",
                Content = "<p>昨晚，杭州市文化广电旅游局发布《关于取消全市A级旅游景区预约的通知》，7月5日起，全市所有A级旅游景区取消预约入园要求。</p><p>通知指出，全市A级旅游景区(除文博场馆外)取消预约要求。法定节假日游客量大的景区应加强流量管控，采取流量提示、错峰分流等措施，确保游客较为舒适地游览体验。</p><img src='/travel_thumb_1.png' style='max-width:100%; margin:20px 0; border-radius:4px;' /><p>同时，文博场馆类A级景区和A级景区内的文博场馆在非周末、非法定节假日取消预约入馆...</p>"
            },
            new Travelogue {
                PlaceId = placeId,
                Title = "暖心相助无国界 延吉民警帮外国游客找回遗失手机",
                Summary = "两名俄罗斯游客专程来到延吉市公安局进学派出所，手中紧攥着手写感谢信和一张写有“I LOVE CHINA”的纸条...",
                MainImage = "/travel_thumb_1.png",
                Author = "张一宁",
                Source = "延吉新闻网",
                Views = 890,
                IsSticky = false,
                PublishDate = DateTime.Now.AddHours(-5),
                Category = "travelogue",
                Content = "<h3>暖心一幕</h3><p>时间回溯到1月5日10时15分，民警张一宁接到警情：园纺路南侧翰馨阁附近，两名外国游客因手机丢失陷入困境...</p>"
            },
            new Travelogue {
                PlaceId = placeId,
                Title = "兰州龙山滑雪场缆车停运事故：104名游客平安获救",
                Summary = "兰州龙山滑雪场因停电突发缆车停运事故，导致104名游客被困滞留半空。当地应急部门迅速启动救援预案...",
                MainImage = null, // 测试无图模式
                Author = "甘肃快讯",
                Source = "官方发布",
                Views = 3420,
                IsSticky = false,
                PublishDate = DateTime.Now.AddDays(-1),
                Category = "travelogue",
                Content = "<p>经过长达4小时的紧急营救，所有被困游客已全部安全下地。相关部门已责令滑雪场停业整顿，排查电力安全隐患。</p>"
            },
            new Travelogue {
                PlaceId = placeId,
                Title = "2026年浙江游客赴黔旅游优惠政策详解",
                Summary = "浙江游客只需出示本人有效身份证件，即可享受全省 A 级景区门票 5 折优惠...",
                MainImage = "/travel_thumb_1.png",
                Author = "旅游局",
                Source = "贵州旅游网",
                Views = 5600,
                IsSticky = true,
                PublishDate = DateTime.Now.AddDays(-2),
                Category = "guide",
                Content = "<p>详细政策如下：1. 所有浙江籍游客凭身份证件免大门票。2. 包含梵净山、黄果树等知名景区...</p>"
            }
        };

        db.Insertable(testData).ExecuteCommand();
        result = "成功！已自动填充 4 条测试数据。请前往 /Travelogues 查看效果。";
    }
    catch (Exception ex) {
        result = "失败：" + ex.Message;
    }
}

<div style="padding: 50px; text-align: center; font-family: sans-serif;">
    <h1 style="color: @(result.StartsWith("成功") ? "#28a745" : "#dc3545")">@result</h1>
    <p style="margin-top: 20px;">
        <a href="/Travelogues" style="color: #007bff; text-decoration: none;">&larr; 返回前端列表页</a>
    </p>
</div>

@page
@model TravelPortal.Web.Pages.Admin.ScenicSpots.CreateModel
@{
    ViewData["Title"] = "发布打卡点";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]" x-data="scenicForm()">
    <partial name="_AdminPageHeader" model='new { 
        Title = "发布打卡点", 
        Subtitle = "Scenic Spots & Check-in Places",
        Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\"/><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\"/></svg>",
        Tabs = new[] {
            new { Name = "打卡地列表", Url = Url.Page("Index"), IsActive = false },
            new { Name = "发布打卡点", Url = Url.Page("Create"), IsActive = true }
        }
    }' />

    <form method="post" enctype="multipart/form-data" class="p-8 space-y-10">

        <!-- 基本信息 -->
        <section class="space-y-6">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">基本信息</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-gray-700 mb-2">打卡点名称 <span class="text-red-500">*</span></label>
                    <input type="text" asp-for="Spot.Title" required placeholder="例如：蓬莱阁、烟台山公园..."
                           class="w-full px-5 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-lg font-medium">
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-3">名气级别</label>
                    <div class="flex flex-wrap gap-3">
                        @foreach (var lv in new[] { "知名景区", "热门景点", "小众秘境", "城市地标", "网红打卡地" })
                        {
                            <label class="relative flex items-center group cursor-pointer">
                                <input type="radio" asp-for="Spot.FameLevel" value="@lv" class="peer sr-only">
                                <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-green-50 peer-checked:border-green-600 peer-checked:text-green-700 transition-all group-hover:border-green-300">@lv</div>
                            </label>
                        }
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-3">景区级别</label>
                    <div class="flex flex-wrap gap-3">
                        @foreach (var g in new[] { "AAAAA级", "AAAA级", "AAA级", "AA级", "A级" })
                        {
                            <label class="relative flex items-center group cursor-pointer">
                                <input type="radio" asp-for="Spot.ScenicGrade" value="@g" class="peer sr-only">
                                <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-yellow-50 peer-checked:border-yellow-500 peer-checked:text-yellow-700 transition-all group-hover:border-yellow-300">@g</div>
                            </label>
                        }
                    </div>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-gray-700 mb-3">打卡点类别 <span class="text-red-500">*</span></label>
                    <div class="flex flex-wrap gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                        @foreach (var cat in Model.ScenicCategories)
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Spot.Classification" value="@cat"
                                       class="w-4 h-4 text-brand border-gray-300 focus:ring-brand">
                                <span class="text-sm text-gray-600 group-hover:text-brand">@cat</span>
                            </label>
                        }
                        @if (!Model.ScenicCategories.Any())
                        {
                            <span class="text-xs text-gray-400 italic">请在"综合管理 > 类别热词"中添加勾选了"打卡地类别"的词条</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- 焦点图与摘要 -->
        <section class="space-y-6 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">焦点图片与摘要</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">焦点图</label>
                    <div class="relative w-full aspect-[4/3] rounded-2xl overflow-hidden bg-gray-50 border-2 border-dashed border-gray-200 group hover:border-brand transition-all cursor-pointer"
                         @@click="$refs.fileInput.click()">
                        <template x-if="imageUrl">
                            <img :src="imageUrl" class="w-full h-full object-cover" />
                        </template>
                        <template x-if="!imageUrl">
                            <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-400">
                                <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
                                <span class="text-xs font-medium">上传封面图</span>
                            </div>
                        </template>
                        <input type="file" x-ref="fileInput" name="MainImageFile" class="hidden" @@change="previewImage" accept="image/*">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">打卡特色 <span class="text-red-500">*</span></label>
                    <textarea asp-for="Spot.Summary" rows="8" maxlength="120" required
                              class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm"
                              placeholder="请输入打卡特色，120字以内..."></textarea>
                    <span class="text-[10px] text-gray-400">要求120汉字以内</span>
                </div>
            </div>
        </section>

        <!-- 详细正文 -->
        <section class="space-y-6 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">详细介绍</h2>
            </div>
            <textarea id="editor" asp-for="Spot.Content"></textarea>
            <partial name="_TinyMCE" model='new { Selector = "#editor", Height = 600 }' />
        </section>

        <!-- 扩展信息 -->
        <section class="space-y-6 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">扩展信息</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">选择地区 <span class="text-red-500">*</span></label>
                    <partial name="_GeoPicker" model='new { FieldName = "Spot.GeoId", CurrentId = (int?)null, CurrentName = (string?)null }' />
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">文章作者</label>
                    <input type="text" asp-for="Spot.Author"
                           class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 transition-all text-sm">
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">跳转链接</label>
                    <input type="url" asp-for="Spot.RedirectUrl" placeholder="不填则显示默认详情页"
                           class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-brand/20 transition-all text-sm">
                </div>
            </div>
        </section>

        <!-- 发布设置 -->
        <section class="space-y-6 pt-4">
            <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                <div class="w-1.5 h-6 bg-brand rounded-full"></div>
                <h2 class="text-lg font-bold text-gray-900">发布设置</h2>
            </div>

            <div class="flex flex-wrap gap-12 items-center bg-gray-50/50 p-8 rounded-2xl border border-gray-100">
                <div class="flex items-center gap-8">
                    <label class="flex items-center gap-3 cursor-pointer">
                        <input type="checkbox" asp-for="Spot.ShowWatermark" class="w-6 h-6 rounded text-brand border-gray-300 focus:ring-brand">
                        <span class="text-sm font-bold text-gray-700">显示图片水印</span>
                    </label>
                    <div class="flex items-center gap-4 bg-white px-4 py-2 rounded-lg border border-gray-100">
                        @foreach (var pos in new[] { (v:"Center", n:"中正"), (v:"Bottom", n:"中下"), (v:"BottomRight", n:"右下") })
                        {
                            <label class="flex items-center gap-1.5 cursor-pointer">
                                <input type="radio" asp-for="Spot.WatermarkPos" value="@pos.v" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand">
                                <span class="text-xs text-gray-500 font-medium">@pos.n</span>
                            </label>
                        }
                    </div>
                </div>
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" asp-for="Spot.IsHome" class="w-6 h-6 rounded text-brand border-gray-300 focus:ring-brand">
                    <span class="text-sm font-bold text-gray-700">推荐到首页</span>
                </label>
            </div>
        </section>

        <!-- 操作按钮 -->
        <div class="px-8 py-6 bg-gray-50 border-t border-gray-100 flex items-center justify-end gap-4">
            <button type="button" onclick="history.back()" class="px-8 py-3 rounded-xl text-sm font-bold text-gray-500 hover:bg-gray-200 transition-all">取消</button>
            <button type="submit" class="px-12 py-3 bg-brand text-white rounded-xl font-bold shadow-xl shadow-brand/30 hover:-translate-y-0.5 active:scale-95 transition-all">确认发布</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    function scenicForm() {
        return {
            imageUrl: '',
            previewImage(e) {
                const file = e.target.files[0];
                if (file) this.imageUrl = URL.createObjectURL(file);
            }
        }
    }
</script>
}

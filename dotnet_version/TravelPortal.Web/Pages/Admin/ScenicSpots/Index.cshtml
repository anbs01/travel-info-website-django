@page
@model TravelPortal.Web.Pages.Admin.ScenicSpots.IndexModel
@{
    ViewData["Title"] = "打卡地管理";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]">
<partial name="_AdminPageHeader" model='new { 
    Title = "打卡地管理", 
    Subtitle = "Scenic Spots & Check-in Places",
    Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\"/><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\"/></svg>",
    Tabs = new[] {
        new { Name = "打卡地列表", Url = Url.Page("Index"), IsActive = true },
        new { Name = "发布打卡点", Url = Url.Page("Create"), IsActive = false }
    }
}' />

    <!-- 筛选栏 -->
    <form method="get" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white border-b border-gray-50">
        <div class="flex items-center space-x-2">
            <button type="submit" asp-page-handler="ToggleSticky" formmethod="post" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">置顶</button>
            <button type="submit" asp-page-handler="ToggleHidden" formmethod="post" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">屏蔽</button>
            <button type="submit" asp-page-handler="Delete" formmethod="post" onclick="return confirm('确定删除选中项吗？')" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">删除</button>
        </div>

        <div class="flex items-center space-x-3">
            <select asp-for="FameLevel" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                <option value="">全部名气</option>
                @foreach (var lv in new[] { "知名景区", "热门景点", "小众秘境", "城市地标", "网红打卡地" })
                {
                    <option value="@lv">@lv</option>
                }
            </select>

            <select asp-for="ScenicGrade" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                <option value="">景区级别</option>
                @foreach (var g in new[] { "AAAAA级", "AAAA级", "AAA级", "AA级", "A级" })
                {
                    <option value="@g">@g</option>
                }
            </select>

            <div class="relative">
                <input type="text" asp-for="Keyword" placeholder="关键字" class="pl-4 pr-10 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs w-48 focus:ring-1 focus:ring-brand/20" />
                <button type="submit" class="absolute right-2 top-1.5 text-gray-400 hover:text-brand transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>

            <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 transition-all">搜索</button>
        </div>
    </form>

    <!-- 数据列表 -->
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                <tr>
                    <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded text-brand border-gray-200" /></th>
                    <th class="px-6 py-4">打卡点名称</th>
                    <th class="px-6 py-4 w-28">名气级别</th>
                    <th class="px-6 py-4 w-24">景区级别</th>
                    <th class="px-6 py-4 w-36">地区</th>
                    <th class="px-6 py-4 w-20 text-center">浏览</th>
                    <th class="px-8 py-4 w-40 text-right">添加日期</th>
                    <th class="px-6 py-4 w-24 text-right">操作</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var item in Model.ScenicSpots.Items)
                {
                    <tr class="hover:bg-gray-50/50 transition-colors group">
                        <td class="px-8 py-4"><input type="checkbox" name="ids" value="@item.Id" class="rounded text-brand border-gray-200" /></td>
                        <td class="px-6 py-4">
                            <div class="flex items-center space-x-2">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="text-gray-700 font-medium group-hover:text-brand transition-colors">@item.Title</a>
                                @if (item.IsSticky) { <span class="text-[10px] text-red-500 font-bold">已置顶</span> }
                                @if (item.IsHidden) { <span class="text-[10px] text-gray-400 font-bold">已屏蔽</span> }
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            @if (!string.IsNullOrEmpty(item.FameLevel))
                            {
                                <span class="px-2 py-0.5 bg-green-50 text-green-600 text-[10px] font-bold rounded">@item.FameLevel</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-xs text-gray-500">@item.ScenicGrade</td>
                        <td class="px-6 py-4 text-xs text-gray-500">@(item.Geo?.Title ?? "未设置")</td>
                        <td class="px-6 py-4 text-center text-gray-400 font-mono">@item.Views</td>
                        <td class="px-8 py-4 text-right text-xs text-gray-400 font-mono">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="px-6 py-4 text-right">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="text-xs text-brand hover:underline">编辑</a>
                        </td>
                    </tr>
                }
                @if (!Model.ScenicSpots.Items.Any())
                {
                    <tr><td colspan="8" class="px-8 py-16 text-center text-gray-400 text-sm">暂无数据</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 分页 -->
    <partial name="_Pagination" model="Model.ScenicSpots.Metadata" />
</div>

<script>
    document.getElementById('selectAll').addEventListener('change', function () {
        document.querySelectorAll('input[name="ids"]').forEach(cb => cb.checked = this.checked);
    });
</script>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 旅游门户管理系统</title>
    <!-- 引入 Tailwind CDN 确保样式立即生效 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand': '#A67C52',
                        'sidebar': '#1e1e2d',
                        'sidebar-hover': '#2b2b40'
                    },
                    fontFamily: {
                        'sans': ['Inter', 'Noto Sans SC', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', 'Noto Sans SC', sans-serif; }
        .active-menu { background: linear-gradient(90deg, rgba(166,124,82,0.1) 0%, rgba(166,124,82,0) 100%); border-left: 3px solid #A67C52; color: #A67C52 !important; }
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    </style>
</head>
<body class="bg-[#f4f7f6] text-[#333]">
    <div class="flex h-screen overflow-hidden">
        
        <!-- 侧边栏 -->
        <aside class="w-64 bg-sidebar text-white flex-shrink-0 flex flex-col shadow-2xl">
            <!-- Logo -->
            <div class="p-8 border-b border-gray-800 flex items-center space-x-3">
                <div class="w-10 h-10 bg-brand rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-brand/30">T</div>
                <div class="logo-text">
                    <div class="text-sm font-bold tracking-wider uppercase">TravelPortal</div>
                    <div class="text-[10px] text-gray-500 uppercase">Management</div>
                </div>
            </div>

            <!-- 导航 -->
            <nav class="flex-1 px-4 py-8 space-y-2 overflow-y-auto custom-scrollbar">
                <div class="px-4 py-2 text-[10px] font-bold text-gray-600 uppercase tracking-widest">Main Menu</div>
                <a href="/Admin" class="flex items-center px-4 py-2.5 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                    <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    控制台首页
                </a>

                <!-- 综合管理 -->
                <div class="menu-group">
                    <button class="menu-trigger flex items-center justify-between w-full px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                            综合管理
                        </div>
                        <svg class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="menu-content hidden pl-11 pr-4 py-2 space-y-1">
                        <a href="/Admin/NotFound?module=互动信息" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">互动信息(2)</a>
                        <a href="/Admin/HotWords" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">类别热词</a>
                        <a href="/Admin/Copyrights" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">版权引用</a>
                        <a href="/Admin/Settings" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">基本信息</a>
                        <a href="/Admin/Recommendations" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">首页推荐</a>
                    </div>
                </div>

                <!-- 纪行攻略 -->
                <div class="menu-group">
                    <button class="menu-trigger flex items-center justify-between w-full px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            纪行攻略
                        </div>
                        <svg class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="menu-content hidden pl-11 pr-4 py-2 space-y-1">
                        <a href="/Admin/Travelogues" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">纪行攻略</a>
                        <a href="/Admin/Travelogues/Create" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">发布作品</a>
                    </div>
                </div>

                <!-- 行业资讯 -->
                <div class="menu-group">
                    <button class="menu-trigger flex items-center justify-between w-full px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2v6h6M7 12h10M7 16h10"/></svg>
                            行业资讯
                        </div>
                        <svg class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="menu-content hidden pl-11 pr-4 py-2 space-y-1">
                        <a href="/Admin/News" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">资讯管理</a>
                        <a href="/Admin/News/Create" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">发布资讯</a>
                    </div>
                </div>

                <!-- 城镇乡村 -->
                <div class="menu-group">
                    <button class="menu-trigger flex items-center justify-between w-full px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            城镇乡村
                        </div>
                        <svg class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="menu-content hidden pl-11 pr-4 py-2 space-y-1">
                        <a href="/Admin/Geos?Level=2" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">省份管理</a>
                        <a href="/Admin/Geos?Level=3" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">国内城镇</a>
                        <a href="/Admin/Geos?Level=1" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">国家管理</a>
                        <a href="/Admin/Geos?Nature=Overseas" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">海外城镇</a>
                        <a href="/Admin/Transports" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">交通管理</a>
                    </div>
                </div>

                <!-- 打卡地 -->
                <div class="menu-group">
                    <button class="menu-trigger flex items-center justify-between w-full px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            打卡地
                        </div>
                        <svg class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="menu-content hidden pl-11 pr-4 py-2 space-y-1">
                        <a href="/Admin/ScenicSpots" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">打卡地</a>
                        <a href="/Admin/ScenicSpots/Create" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">发布打卡点</a>
                    </div>
                </div>

                <!-- 特产美食 -->
                <div class="menu-group">
                    <button class="menu-trigger flex items-center justify-between w-full px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.703 2.703 0 01-3 0 2.703 2.703 0 01-3 0 2.703 2.703 0 01-3 0 2.701 2.701 0 01-1.5-.454M9 16v2a2 2 0 01-2 2H5a2 2 0 01-2-2v-2m9-2.333a2 2 0 012-2h1.833M12 12V6a2 2 0 012-2h3.28m2.72 6.447l.32-2.133a2 2 0 00-1.28-2.18l-4.47-1.49a2 2 0 00-2.58 1.94V12"/></svg>
                            特产美食
                        </div>
                        <svg class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="menu-content hidden pl-11 pr-4 py-2 space-y-1">
                        <a href="/Admin/Foods" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">特产美食</a>
                        <a href="/Admin/Foods/Create" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">发布产品</a>
                    </div>
                </div>

                <!-- 文创商品 -->
                <div class="menu-group">
                    <button class="menu-trigger flex items-center justify-between w-full px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                            文创商品
                        </div>
                        <svg class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="menu-content hidden pl-11 pr-4 py-2 space-y-1">
                        <a href="/Admin/CreativeProducts" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">文创管理</a>
                        <a href="/Admin/CreativeProducts/Create" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">发布产品</a>
                    </div>
                </div>

                <!-- 系统管理 -->
                <div class="menu-group">
                    <button class="menu-trigger flex items-center justify-between w-full px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-sidebar-hover group">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-3 text-gray-400 group-hover:text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            系统管理
                        </div>
                        <svg class="w-3 h-3 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div class="menu-content hidden pl-11 pr-4 py-2 space-y-1">
                        <a href="/Admin/System/Username" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">修改用户名</a>
                        <a href="/Admin/System/Password" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">修改密码</a>
                        <a href="/Admin/NotFound?module=数据备份" class="block py-2 text-xs text-gray-500 hover:text-white transition-all">数据备份</a>
                    </div>
                </div>
            </nav>

            <!-- 底部用户信息 -->
            <div class="p-6 bg-[#161622] flex items-center justify-between border-t border-gray-800">
                <div class="flex items-center space-x-3 text-white">
                    <div class="w-9 h-9 rounded-full bg-brand flex items-center justify-center text-xs font-bold ring-2 ring-brand/20">
                        @User.Identity?.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <div class="text-[12px] font-bold">@User.Identity?.Name</div>
                        <div class="text-[10px] text-gray-500">Super Admin</div>
                    </div>
                </div>
                <form method="post" action="/Account/Logout">
                    <button class="p-2 hover:bg-gray-800 rounded-lg text-gray-500 hover:text-red-400 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    </button>
                </form>
            </div>
        </aside>

        <!-- 主内容区 -->
        <div class="flex-1 flex flex-col min-w-0">
            <!-- 顶部导航 -->
            <header class="h-20 bg-white/80 backdrop-blur-md border-b border-gray-100 flex items-center justify-between px-10 sticky top-0 z-10">
                <div class="flex items-center space-x-3">
                    <button id="sidebarToggle" class="bg-gray-50 p-2 rounded-lg text-gray-400 hover:bg-gray-100 transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                    </button>
                    <span class="text-sm font-semibold text-gray-800">@ViewData["Title"]</span>
                </div>
                
                <div class="flex items-center space-x-4">
                    <a href="/" target="_blank" class="flex items-center text-xs font-medium text-brand bg-brand/5 px-4 py-2 rounded-full hover:bg-brand/10 transition-all border border-brand/20">
                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        预览前台
                    </a>
                </div>
            </header>

            <!-- 页面内容 -->
            <main class="flex-1 overflow-y-auto p-6 bg-[#f4f7f6]">
                <div class="max-w-[1200px] mx-auto">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $(function() {
            // 手风琴折叠逻辑
            $('.menu-trigger').click(function() {
                const $trigger = $(this);
                const $content = $trigger.next('.menu-content');
                const $chevron = $trigger.find('svg').last();

                // 关闭其他已打开的菜单 (可选)
                $('.menu-content').not($content).slideUp().prev('.menu-trigger').find('svg').last().removeClass('rotate-180');

                // 切换当前菜单
                $content.slideToggle(300);
                $chevron.toggleClass('rotate-180');
            });

            // 侧边栏整体切换逻辑
            $('#sidebarToggle').click(function() {
                const $sidebar = $('aside');
                const $logo = $sidebar.find('.logo-text');
                $sidebar.toggleClass('w-64 w-20');
                $('.logo-text, .menu-trigger span, .menu-group button div span, .menu-content, .text-[10px]').toggle();
            });

            // 自动展开当前活动链接所在的组
            const currentFull = window.location.pathname + window.location.search;
            const currentPath = window.location.pathname;
            const params = new URLSearchParams(window.location.search);

            $('.menu-content a').each(function() {
                const linkHref = $(this).attr('href');
                const linkPath = linkHref.split('?')[0];
                const linkParams = new URLSearchParams(linkHref.split('?')[1] || '');
                
                let isMatch = (linkHref === currentFull || linkHref === currentPath);

                // 特殊处理地理模块 (Geos) 的联动激活
                if (!isMatch && currentPath.includes('/Admin/Geos')) {
                    if (linkPath === '/Admin/Geos') {
                        const cLevel = params.get('level') || params.get('Level') || '';
                        const cNature = params.get('nature') || params.get('Nature') || 'Domestic';
                        
                        const lLevel = linkParams.get('Level') || '';
                        const lNature = linkParams.get('Nature') || 'Domestic';

                        // 海外城镇逻辑：如果两者都是 Overseas，则忽略 Level 直接匹配
                        if (cNature === 'Overseas' && lNature === 'Overseas') {
                            isMatch = true;
                        } else if (cLevel == lLevel && cNature == lNature) {
                            isMatch = true;
                        }
                    }
                } 
                // 通用逻辑：如果是其他模块的 Create/Edit 页面，只激活非列表链接
                else if (!isMatch && currentPath.startsWith(linkPath) && linkPath !== '/Admin') {
                    const isCreateOrEdit = currentPath.includes('/Create') || currentPath.includes('/Edit');
                    const linkIsIndex = !linkHref.includes('/Create') && !linkHref.includes('/Edit');
                    if (isCreateOrEdit && !linkIsIndex) {
                        isMatch = true;
                    }
                }

                if (isMatch) {
                    $(this).addClass('text-brand font-bold bg-white/5 rounded-lg');
                    const $group = $(this).parent();
                    $group.show().prev('.menu-trigger').find('svg').last().addClass('rotate-180').parent().addClass('text-brand');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@page
@model TravelPortal.Web.Pages.Admin.CreativeProducts.EditModel
@{
    ViewData["Title"] = "编辑文创产品";
}

<div class="max-w-5xl mx-auto pb-20" x-data="creativeForm('@Model.Product.MainImage')">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a href="/Admin/CreativeProducts" class="hover:text-indigo-600 transition-colors">文创产品</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"></path></svg>
        <span class="text-gray-900 font-medium">编辑产品</span>
    </nav>

    <form method="post" enctype="multipart/form-data" class="space-y-8">
        <input type="hidden" asp-for="Product.Id" />
        <input type="hidden" asp-for="Product.MainImage" />
        <input type="hidden" asp-for="Product.CreatedAt" />

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 md:p-8 space-y-8">
                
                <!-- Basic Info Section -->
                <section class="space-y-6">
                    <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                        <div class="w-1.5 h-6 bg-indigo-600 rounded-full"></div>
                        <h2 class="text-lg font-bold text-gray-900">基本信息</h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">产品名称 <span class="text-red-500">*</span></label>
                            <input type="text" asp-for="Product.Title" required placeholder="输入文创产品标题..."
                                   class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-lg font-medium">
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">产品类别 <span class="text-red-500">*</span></label>
                            <div class="flex flex-wrap gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                                @foreach (var cat in Model.Categories)
                                {
                                    <label class="flex items-center space-x-2 cursor-pointer group">
                                        <input type="radio" asp-for="Product.Category" value="@cat" required
                                               class="w-4 h-4 text-indigo-600 border-gray-300 focus:ring-indigo-500 transition-all">
                                        <span class="text-sm text-gray-600 group-hover:text-indigo-600 transition-colors">@cat</span>
                                    </label>
                                }
                                @if (!Model.Categories.Any())
                                {
                                    <span class="text-xs text-gray-400 italic">请先在“综合管理 > 类别热词”中添加勾选了“文创类别”的词条</span>
                                }
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">非遗级别</label>
                            <div class="flex flex-wrap gap-3 mt-1">
                                @foreach (var level in new[] { "国家级", "省级", "市级", "县级" })
                                {
                                    <label class="relative flex items-center group cursor-pointer">
                                        <input type="radio" asp-for="Product.LevelTag" value="@level" class="peer sr-only">
                                        <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-indigo-50 peer-checked:border-indigo-600 peer-checked:text-indigo-700 transition-all group-hover:border-indigo-300">
                                            @level
                                        </div>
                                    </label>
                                }
                                <label class="relative flex items-center group cursor-pointer">
                                    <input type="radio" asp-for="Product.LevelTag" value="" class="peer sr-only">
                                    <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-gray-100 peer-checked:border-gray-400 peer-checked:text-gray-900 transition-all">
                                        无级别
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Media Section -->
                <section class="space-y-6 pt-4">
                    <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                        <div class="w-1.5 h-6 bg-indigo-600 rounded-full"></div>
                        <h2 class="text-lg font-bold text-gray-900">焦点图片</h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
                        <div class="md:col-span-1">
                            <label class="group relative flex flex-col items-center justify-center w-full aspect-[4/3] rounded-2xl border-2 border-dashed border-gray-200 hover:border-indigo-400 hover:bg-indigo-50/30 transition-all cursor-pointer overflow-hidden">
                                <template x-if="!imagePreview">
                                    <div class="flex flex-col items-center justify-center p-6 text-center">
                                        <div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center text-gray-400 mb-3">
                                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        </div>
                                        <p class="text-sm font-medium text-gray-600">更换图片</p>
                                    </div>
                                </template>
                                <template x-if="imagePreview">
                                    <img :src="imagePreview" class="w-full h-full object-cover">
                                </template>
                                <input type="file" name="MainImageFile" class="sr-only" x-on:change="previewImage">
                                <div x-show="imagePreview" class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                    <span class="text-white text-sm font-medium bg-white/20 backdrop-blur-md px-3 py-1.5 rounded-lg border border-white/30">上传新图片</span>
                                </div>
                            </label>
                        </div>
                        <div class="md:col-span-2">
                             <div class="p-4 bg-gray-50 rounded-xl text-sm text-gray-500 leading-relaxed">
                                <p>当前图片路径：<code class="text-xs bg-gray-200 px-1 rounded">@Model.Product.MainImage</code></p>
                                <p class="mt-2 text-xs text-gray-400 italic">* 如需保留原图，请勿上传新文件</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Content Section -->
                <section class="space-y-6 pt-4">
                    <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                        <div class="w-1.5 h-6 bg-indigo-600 rounded-full"></div>
                        <h2 class="text-lg font-bold text-gray-900">产品介绍</h2>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">产品特色 (120字以内) <span class="text-red-500">*</span></label>
                        <textarea asp-for="Product.Summary" required maxlength="120" rows="3"
                                  class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all"></textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">详细正文 <span class="text-red-500">*</span></label>
                        <textarea id="creativeEditor" asp-for="Product.Content"></textarea>
                        <partial name="_TinyMCE" model='new { Selector = "#creativeEditor", Height = 600 }' />
                    </div>
                </section>

                <!-- Extra Info Section -->
                <section class="space-y-6 pt-4">
                    <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                        <div class="w-1.5 h-6 bg-indigo-600 rounded-full"></div>
                        <h2 class="text-lg font-bold text-gray-900">扩展信息</h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">所属地区</label>
                            <select asp-for="Product.RegionId" asp-items="Model.RegionList"
                                    class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                                <option value="">-- 选择归属地 --</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">文章作者</label>
                            <input type="text" asp-for="Product.Author"
                                   class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">文章来源</label>
                            <input type="text" asp-for="Product.Source"
                                   class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">原文链接</label>
                            <input type="url" asp-for="Product.OriginalUrl"
                                   class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">跳转链接</label>
                            <input type="url" asp-for="Product.RedirectUrl"
                                   class="w-full px-4 py-3 rounded-xl border-gray-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                        </div>
                    </div>
                </section>

                <!-- Settings Section -->
                <section class="space-y-6 pt-4">
                    <div class="flex items-center gap-2 pb-2 border-b border-gray-50">
                        <div class="w-1.5 h-6 bg-indigo-600 rounded-full"></div>
                        <h2 class="text-lg font-bold text-gray-900">发布设置</h2>
                    </div>

                    <div class="flex flex-wrap gap-8 items-center bg-gray-50/50 p-6 rounded-2xl border border-gray-100">
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="checkbox" asp-for="Product.IsSticky" class="w-5 h-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                            <span class="text-sm font-medium text-gray-700 group-hover:text-indigo-600 transition-colors">置顶产品</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="checkbox" asp-for="Product.IsHome" class="w-5 h-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                            <span class="text-sm font-medium text-gray-700 group-hover:text-indigo-600 transition-colors">推荐到首页</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="checkbox" asp-for="Product.IsHidden" class="w-5 h-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                            <span class="text-sm font-medium text-gray-700 group-hover:text-indigo-600 transition-colors">屏蔽显示</span>
                        </label>
                        <div class="flex items-center gap-4 ml-auto border-l border-gray-200 pl-8">
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input type="checkbox" asp-for="Product.ShowWatermark" class="w-5 h-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                                <span class="text-sm font-medium text-gray-700 group-hover:text-indigo-600 transition-colors">添加水印</span>
                            </label>
                            <select asp-for="Product.WatermarkPos" class="text-sm rounded-lg border-gray-200 py-1.5 focus:ring-indigo-500 focus:border-indigo-500">
                                <option value="RightBottom">右下角</option>
                                <option value="Center">居中</option>
                                <option value="CenterBottom">中下方</option>
                            </select>
                        </div>
                    </div>
                </section>
            </div>

            <!-- Form Actions -->
            <div class="px-8 py-6 bg-gray-50 border-t border-gray-100 flex items-center justify-end gap-4">
                <button type="button" onclick="history.back()" class="px-6 py-2.5 rounded-xl text-sm font-semibold text-gray-600 hover:bg-gray-200 transition-all">
                    取消编辑
                </button>
                <button type="submit" class="px-10 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-200 hover:-translate-y-0.5 transition-all active:scale-95">
                    保存修改
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function creativeForm(initialImage) {
            return {
                imagePreview: initialImage || null,
                previewImage(event) {
                    const file = event.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = (e) => {
                            this.imagePreview = e.target.result;
                        };
                        reader.readAsDataURL(file);
                    }
                }
            }
        }
    </script>
}

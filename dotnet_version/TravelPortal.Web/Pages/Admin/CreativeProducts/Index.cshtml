@page
@model TravelPortal.Web.Pages.Admin.CreativeProducts.IndexModel
@{
    ViewData["Title"] = "文创产品管理";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]">
    <partial name="_AdminPageHeader" model='new { 
        Title = "文创产品管理", 
        Subtitle = "Cultural & Creative Product Management",
        Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z\"></path></svg>",
        Tabs = new[] {
            new { Name = "产品列表", Url = Url.Page("Index"), IsActive = true },
            new { Name = "发布产品", Url = Url.Page("Create"), IsActive = false }
        }
    }' />

    <!-- Filters -->
    <div class="p-6 border-b border-gray-50 bg-gray-50/20">
        <form method="get" class="flex flex-wrap items-center gap-4">
            <div class="w-full md:w-48">
                <select name="Category" onchange="this.form.submit()"
                        class="w-full rounded-lg border-gray-200 text-sm focus:ring-indigo-500 focus:border-indigo-500">
                    <option value="">所有类别</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                    }
                </select>
            </div>
            
            <div class="w-full md:w-64 relative">
                <input type="text" name="Search" value="@Model.Search" placeholder="搜索产品名称..."
                       class="w-full pl-10 pr-4 py-2 rounded-lg border-gray-200 text-sm focus:ring-indigo-500 focus:border-indigo-500">
                <div class="absolute left-3 top-2.5 text-gray-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
            </div>

            <button type="submit" class="px-4 py-2 bg-gray-900 text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors">
                搜索
            </button>
            
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Category))
            {
                <a href="/Admin/CreativeProducts" class="text-sm text-gray-500 hover:text-indigo-600">清除筛选</a>
            }
        </form>
    </div>

    <!-- Table -->
    <div class="overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">标题</th>
                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">类别</th>
                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">浏览</th>
                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">添加日期</th>
                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">操作</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model.Products)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center">
                                    @if (!string.IsNullOrEmpty(item.MainImage))
                                    {
                                        <img src="@item.MainImage" class="w-10 h-10 rounded-lg object-cover mr-3 border border-gray-100">
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center mr-3 text-gray-400">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        </div>
                                    }
                                    <div>
                                        <div class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 transition-colors">@item.Title</div>
                                        <div class="flex items-center gap-2 mt-1">
                                            @if (item.IsSticky)
                                            {
                                                <span class="px-1.5 py-0.5 text-[10px] font-bold bg-orange-100 text-orange-600 rounded">已置顶</span>
                                            }
                                            @if (item.IsHidden)
                                            {
                                                <span class="px-1.5 py-0.5 text-[10px] font-bold bg-gray-100 text-gray-600 rounded">已屏蔽</span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.NonLegacyLevel))
                                            {
                                                <span class="px-1.5 py-0.5 text-[10px] font-bold bg-indigo-50 text-indigo-500 rounded">@item.NonLegacyLevel</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600">
                                <span class="px-2 py-1 bg-gray-100 rounded-md text-xs">@item.Classification</span>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600">@item.Views</td>
                            <td class="px-6 py-4 text-sm text-gray-500 font-mono">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="px-6 py-4 text-right space-x-2">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <a href="/Admin/CreativeProducts/Edit?id=@item.Id" 
                                       class="p-1.5 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all" title="编辑">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="inline" onsubmit="return confirm('确定要删除这个产品吗？')">
                                        <button type="submit" class="p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all" title="删除">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Products.Any())
        {
            <div class="py-12 text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-50 text-gray-300 mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                </div>
                <h3 class="text-gray-900 font-medium">暂无产品数据</h3>
                <p class="text-gray-500 text-sm mt-1">开始发布你的第一个文创产品吧</p>
            </div>
        }
    </div>
</div>

@page
@model TravelPortal.Web.Pages.Admin.CreativeProducts.IndexModel
@{
    ViewData["Title"] = "文创商品管理";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]">
<partial name="_AdminPageHeader" model='new { 
    Title = "文创商品管理", 
    Subtitle = "Cultural & Creative Product Management",
    Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z\"></path></svg>",
    Tabs = new[] {
        new { Name = "产品列表", Url = Url.Page("Index"), IsActive = true },
        new { Name = "发布产品", Url = Url.Page("Create"), IsActive = false }
    }
}' />

    <!-- 筛选栏 (GET form) -->
    <form method="get" id="filterForm" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white border-b border-gray-50">
        <div class="flex items-center space-x-3">
            <select asp-for="Category" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                <option value="">全部类别</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat">@cat</option>
                }
            </select>

            <div class="relative">
                <input type="text" asp-for="Search" placeholder="产品名称关键字" class="pl-4 pr-10 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs w-48 focus:ring-1 focus:ring-brand/20" />
                <button type="submit" class="absolute right-2 top-1.5 text-gray-400 hover:text-brand transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>

            <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 transition-all">搜索</button>
        </div>
    </form>

    <!-- 操作按钮 + 数据列表 (POST form) -->
    <form method="post" id="batchForm">
        <div class="px-6 py-3 flex items-center gap-2 border-b border-gray-50">
            <button type="submit" asp-page-handler="ToggleSticky" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">置顶</button>
            <button type="submit" asp-page-handler="Delete" onclick="return confirm('确定删除选中项吗？')" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">删除</button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded text-brand border-gray-200" /></th>
                        <th class="px-6 py-4">产品名称</th>
                        <th class="px-6 py-4 w-28">类别</th>
                        <th class="px-6 py-4 w-28">非遗级别</th>
                        <th class="px-6 py-4 w-20 text-center">浏览</th>
                        <th class="px-8 py-4 w-40 text-right">添加日期</th>
                        <th class="px-6 py-4 w-24 text-right">操作</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.Products.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="px-8 py-4"><input type="checkbox" name="ids" value="@item.Id" class="rounded text-brand border-gray-200" /></td>
                            <td class="px-6 py-4">
                                <div class="flex items-center space-x-2">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="text-gray-700 font-medium group-hover:text-brand transition-colors">@item.Title</a>
                                    @if (item.IsSticky) { <span class="text-[10px] text-red-500 font-bold">已置顶</span> }
                                    @if (item.IsHidden) { <span class="text-[10px] text-gray-400 font-bold">已屏蔽</span> }
                                </div>
                            </td>
                            <td class="px-6 py-4 text-xs text-gray-500">@item.Classification</td>
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(item.NonLegacyLevel))
                                {
                                    <span class="px-2 py-0.5 bg-indigo-50 text-indigo-600 text-[10px] font-bold rounded">@item.NonLegacyLevel</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center text-gray-400 font-mono">@item.Views</td>
                            <td class="px-8 py-4 text-right text-xs text-gray-400 font-mono">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="p-1.5 text-gray-400 hover:text-brand hover:bg-brand/5 rounded-lg transition-all" title="编辑">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <form method="post" asp-page-handler="Delete" class="inline" onsubmit="return confirm('确定删除该产品吗？')">
                                        <input type="hidden" name="ids" value="@item.Id" />
                                        <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all" title="删除">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Products.Items.Any())
                    {
                        <tr><td colspan="7" class="px-8 py-16 text-center text-gray-400 text-sm">暂无数据</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model.Products.Metadata" />
    </form>
</div>

<script>
    document.getElementById('selectAll').addEventListener('change', function () {
        document.querySelectorAll('input[name="ids"]').forEach(cb => cb.checked = this.checked);
    });
</script>

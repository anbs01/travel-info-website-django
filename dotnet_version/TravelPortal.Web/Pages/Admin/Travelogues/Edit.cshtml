@page "{id:int}"
@model TravelPortal.Web.Pages.Admin.Travelogues.EditModel
@{
    ViewData["Title"] = "编辑作品";
}

<div class="max-w-6xl mx-auto bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden mb-20" 
     x-data="{ mainCategory: '@Model.Travelogue.Category', imageUrl: '@Model.Travelogue.MainImage' }">
    
    <partial name="_TinyMCE" model='new { Selector = "#editor", Height = 600 }' />

    <!-- 头部 -->
    <div class="px-10 py-6 border-b border-gray-50 bg-gray-50/50 flex justify-between items-center">
        <div>
            <h1 class="text-xl font-bold text-gray-800">编辑作品</h1>
            <div class="flex space-x-4 mt-2 text-xs text-gray-400">
                <span>纪行攻略</span>
                <span>&gt;</span>
                <span class="text-brand font-bold">@Model.Travelogue.Title</span>
            </div>
        </div>
        <a asp-page="./Index" class="text-gray-400 hover:text-gray-600 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
        </a>
    </div>

    <form method="post" enctype="multipart/form-data" class="p-10 space-y-10">
        <input type="hidden" asp-for="Travelogue.Id" />
        <input type="hidden" asp-for="Travelogue.MainImage" />
        <input type="hidden" asp-for="Travelogue.CreatedAt" />
        <input type="hidden" asp-for="Travelogue.IsSticky" />
        <input type="hidden" asp-for="Travelogue.StickyAt" />
        <input type="hidden" asp-for="Travelogue.IsHidden" />

        <!-- 1. 输入标题 -->
        <div class="flex items-start space-x-6">
            <label class="w-24 pt-3 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>作品标题</label>
            <div class="flex-1 space-y-2">
                <input type="text" asp-for="Travelogue.Title" placeholder="给您的纪行起一个吸引人的标题吧..." 
                       class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl text-lg font-bold focus:ring-2 focus:ring-brand/20 transition-all" />
                <span asp-validation-for="Travelogue.Title" class="text-red-500 text-xs pl-2"></span>
            </div>
        </div>

        <!-- 2. 分类选择 -->
        <div class="flex items-start space-x-6">
            <label class="w-24 pt-3 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>选择分类</label>
            <div class="flex-1 flex space-x-4">
                <select asp-for="Travelogue.Category" x-model="mainCategory"
                        class="px-6 py-3 bg-gray-50 border-none rounded-xl text-sm font-medium focus:ring-2 focus:ring-brand/20 transition-all">
                    <option value="Stories">纪行故事</option>
                    <option value="Guides">实用攻略</option>
                </select>
                
                <select asp-for="Travelogue.PlaceId" asp-items="Model.PlaceList"
                        class="px-6 py-3 bg-gray-50 border-none rounded-xl text-sm font-medium focus:ring-2 focus:ring-brand/20 transition-all">
                    <option value="">所属城镇/乡村</option>
                </select>

                <select asp-for="Travelogue.RegionId" asp-items="Model.RegionList"
                        class="px-6 py-3 bg-gray-50 border-none rounded-xl text-sm font-medium focus:ring-2 focus:ring-brand/20 transition-all">
                    <option value="">所属地区 (如：烟台)</option>
                </select>
            </div>
        </div>

        <!-- 3. 上传焦点图 -->
        <div class="flex items-start space-x-6">
            <label class="w-24 pt-3 text-sm font-bold text-gray-700 text-right">更换封面</label>
            <div class="flex-1">
                <div class="relative w-full aspect-[21/9] rounded-3xl overflow-hidden bg-gray-50 border-2 border-dashed border-gray-200 group hover:border-brand/30 transition-all">
                    <!-- 预览图 -->
                    <template x-if="imageUrl">
                        <img :src="imageUrl" class="w-full h-full object-cover" />
                    </template>
                    <template x-if="!imageUrl">
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-300">
                            <svg class="w-16 h-16 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            <span class="text-sm font-medium">点击或拖拽上传封面图</span>
                        </div>
                    </template>
                    
                    <!-- 蒙层 -->
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                        <span class="px-6 py-2 bg-white rounded-full text-sm font-bold text-gray-800">更换图片</span>
                    </div>

                    <input type="file" asp-for="MainImageFile" class="absolute inset-0 opacity-0 cursor-pointer" x-on:change="if($event.target.files[0]) imageUrl = URL.createObjectURL($event.target.files[0])" />
                </div>
                <p class="mt-3 text-[10px] text-gray-400">建议比例 21:9，支持 JPG、PNG 格式，大小不超过 5MB</p>
            </div>
        </div>

        <!-- 4. 正文内容 -->
        <div class="flex items-start space-x-6">
            <label class="w-24 pt-3 text-sm font-bold text-gray-700 text-right"><span class="text-red-500">*</span>正文内容</label>
            <div class="flex-1">
                <textarea id="editor" asp-for="Travelogue.Content"></textarea>
                <span asp-validation-for="Travelogue.Content" class="text-red-500 text-xs mt-2 block"></span>
            </div>
        </div>

        <!-- 5. 摘要 -->
        <div class="flex items-start space-x-6">
            <label class="w-24 pt-3 text-sm font-bold text-gray-700 text-right">文章摘要</label>
            <div class="flex-1">
                <textarea asp-for="Travelogue.Summary" rows="3" placeholder="选填，若不填写将自动截取正文前100字..."
                          class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-brand/20 transition-all"></textarea>
            </div>
        </div>

        <!-- 6. 底部提交 -->
        <div class="pt-10 border-t border-gray-50 flex items-center justify-end space-x-4">
            <a asp-page="./Index" class="px-10 py-4 rounded-2xl text-sm font-bold text-gray-400 hover:bg-gray-50 transition-all">取消修改</a>
            <button type="submit" class="px-12 py-4 bg-brand text-white rounded-2xl text-sm font-bold shadow-xl shadow-brand/20 hover:scale-105 active:scale-95 transition-all">
                保存修改
            </button>
        </div>
    </form>
</div>

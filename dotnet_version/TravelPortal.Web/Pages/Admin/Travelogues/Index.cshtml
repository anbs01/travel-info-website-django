@page
@model TravelPortal.Web.Pages.Admin.Travelogues.IndexModel
@{
    ViewData["Title"] = "故事攻略";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]">
    <partial name="_AdminPageHeader" model='new { 
        Title = "故事攻略", 
        Subtitle = "Travel Guides & Experience Sharing",
        Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\"/></svg>",
        Tabs = new[] {
            new { Name = "纪行攻略", Url = Url.Page("Index"), IsActive = true },
            new { Name = "发布作品", Url = Url.Page("Create"), IsActive = false }
        }
    }' />

        <!-- 2. 操作与筛选栏 -->
        <form method="get" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white">
            <div class="flex items-center space-x-2">
                <button type="submit" asp-page-handler="ToggleSticky" formmethod="post" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">置顶</button>
                <button type="submit" asp-page-handler="ToggleHidden" formmethod="post" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">屏蔽</button>
                <button type="button" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">编辑</button>
                <button type="submit" asp-page-handler="Delete" formmethod="post" onclick="return confirm('确定删除选中项吗？')" class="px-4 py-1.5 bg-[#d4a373] text-white rounded text-xs font-bold hover:opacity-90 transition-all">删除</button>
            </div>
            
            <div class="flex items-center space-x-3">
                <select asp-for="Status" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                    <option value="">显示状态</option>
                    <option value="Normal">正常显示</option>
                    <option value="Sticky">已置顶</option>
                    <option value="Hidden">已屏蔽</option>
                </select>
                
                <select asp-for="GeoId" asp-items="Model.GeoList" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                    <option value="">全部城镇</option>
                </select>

                <div class="relative">
                    <input type="text" asp-for="Keyword" placeholder="名称关键字" class="pl-4 pr-10 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs w-48 focus:ring-1 focus:ring-brand/20" />
                    <button type="submit" class="absolute right-2 top-1.5 text-gray-400 hover:text-brand transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </button>
                </div>
                
                <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 transition-all">搜索</button>
            </div>
        </form>

        <!-- 3. 数据列表 -->
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded text-brand border-gray-200" /></th>
                        <th class="px-6 py-4">标题</th>
                        <th class="px-6 py-4 w-24 text-center">浏览</th>
                        <th class="px-8 py-4 w-40 text-center">添加日期</th>
                        <th class="px-8 py-4 w-32 text-right">操作</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.Travelogues)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="px-8 py-4"><input type="checkbox" name="ids" value="@item.Id" class="rounded text-brand border-gray-200" /></td>
                            <td class="px-6 py-4">
                                <div class="flex items-center space-x-2">
                                    <span class="text-gray-700 font-medium group-hover:text-brand transition-colors">@item.Title</span>
                                    @if (item.IsSticky)
                                    {
                                        <span class="px-2 py-0.5 bg-red-50 text-[10px] text-red-500 font-bold rounded">已置顶</span>
                                    }
                                    @if (item.IsHidden)
                                    {
                                        <span class="px-2 py-0.5 bg-gray-50 text-[10px] text-gray-400 font-bold rounded">已屏蔽</span>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4 text-center text-gray-400 font-mono">@item.Views</td>
                            <td class="px-8 py-4 text-center text-xs text-gray-400 font-mono">
                                @item.CreatedAt.ToString("yyyy-MM-dd")
                            </td>
                            <td class="px-8 py-4 text-right">
                                <div class="flex items-center justify-end space-x-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="p-1.5 text-gray-400 hover:text-brand hover:bg-brand/5 rounded-lg transition-all" title="编辑">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <button type="submit" asp-page-handler="Delete" asp-route-ids="@item.Id" 
                                            onclick="return confirm('确定删除该作品吗？')"
                                            class="p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all" title="删除">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 4. 分页占位 -->
        <div class="p-8 flex items-center justify-center space-x-4">
             <span class="text-xs text-gray-400">共 @Model.Travelogues.Count 条</span>
             <div class="flex space-x-2">
                 <span class="w-8 h-8 flex items-center justify-center rounded bg-brand text-white text-xs font-bold">1</span>
             </div>
        </div>
</div>

<script>
    document.getElementById('selectAll').addEventListener('change', function() {
        const checkboxes = document.querySelectorAll('input[name="ids"]');
        checkboxes.forEach(cb => cb.checked = this.checked);
    });
</script>

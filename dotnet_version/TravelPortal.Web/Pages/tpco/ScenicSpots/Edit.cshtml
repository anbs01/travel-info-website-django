@page "{id:int}"
@model TravelPortal.Web.Pages.tpco.ScenicSpots.EditModel
@{
    ViewData["Title"] = "编辑打卡点";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]" x-data="scenicForm('@Model.Spot.MainImage')">
    <partial name="_AdminPageHeader" model='new { 
        Tabs = new[] {
            new { Name = "打卡地列表", Url = Url.Page("Index"), IsActive = false },
            new { Name = "编辑打卡点", Url = "#", IsActive = true }
        }
    }' />

    <form method="post" enctype="multipart/form-data" class="p-8 space-y-10">
        <input type="hidden" asp-for="Spot.Id" />
        <input type="hidden" asp-for="Spot.MainImage" />
        <input type="hidden" asp-for="Spot.CreatedAt" />

        <div class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">打卡点名称 <span class="text-red-400">*</span></label>
                <div class="flex-1">
                    <input type="text" asp-for="Spot.Title" required maxlength="60"
                           class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">名气级别</label>
                <div class="flex-1">
                    <div class="flex flex-wrap gap-3">
                        @foreach (var lv in new[] { "知名景区", "热门景点", "小众秘境", "城市地标", "网红打卡地" })
                        {
                            <label class="relative flex items-center group cursor-pointer">
                                <input type="radio" asp-for="Spot.FameLevel" value="@lv" class="peer sr-only">
                                <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-green-50 peer-checked:border-green-600 peer-checked:text-green-700 transition-all group-hover:border-green-300">@lv</div>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">景区级别</label>
                <div class="flex-1">
                    <div class="flex flex-wrap gap-3">
                        @foreach (var g in new[] { "AAAAA级", "AAAA级", "AAA级", "AA级", "A级" })
                        {
                            <label class="relative flex items-center group cursor-pointer">
                                <input type="radio" asp-for="Spot.ScenicGrade" value="@g" class="peer sr-only">
                                <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-yellow-50 peer-checked:border-yellow-500 peer-checked:text-yellow-700 transition-all group-hover:border-yellow-300">@g</div>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">打卡点类别 <span class="text-red-400">*</span></label>
                <div class="flex-1">
                    <div class="flex flex-wrap gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                        @foreach (var cat in Model.ScenicCategories)
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Spot.Classification" value="@cat" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand transition-all">
                                <span class="text-sm text-gray-600 group-hover:text-brand transition-colors">@cat</span>
                            </label>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">焦点图</label>
                <div class="flex-1">
                    <div class="relative w-full max-w-sm aspect-[4/3] rounded-2xl overflow-hidden bg-gray-50 border-2 border-dashed border-gray-200 group hover:border-brand transition-all cursor-pointer"
                         @@click="$refs.fileInput.click()">
                        <template x-if="imagePreview">
                            <img :src="imagePreview" class="w-full h-full object-cover" />
                        </template>
                        <template x-if="!imagePreview">
                            <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-400">
                                <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
                                <span class="text-xs font-medium">更换图片</span>
                            </div>
                        </template>
                        <input type="file" x-ref="fileInput" name="MainImageFile" class="hidden" @@change="previewImage" accept="image/*">
                        <div x-show="imagePreview" class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <span class="text-white text-xs font-bold bg-white/20 backdrop-blur-md px-3 py-1.5 rounded-lg border border-white/30">上传新图片</span>
                        </div>
                    </div>
                    <p class="mt-2 text-xs text-gray-400">当前：<code class="bg-gray-100 px-1 rounded">@Model.Spot.MainImage</code></p>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">打卡特色 <span class="text-red-400">*</span></label>
                <div class="flex-1">
                    <textarea asp-for="Spot.Summary" rows="6" maxlength="120" required
                              class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium"></textarea>
                </div>
            </div>
        </div>

        <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
            <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">详细正文 <span class="text-red-400">*</span></label>
            <div class="flex-1 rounded-xl overflow-hidden border border-gray-100">
                <textarea id="editor" asp-for="Spot.Content"></textarea>
            </div>
        </div>
        <partial name="_TinyMCE" model='new { Selector = "#editor", Height = 600 }' />

        <div class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">选择地区 <span class="text-red-400">*</span></label>
                <div class="flex-1">
                    <partial name="_GeoPicker" model='new { FieldName = "Spot.GeoId", CurrentId = Model.Spot.GeoId, CurrentName = Model.CurrentGeoTitle }' />
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">文章作者</label>
                <div class="flex-1">
                    <input type="text" asp-for="Spot.Author"
                           class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">跳转链接</label>
                <div class="flex-1">
                    <input type="url" asp-for="Spot.RedirectUrl"
                           class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                </div>
            </div>
        </div>

        <div class="space-y-6 pt-4">
            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <div class="w-32 shrink-0">
                    <div class="text-xs font-bold text-gray-700">图片水印</div>
                    <div class="text-[10px] text-gray-400">正文图片是否带水印</div>
                </div>
                <div class="flex-1 flex flex-col sm:flex-row sm:items-center gap-4">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" asp-for="Spot.ShowWatermark" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                    </label>
                    <div class="flex items-center gap-4 bg-gray-50 px-4 py-2 rounded-xl border border-gray-100">
                        @foreach (var pos in new[] { (v:"Center", n:"中正"), (v:"Bottom", n:"中下"), (v:"BottomRight", n:"右下") })
                        {
                            <label class="flex items-center gap-1.5 cursor-pointer">
                                <input type="radio" asp-for="Spot.WatermarkPos" value="@pos.v" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand transition-all">
                                <span class="text-xs text-gray-500 font-medium transition-colors">@pos.n</span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <div class="w-32 shrink-0">
                    <div class="text-xs font-bold text-gray-700">置顶显示</div>
                    <div class="text-[10px] text-gray-400">是否置顶显示</div>
                </div>
                <div class="flex-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" asp-for="Spot.IsSticky" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                    </label>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <div class="w-32 shrink-0">
                    <div class="text-xs font-bold text-gray-700">首页推荐</div>
                    <div class="text-[10px] text-gray-400">是否推荐至首页展示</div>
                </div>
                <div class="flex-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" asp-for="Spot.IsHome" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                    </label>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <div class="w-32 shrink-0">
                    <div class="text-xs font-bold text-gray-700">屏蔽显示</div>
                    <div class="text-[10px] text-gray-400">是否隐藏屏蔽显示</div>
                </div>
                <div class="flex-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" asp-for="Spot.IsHidden" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                    </label>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">排序</label>
                <div class="flex-1 flex items-center gap-3">
                    <input type="number" asp-for="Spot.SortOrder" class="w-24 px-3 py-1.5 rounded-lg border-gray-200 focus:ring-brand focus:border-brand text-sm font-mono" />
                    <span class="text-[10px] text-gray-400">数字越小越靠前</span>
                </div>
            </div>
        </div>

        <div class="pt-10 flex justify-end space-x-4">
            <button type="submit" class="px-12 py-4 bg-brand text-white rounded-2xl text-sm font-bold shadow-xl shadow-brand/30 hover:scale-105 active:scale-95 transition-all">
                提交
            </button>
            <button type="reset" class="px-12 py-4 bg-gray-100 text-gray-500 hover:text-gray-700 hover:bg-gray-200 rounded-2xl text-sm font-bold hover:scale-105 active:scale-95 transition-all">
                重置
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    function scenicForm(initialImage) {
        return {
            imagePreview: initialImage || null,
            previewImage(event) {
                const file = event.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = (e) => { this.imagePreview = e.target.result; };
                    reader.readAsDataURL(file);
                }
            }
        }
    }
</script>
}

@page "{id:int}"
@model TravelPortal.Web.Pages.tpco.Geos.EditModel
@{
    ViewData["Title"] = Model.PageTitle;
    
    string listTitle = "行政列表";
    if (Model.Geo.Nature == "Overseas") listTitle = "海外城镇";
    else if (Model.Geo.Level == 1) listTitle = "国家列表";
    else if (Model.Geo.Level == 2) listTitle = "省份列表";
    else if (Model.Geo.Level >= 3) listTitle = "城镇列表";

    // 安全、健壮地过滤和解析已存的热词 ID
    var activeTagIds = (Model.Geo.Tags ?? "")
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(s => int.TryParse(s, out var id) ? id : (int?)null)
        .Where(id => id.HasValue)
        .Select(id => id!.Value)
        .ToList();

    // 实时根据加载的热词全量库，回显翻译出最新的中文名字
    var activeTagNames = Model.PlaceHotWords
        .Where(hw => activeTagIds.Contains(hw.Id))
        .Select(hw => hw.Name)
        .ToList();
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]">
    <partial name="_AdminPageHeader" model='new { 
        Tabs = new[] {
            new { Name = listTitle, Url = Url.Page("Index", new { parentId = Model.Geo.ParentId, level = Model.Geo.Level, nature = Model.Geo.Nature }), IsActive = false },
            new { Name = Model.PageTitle, Url = "#", IsActive = true }
        }
    }' />

    <form method="post" enctype="multipart/form-data" class="p-8 space-y-10">
        <input type="hidden" asp-for="Geo.Id" />
        <input type="hidden" asp-for="Geo.Level" />
        <input type="hidden" asp-for="Geo.Nature" />
        <input type="hidden" asp-for="Geo.GeoId" />
        <input type="hidden" asp-for="Geo.Views" />
        <input type="hidden" asp-for="Geo.PublishDate" />
        <input type="hidden" asp-for="Geo.MainImage" />
        <input type="hidden" asp-for="Geo.CreatedAt" />
        <input type="hidden" asp-for="ReturnUrl" />

        @if (Model.Geo.Level == 2)
        {
            <div class="space-y-6">
                <!-- 1. 省级简称 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">省级简称 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <input asp-for="Geo.Title" maxlength="60" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required />
                    </div>
                </div>

                <!-- 2. 省级全称 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">省级全称 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <input asp-for="Geo.FullTitle" maxlength="60" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required />
                    </div>
                </div>

                <!-- 3. 城乡代码 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡代码 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <input asp-for="Geo.Slug" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" 
                               required pattern="^[a-zA-Z]+$" title="城乡代码只能是纯英文字母（且不能有空格和特殊字符）" />
                        <span asp-validation-for="Geo.Slug" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- 4. 跳转链接 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">跳转链接</label>
                    <div class="flex-1">
                        <input asp-for="Geo.RedirectUrl" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" />
                    </div>
                </div>

                <!-- 5. 省份介绍 -->
                <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">省份介绍 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <textarea asp-for="Geo.Content" id="editor" class="hidden" required></textarea>
                        <span asp-validation-for="Geo.Content" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>
            </div>
        }
        else if (Model.Geo.Level >= 3 && Model.Geo.Nature == "Domestic")
        {
            <!-- 国内城镇专属编辑表单 -->
            <div x-data="{
                geoTags: [@(string.IsNullOrEmpty(Model.Geo.GeoTag) ? "" : string.Join(",", Model.Geo.GeoTag.Split(',').Where(t => new[] { "市府所在地", "省会城市", "副省级城市" }.Contains(t)).Select(t => $"'{t}'")))],
                hasOtherTag: @(Model.Geo.GeoTag?.Split(',').Any(t => t.StartsWith("其他:")) == true ? "true" : "false"),
                otherTagText: '@(Html.Raw(Model.Geo.GeoTag?.Split(',').FirstOrDefault(t => t.StartsWith("其他:"))?.Replace("其他:", "").Replace("'", "\\'") ?? ""))',
                selectedLevel: @(Model.Geo.Level >= 3 ? Model.Geo.Level : 3),
                bestTimes: [],
                selectedSeasons: [@(string.IsNullOrEmpty(Model.Geo.BestTime) ? "" : string.Join(",", Model.Geo.BestTime.Split(',').Intersect(new[] { "春季", "夏季", "秋季", "冬季" }).Select(t => $"'{t}'")))],
                hasOtherTime: @(Model.Geo.BestTime?.Split(',').Any(t => t.StartsWith("其他时间:")) == true ? "true" : "false"),
                otherTimeText: '@(Html.Raw(Model.Geo.BestTime?.Split(',').FirstOrDefault(t => t.StartsWith("其他时间:"))?.Replace("其他时间:", "").Replace("'", "\\'") ?? ""))',
                hideNav: @(Model.Geo.ShowNavStrip == false ? "true" : "false"),
                selectedTagIds: @Html.Raw(Json.Serialize(activeTagIds)),
                selectedTagNames: @Html.Raw(Json.Serialize(activeTagNames)),
                imageUrl: '@Model.Geo.MainImage',
                previewImage(e) {
                    const file = e.target.files[0];
                    if (file) this.imageUrl = URL.createObjectURL(file);
                },
                toggleTag(id, name) {
                    let idx = this.selectedTagIds.indexOf(id);
                    if (idx > -1) {
                        this.selectedTagIds.splice(idx, 1);
                        this.selectedTagNames.splice(idx, 1);
                    } else {
                        this.selectedTagIds.push(id);
                        this.selectedTagNames.push(name);
                    }
                },
                isTagSelected(id) {
                    return this.selectedTagIds.includes(id);
                }
            }" class="space-y-6">
                <!-- 1. 城乡简称 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡简称 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <input asp-for="Geo.Title" maxlength="60" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required />
                    </div>
                </div>

                <!-- 2. 城乡全称 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡全称 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <input asp-for="Geo.FullTitle" maxlength="60" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required />
                    </div>
                </div>

                <!-- 3. 城乡代码 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡代码 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <input asp-for="Geo.Slug" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" 
                               required pattern="^[a-zA-Z]+$" title="城乡代码只能是纯英文字母（且不能有空格和特殊字符）" />
                        <span asp-validation-for="Geo.Slug" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- 4. 城乡标签 -->
                <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">城乡标签</label>
                    <div class="flex-1">
                        <div class="flex flex-wrap items-center gap-3">
                            @foreach (var tag in new[] { "市府所在地", "省会城市", "副省级城市" })
                            {
                                <label class="relative flex items-center group cursor-pointer">
                                    <input type="checkbox" value="@tag" x-model="geoTags" class="peer sr-only">
                                    <div class="px-4 py-2 bg-gray-50 border border-gray-200 peer-checked:border-brand peer-checked:bg-brand/5 peer-checked:text-brand rounded-xl text-sm font-medium text-gray-600 transition-all">@tag</div>
                                </label>
                            }
                            <div class="flex items-center gap-2">
                                <label class="relative flex items-center group cursor-pointer">
                                    <input type="checkbox" x-model="hasOtherTag" class="peer sr-only">
                                    <div class="px-4 py-2 bg-gray-50 border border-gray-200 peer-checked:border-brand peer-checked:bg-brand/5 peer-checked:text-brand rounded-xl text-sm font-medium text-gray-600 transition-all">其他</div>
                                </label>
                                <div x-show="hasOtherTag" x-transition class="w-48" style="display: none;">
                                    <input type="text" x-model="otherTagText" placeholder="请输入其他标签..." class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand text-xs font-medium transition-all" />
                                </div>
                            </div>
                        </div>
                        <input type="hidden" name="Geo.GeoTag" :value="[...geoTags, (hasOtherTag && otherTagText.trim() ? '其他:' + otherTagText.trim() : '')].filter(Boolean).join(',')" />
                    </div>
                </div>

                <!-- 5. 城乡别名 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡别名</label>
                    <div class="flex-1">
                        <input asp-for="Geo.SubTitle" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" />
                    </div>
                </div>

                <!-- 6. 城乡级别 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡级别 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <div class="flex flex-wrap gap-3">
                            @foreach (var lv in new[] { (v: 3, n: "地级市"), (v: 4, n: "县级市"), (v: 5, n: "乡镇"), (v: 6, n: "村庄") })
                            {
                                <label class="relative flex items-center group cursor-pointer">
                                    <input type="checkbox" :checked="selectedLevel === @lv.v" x-on:change="selectedLevel = @lv.v" class="peer sr-only">
                                    <div class="px-4 py-2 bg-gray-50 border border-gray-200 peer-checked:border-brand peer-checked:bg-brand/5 peer-checked:text-brand rounded-xl text-sm font-medium text-gray-600 transition-all">@lv.n</div>
                                </label>
                            }
                        </div>
                        <input type="hidden" name="Geo.Level" :value="selectedLevel" />
                    </div>
                </div>

                <!-- 7. 行政区划 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">行政区划 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <partial name="_GeoPicker" model='new { FieldName = "Geo.ParentId", CurrentId = Model.Geo.ParentId, CurrentName = Model.Geo.Parent?.Title }' />
                        <span asp-validation-for="Geo.ParentId" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- 8. 旅游特色 -->
                <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">旅游特色 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <textarea asp-for="Geo.Summary" rows="3" maxlength="120" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required></textarea>
                    </div>
                </div>

                <!-- 9. 详细介绍 -->
                <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">详细介绍 <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <textarea asp-for="Geo.Content" id="editor" class="hidden" required></textarea>
                        <span asp-validation-for="Geo.Content" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- 10. 焦点图 -->
                <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">焦点图</label>
                    <div class="flex-1">
                        <div class="space-y-4">
                            <input type="file" name="MainImageFile" class="hidden" x-ref="photo" x-on:change="previewImage">
                            <div class="relative group aspect-[4/3] max-w-sm rounded-2xl bg-gray-100 overflow-hidden border-2 border-dashed border-gray-200 hover:border-brand transition-all cursor-pointer" 
                                 x-on:click.prevent="$refs.photo.click()">
                                <template x-if="!imageUrl">
                                    <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-400">
                                        <svg class="w-8 h-8 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                        <span class="text-[10px] font-bold uppercase tracking-widest">点击上传</span>
                                    </div>
                                </template>
                                <template x-if="imageUrl">
                                    <img :src="imageUrl" class="absolute inset-0 w-full h-full object-cover">
                                </template>
                                <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                    <span class="text-white text-xs font-bold">点击更换</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 11. 最佳旅游时间 -->
                <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">最佳旅游时间</label>
                    <div class="flex-1">
                        <div class="flex flex-wrap items-center gap-3">
                            @foreach (var season in new[] { "春季", "夏季", "秋季", "冬季" })
                            {
                                <label class="relative flex items-center group cursor-pointer">
                                    <input type="checkbox" value="@season" x-model="selectedSeasons" class="peer sr-only">
                                    <div class="px-4 py-2 bg-gray-50 border border-gray-200 peer-checked:border-brand peer-checked:bg-brand/5 peer-checked:text-brand rounded-xl text-sm font-medium text-gray-600 transition-all">@season</div>
                                </label>
                            }
                            <div class="flex items-center gap-2">
                                <label class="relative flex items-center group cursor-pointer">
                                    <input type="checkbox" x-model="hasOtherTime" class="peer sr-only">
                                    <div class="px-4 py-2 bg-gray-50 border border-gray-200 peer-checked:border-brand peer-checked:bg-brand/5 peer-checked:text-brand rounded-xl text-sm font-medium text-gray-600 transition-all">其他时间</div>
                                </label>
                                <div x-show="hasOtherTime" x-transition class="w-48" style="display: none;">
                                    <input type="text" x-model="otherTimeText" placeholder="请输入其他时间..." class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand text-xs font-medium transition-all" />
                                </div>
                            </div>
                        </div>
                        <input type="hidden" name="Geo.BestTime" :value="[...selectedSeasons, (hasOtherTime && otherTimeText.trim() ? '其他时间:' + otherTimeText.trim() : '')].filter(Boolean).join(',')" />
                    </div>
                </div>

                <!-- 12. 跳转链接 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">跳转链接</label>
                    <div class="flex-1">
                        <input asp-for="Geo.RedirectUrl" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" />
                    </div>
                </div>

                <!-- 13. 搜索热词 -->
                <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">搜索热词</label>
                    <div class="flex-1 space-y-4">
                        <!-- 只读输入框，用于前台展示中文热词名称列表 -->
                        <input type="text" :value="selectedTagNames.join(',')" readonly class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium cursor-not-allowed" placeholder="请选择下方推荐热词进行添加（只读，无法手动修改）..." />
                        
                        <!-- 隐藏的 input，真正提交到数据库 Geo.Tags 字段中的 ID 字符串 -->
                        <input type="hidden" name="Geo.Tags" :value="selectedTagIds.join(',')" />
                        
                        @if (Model.PlaceHotWords != null && Model.PlaceHotWords.Any())
                        {
                            <div class="space-y-1.5 p-4 bg-gray-50 rounded-2xl border border-gray-100 max-w-3xl">
                                <div class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">推荐热词分类（点击快捷选择）：</div>
                                <div class="flex flex-wrap gap-2 pt-1">
                                    @foreach (var hw in Model.PlaceHotWords)
                                    {
                                        <button type="button" x-on:click="toggleTag(@hw.Id, '@hw.Name')"
                                                :class="isTagSelected(@hw.Id) ? 'bg-brand text-white border-brand shadow-sm font-bold' : 'bg-white text-gray-600 border-gray-200 hover:border-brand hover:text-brand'"
                                                class="px-3 py-1.5 border rounded-lg text-xs transition-all transform hover:scale-[1.03] active:scale-95 duration-100">
                                            @hw.Name
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- 14. 图片水印 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <div class="w-32 shrink-0">
                        <div class="text-xs font-bold text-gray-700">图片水印</div>
                        <div class="text-[10px] text-gray-400">是否在详细正文图中显示水印</div>
                    </div>
                    <div class="flex-1 flex flex-col sm:flex-row sm:items-center gap-4">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" asp-for="Geo.ShowWatermark" class="sr-only peer">
                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                            <span class="text-xs font-bold text-gray-500 ml-3">显示水印</span>
                        </label>
                        <div class="flex items-center gap-4 bg-gray-50 px-4 py-2 rounded-xl border border-gray-100">
                            @foreach (var pos in new[] { (v:"Center", n:"中正"), (v:"BottomCenter", n:"中下"), (v:"BottomRight", n:"右下") })
                            {
                                <label class="flex items-center gap-1.5 cursor-pointer">
                                    <input type="radio" asp-for="Geo.WatermarkPos" value="@pos.v" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand transition-all">
                                    <span class="text-xs text-gray-500 font-medium transition-colors">@pos.n</span>
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <!-- 15. 详情页导航条 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <div class="w-32 shrink-0">
                        <div class="text-xs font-bold text-gray-700">详情页导航条</div>
                        <div class="text-[10px] text-gray-400">是否显示顶部导航</div>
                    </div>
                    <div class="flex-1">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" :checked="hideNav" x-on:change="hideNav = $event.target.checked" class="sr-only peer">
                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                            <span class="text-xs font-bold text-gray-500 ml-3">不显示</span>
                        </label>
                        <input type="hidden" name="Geo.ShowNavStrip" :value="hideNav ? 'false' : 'true'" />
                    </div>
                </div>

                <!-- 16. 排序 -->
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">排序</label>
                    <div class="flex-1 flex items-center gap-3">
                        <input type="number" asp-for="Geo.SortOrder" class="w-24 px-3 py-1.5 rounded-lg border-gray-200 focus:ring-brand focus:border-brand text-xs font-mono" />
                        <span class="text-[10px] text-gray-400">数字越小越靠前</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="space-y-6">
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">@(Model.Geo.Level == 1 ? "国家简称" : "中文简称") <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <input asp-for="Geo.Title" maxlength="60" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required />
                    </div>
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                    <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">@(Model.Geo.Level == 1 ? "国家全称" : "中文全称") <span class="text-red-400">*</span></label>
                    <div class="flex-1">
                        <input asp-for="Geo.FullTitle" maxlength="60" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required />
                    </div>
                </div>
                @if (Model.Geo.Level >= 3)
                {
                    <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                        <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡代码 <span class="text-red-400">*</span></label>
                        <div class="flex-1">
                            <input asp-for="Geo.Slug" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" 
                                   required pattern="^[a-zA-Z]+$" title="城乡代码只能是纯英文字母（且不能有空格和特殊字符）" />
                            <span asp-validation-for="Geo.Slug" class="text-red-400 text-xs mt-1 block"></span>
                        </div>
                    </div>
                }
            </div>

            @if (Model.Geo.Level > 1)
            {
                <div class="space-y-6">
                    @if (Model.Geo.Level >= 3)
                    {
                        <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                            <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡级别 <span class="text-red-400">*</span></label>
                            <div class="flex-1">
                                <select asp-for="Geo.GeoTag" id="geoTagSelect" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required>
                                    <option value="地级市" data-level="3">地级市</option>
                                    <option value="县级市" data-level="4">县级市/区</option>
                                    <option value="乡镇" data-level="5">乡镇</option>
                                    <option value="村庄" data-level="6">村庄</option>
                                    <option value="其他" data-level="3">其他</option>
                                </select>
                            </div>
                        </div>
                        <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                            <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">城乡别名</label>
                            <div class="flex-1">
                                <input asp-for="Geo.SubTitle" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" />
                            </div>
                        </div>
                    }
                    
                    @if (Model.Geo.Nature == "Overseas")
                    {
                        <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                            <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">英文名称</label>
                            <div class="flex-1">
                                <input asp-for="Geo.EnglishName" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" />
                            </div>
                        </div>
                    }
                </div>

                <div class="space-y-6">
                    @if (Model.Geo.Level >= 3)
                    {
                        <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                            <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">旅游特色 / 简介 <span class="text-red-400">*</span></label>
                            <div class="flex-1">
                                <textarea asp-for="Geo.Summary" rows="3" maxlength="120" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required></textarea>
                            </div>
                        </div>
                    }

                    <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                        <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">详细介绍 <span class="text-red-400">*</span></label>
                        <div class="flex-1">
                            <textarea asp-for="Geo.Content" id="editor" class="hidden" required></textarea>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                        <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">焦点图片</label>
                        <div class="flex-1">
                            <div x-data="{ photoName: null, photoPreview: '@Model.Geo.MainImage' }" class="space-y-4">
                                <input type="file" name="MainImageFile" class="hidden" x-ref="photo"
                                       x-on:change="
                                            photoName = $refs.photo.files[0].name;
                                            const reader = new FileReader();
                                            reader.onload = (e) => {
                                                photoPreview = e.target.result;
                                            };
                                            reader.readAsDataURL($refs.photo.files[0]);
                                       ">
                                <div class="relative group aspect-[4/3] max-w-sm rounded-2xl bg-gray-100 overflow-hidden border-2 border-dashed border-gray-200 hover:border-brand transition-all cursor-pointer" 
                                     x-on:click.prevent="$refs.photo.click()">
                                    <template x-if="!photoPreview">
                                        <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-400">
                                            <svg class="w-8 h-8 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                            <span class="text-[10px] font-bold uppercase tracking-widest">更换图片</span>
                                        </div>
                                    </template>
                                    <template x-if="photoPreview">
                                        <img :src="photoPreview" class="absolute inset-0 w-full h-full object-cover">
                                    </template>
                                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                        <span class="text-white text-xs font-bold">点击更换</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                        <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">最佳旅游时间</label>
                        <div class="flex-1">
                            <select asp-for="Geo.BestTime" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                                <option value="一年四季">一年四季</option>
                                <option value="春季">春季</option>
                                <option value="夏季">夏季</option>
                                <option value="秋季">秋季</option>
                                <option value="冬季">冬季</option>
                                <option value="其他">其他</option>
                            </select>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                        <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">搜索标签</label>
                        <div class="flex-1">
                            <input asp-for="Geo.Tags" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" />
                        </div>
                    </div>
                </div>

                <div class="space-y-6 pt-4">
                    <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                        <div class="w-32 shrink-0">
                            <div class="text-xs font-bold text-gray-700">详情页导航</div>
                            <div class="text-[10px] text-gray-400">是否显示顶部导航</div>
                        </div>
                        <div class="flex-1">
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input asp-for="Geo.ShowNavStrip" type="checkbox" class="sr-only peer">
                                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                            </label>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                        <div class="w-32 shrink-0">
                            <div class="text-xs font-bold text-gray-700">图片水印</div>
                            <div class="text-[10px] text-gray-400">正文图片是否带水印</div>
                        </div>
                        <div class="flex-1">
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input asp-for="Geo.ShowWatermark" type="checkbox" class="sr-only peer">
                                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                            </label>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                        <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">水印位置</label>
                        <div class="flex-1">
                            <select asp-for="Geo.WatermarkPos" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                                <option value="Center">中正</option>
                                <option value="BottomCenter">中下</option>
                                <option value="BottomRight">右下</option>
                            </select>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                        <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">排序</label>
                        <div class="flex-1 flex items-center gap-3">
                            <input type="number" asp-for="Geo.SortOrder" class="w-24 px-3 py-1.5 rounded-lg border-gray-200 focus:ring-brand focus:border-brand text-xs font-mono" />
                            <span class="text-[10px] text-gray-400">数字越小越靠前</span>
                        </div>
                    </div>
                </div>
            }
        }

        <div class="pt-10 flex justify-end space-x-4">
            <button type="submit" class="px-12 py-4 bg-brand text-white rounded-2xl text-sm font-bold shadow-xl shadow-brand/30 hover:scale-105 active:scale-95 transition-all">
                提交
            </button>
            <button type="reset" class="px-12 py-4 bg-gray-100 text-gray-500 hover:text-gray-700 hover:bg-gray-200 rounded-2xl text-sm font-bold hover:scale-105 active:scale-95 transition-all">
                重置
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_TinyMCE" model='new { Selector = "#editor", Height = 450 }' />
    <script>
        function initGeoLevelSync() {
            const geoTagSelect = document.getElementById("geoTagSelect");
            const levelInput = document.querySelector("input[name='Geo.Level']");
            const parentLevel = @(Model.ParentGeo?.Level ?? 0);

            if (geoTagSelect && levelInput) {
                let firstValidIndex = -1;
                Array.from(geoTagSelect.options).forEach((opt, idx) => {
                    const optLevel = parseInt(opt.getAttribute("data-level") || "3");
                    if (parentLevel > 0 && optLevel <= parentLevel) {
                        opt.disabled = true;
                        if (!opt.text.includes("(层级冲突")) {
                            opt.text += " (层级冲突-不可选)";
                        }
                    } else if (firstValidIndex === -1) {
                        firstValidIndex = idx;
                    }
                });

                if (geoTagSelect.selectedIndex !== -1 && geoTagSelect.options[geoTagSelect.selectedIndex].disabled && firstValidIndex !== -1) {
                    geoTagSelect.selectedIndex = firstValidIndex;
                }

                if (!geoTagSelect.dataset.listenerBound) {
                    geoTagSelect.addEventListener("change", function () {
                        const selectedOpt = geoTagSelect.options[geoTagSelect.selectedIndex];
                        if (selectedOpt) {
                            const newLevel = parseInt(selectedOpt.getAttribute("data-level") || "3");
                            levelInput.value = newLevel;
                        }
                    });
                    geoTagSelect.dataset.listenerBound = "true";
                }

                const selectedOpt = geoTagSelect.options[geoTagSelect.selectedIndex];
                if (selectedOpt) {
                    const newLevel = parseInt(selectedOpt.getAttribute("data-level") || "3");
                    levelInput.value = newLevel;
                }
            }
        }

        initGeoLevelSync();
        document.addEventListener("DOMContentLoaded", initGeoLevelSync);

        if (window.up) {
            up.compiler('#geoTagSelect', function(element) {
                initGeoLevelSync();
            });
        }
    </script>
}

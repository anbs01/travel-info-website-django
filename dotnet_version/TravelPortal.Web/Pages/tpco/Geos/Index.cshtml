@page
@model TravelPortal.Web.Pages.tpco.Geos.IndexModel
@{
    string typeName = Model.Level switch
    {
        1 => "国家",
        2 => "省份",
        3 => "城市",
        4 => "区县",
        5 => "乡镇",
        6 => "村庄",
        _ => "节点"
    };

    string title = $"{typeName}管理";
    string listTitle = $"{typeName}列表";
    string createTitle = $"发布{typeName}";
    
    if (Model.Nature == "Overseas") 
    {
        title = "海外城镇";
        listTitle = "海外城镇";
        createTitle = "发布海外城镇";
    }

    ViewData["Title"] = title;
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]">
<partial name="_AdminPageHeader" model='new { 
    Title = title, 
    Subtitle = "Global Geographic Content Management System",
    Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z\"/><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 11a3 3 0 11-6 0 3 3 0 016 0z\"/></svg>",
    Tabs = new[] {
        new { Name = listTitle, Url = Url.Page("Index", new { parentId = Model.ParentId, level = Model.Level, nature = Model.Nature }), IsActive = true },
        new { Name = createTitle, Url = Url.Page("Create", new { parentId = Model.ParentId, level = (Model.Level ?? (Model.ParentGeo?.Level + 1) ?? 1), nature = Model.Nature }), IsActive = false }
    },
    RightContent = Model.ParentGeo != null ? $"<span class=\"px-3 py-1.5 bg-brand/10 text-brand text-xs rounded-xl font-bold\">上级：{Model.ParentGeo.Title}</span>" : null
}' />

<div class="p-6">
    <form method="post" id="batchForm">
        <partial name="_AdminTableToolbar" model='new { 
            TotalCount = Model.GeoList.Items.Count(),
            Buttons = new List<dynamic> {
                new { Id = "Edit", Text = "编辑", ActionType = "redirect", IsSingleSelectOnly = true },
                new { Id = "Delete", Text = "删除", Handler = "Delete", ActionType = "delete" }
            }
        }' />

        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded text-brand border-gray-200" /></th>
                        <th class="px-6 py-4 w-16">ID</th>
                        <th class="px-6 py-4">名称</th>
                        <th class="px-6 py-4">性质</th>
                        <th class="px-6 py-4">Slug</th>
                        <th class="px-6 py-4">排序</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.GeoList.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group" data-url="@Url.Page("Edit", new { id = item.Id })">
                            <td class="px-8 py-4"><input type="checkbox" name="ids" value="@item.Id" class="rounded text-brand border-gray-200" /></td>
                            <td class="px-6 py-4 font-mono text-xs text-gray-400">@item.Id</td>
                            <td class="px-6 py-4">
                                <a asp-page="Edit" asp-route-id="@item.Id" class="flex items-center space-x-2 group/title">
                                    <span class="text-gray-700 font-medium group-hover/title:text-brand transition-colors">@item.Title</span>
                                    <svg class="w-3 h-3 text-gray-300 opacity-0 group-hover/title:opacity-100 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                </a>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-0.5 rounded text-[10px] font-bold @(item.Nature == "Overseas" ? "bg-purple-50 text-purple-600" : "bg-green-50 text-green-600")">
                                    @item.Nature
                                </span>
                            </td>
                            <td class="px-6 py-4 text-xs text-gray-400">@item.Slug</td>
                            <td class="px-6 py-4 text-xs text-gray-400">@item.SortOrder</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </form>
    <partial name="_Pagination" model="Model.GeoList.Metadata" />
</div>

@functions {
    string GetLevelName(int level) => level switch
    {
        1 => "国家",
        2 => "省份",
        3 => "城市",
        4 => "区县",
        5 => "乡镇",
        6 => "村庄",
        _ => "未知"
    };
}

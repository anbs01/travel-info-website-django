@page
@model TravelPortal.Web.Pages.tpco.Geos.IndexModel
@{
    string typeName = Model.Level switch
    {
        1 => "国家",
        2 => "省份",
        3 => "城乡",
        4 => "区县",
        5 => "乡镇",
        6 => "村庄",
        _ => "节点"
    };

    string title = $"{typeName}管理";
    string listTitle = $"{typeName}列表";
    string createTitle = $"发布{typeName}";
    
    if (Model.Nature == "Overseas") 
    {
        title = "海外城镇";
        listTitle = "海外城镇";
        createTitle = "发布海外城镇";
    }

    ViewData["Title"] = title;
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]"
     x-data="{ 
        selectedIds: [], 
        toggleAll(checked) {
            this.selectedIds = checked ? Array.from(document.querySelectorAll('input[name=ids]')).map(el => el.value) : [];
        }
     }">
<partial name="_AdminPageHeader" model='new { 
    Title = title, 
    Tabs = new[] {
        new { Name = listTitle, Url = Url.Page("Index", new { parentId = Model.ParentId, level = Model.Level, nature = Model.Nature }), IsActive = true },
        new { Name = createTitle, Url = Url.Page("Create", new { parentId = Model.ParentId, level = (Model.Level ?? (Model.ParentGeo?.Level + 1) ?? 1), nature = Model.Nature }), IsActive = false }
    },
    RightContent = Model.ParentGeo != null ? $"<span class=\"px-3 py-1.5 bg-brand/10 text-brand text-xs rounded-xl font-bold\">上级：{Model.ParentGeo.Title}</span>" : null
}' />

<div class="p-0">
    <form method="post" id="batchForm">
        <!-- 3. 操作工具栏 -->
        <div class="px-8 py-4 flex items-center justify-between bg-white border-b border-gray-100">
            <div class="flex items-center gap-3">
                <button type="button" 
                        @@click="if(selectedIds.length > 0) confirmAndPost('警告：确定要批量删除已选中的地点吗？操作不可恢复！', 'Delete', selectedIds.join(','))"
                        class="bg-brand text-white border-brand/80 px-4 py-1.5 rounded-sm border-b-2 text-xs font-bold tracking-widest transition-all flex items-center gap-2"
                        :class="selectedIds.length > 0 ? 'opacity-100 hover:bg-brand/90 active:translate-y-[1px] active:border-b-0' : 'opacity-50 cursor-not-allowed'">
                    <span>批量删除</span>
                </button>
            </div>

            <div class="text-[10px] text-gray-400 font-medium bg-gray-50 px-3 py-1 rounded-full border border-gray-100">
                已选 <span class="text-brand font-bold font-mono" x-text="selectedIds.length">0</span> / @Model.GeoList.Items.Count()
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12 text-center">
                            <input type="checkbox" @@change="toggleAll($event.target.checked)" 
                                   :checked="selectedIds.length === @Model.GeoList.Items.Count() && @Model.GeoList.Items.Count() > 0"
                                   class="rounded text-brand border-gray-200 focus:ring-brand" />
                        </th>
                        <th class="px-6 py-4 w-16">ID</th>
                        <th class="px-6 py-4">@(Model.Level <= 2 ? "简称" : "名称")</th>
                        @if (Model.Level == 1) { <th class="px-6 py-4">全称</th> <th class="px-6 py-4 text-center">城乡数</th> }
                        else if (Model.Level == 2) { <th class="px-6 py-4">全称</th> <th class="px-6 py-4 text-center">浏览数</th> }
                        else if (Model.Nature == "Overseas") { <th class="px-6 py-4">全称</th> <th class="px-6 py-4 text-center">所属国家</th> <th class="px-6 py-4 text-center">浏览数</th> }
                        else { <th class="px-6 py-4">所属省份</th> <th class="px-6 py-4 text-center">浏览数</th> }
                        <th class="px-6 py-4 w-24">排序</th>
                        <th class="px-8 py-4 text-center w-48">添加时间</th>
                        <th class="px-8 py-4 text-center w-32">操作</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.GeoList.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group"
                            :class="selectedIds.includes('@item.Id') ? 'bg-brand/5' : ''">
                            <td class="px-8 py-4 text-center">
                                <input type="checkbox" name="ids" value="@item.Id" x-model="selectedIds"
                                       class="rounded text-brand border-gray-200 focus:ring-brand" />
                            </td>
                            <td class="px-6 py-4 text-gray-400 font-mono text-xs">@item.Id</td>
                            <td class="px-6 py-4">
                                @if (Model.Level == 3)
                                {
                                    <div class="flex flex-col space-y-1.5 py-1">
                                        <!-- 第一行：名称 + 标签 -->
                                        <div class="flex items-center space-x-2.5">
                                            <span class="text-gray-900 font-bold text-[15px]">@item.Title</span>
                                            
                                            <!-- 状态标签组 -->
                                            <div class="flex items-center space-x-1.5 text-xs text-red-500 font-medium">
                                                @if (item.IsHome)
                                                {
                                                    <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-50 text-red-600 border border-red-100">主页</span>
                                                }
                                                @if (item.IsSticky)
                                                {
                                                    <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-50 text-red-600 border border-red-100">已置顶</span>
                                                }
                                                @if (item.IsHidden)
                                                {
                                                    <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-50 text-red-600 border border-red-100">已屏蔽</span>
                                                }
                                            </div>
                                        </div>
                                        
                                        <!-- 第二行：子项统计 -->
                                        <div class="flex items-center space-x-3.5 text-xs text-gray-400 font-medium whitespace-nowrap">
                                            <a href="/tpco/ScenicSpots?GeoId=@item.Id&ScenicGrade=Scenic" class="text-gray-400 hover:text-brand hover:underline transition-colors">@item.ScenicSpotCount 景区</a>
                                            <a href="/tpco/ScenicSpots?GeoId=@item.Id&ScenicGrade=Attraction" class="text-gray-400 hover:text-brand hover:underline transition-colors">@item.AttractionCount 打卡地</a>
                                            <a href="/tpco/Foods?GeoId=@item.Id" class="text-gray-400 hover:text-brand hover:underline transition-colors">@item.FoodCount 美食</a>
                                            <a href="/tpco/CreativeProducts?GeoId=@item.Id" class="text-gray-400 hover:text-brand hover:underline transition-colors">@item.ProductCount 文创</a>
                                            <a href="/tpco/Travelogues?GeoId=@item.Id" class="text-gray-400 hover:text-brand hover:underline transition-colors">@item.TravelogueCount 攻略</a>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-gray-700 font-medium">@item.Title</span>
                                }
                            </td>
                            
                            @if (Model.Level == 1 || Model.Level == 2 || Model.Nature == "Overseas") { <td class="px-6 py-4 text-xs text-gray-500">@(Model.Nature == "Overseas" ? item.EnglishName : item.Title)</td> }
                            
                            @if (Model.Level == 1) { <td class="px-6 py-4 text-center text-gray-400 font-mono text-xs">@item.JurisdictionLayers</td> }
                            else if (Model.Level == 2) { <td class="px-6 py-4 text-center text-gray-400 font-mono text-xs">@item.Views</td> }
                            else if (Model.Nature == "Overseas") { 
                                <td class="px-6 py-4 text-center text-xs text-gray-500">@(item.Parent?.Title ?? "-")</td> 
                                <td class="px-6 py-4 text-center text-gray-400 font-mono text-xs">@item.Views</td> 
                            }
                            else { 
                                <td class="px-6 py-4 text-center text-xs text-gray-500">@(item.Parent?.Title ?? "-")</td> 
                                <td class="px-6 py-4 text-center text-gray-400 font-mono text-xs">@item.Views</td> 
                            }

                            <td class="px-6 py-4">
                                <span class="text-gray-400 text-xs font-mono">@item.SortOrder</span>
                            </td>
                            <td class="px-8 py-4 text-center text-xs text-gray-400 font-mono whitespace-nowrap">
                                @item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                            </td>
                            <td class="px-8 py-4 text-center">
                                <div class="flex items-center justify-center space-x-2">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" 
                                       class="p-1.5 text-brand hover:bg-brand/10 rounded-lg transition-colors" 
                                       title="编辑">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <button type="button" 
                                            @@click="confirmAndPost('警告：确定要彻底删除该地点吗？操作不可恢复！', 'Delete', '@item.Id')"
                                            class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg transition-colors" 
                                            title="删除">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.GeoList.Items.Any())
                    {
                        <tr><td colspan="10" class="px-8 py-16 text-center text-gray-400 text-sm">暂无数据</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-6 border-t border-gray-50 bg-gray-50/30">
            <partial name="_Pagination" model="Model.GeoList.Metadata" />
        </div>
    </form>
</div>
</div>

@functions {
    string GetLevelName(int level) => level switch
    {
        1 => "国家",
        2 => "省份",
        3 => "城市",
        4 => "区县",
        5 => "乡镇",
        6 => "村庄",
        _ => "未知"
    };
}

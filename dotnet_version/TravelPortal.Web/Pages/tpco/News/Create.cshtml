@page
@model TravelPortal.Web.Pages.tpco.News.CreateModel
@{
    ViewData["Title"] = "发布资讯";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]" x-data="{ imageUrl: '' }">
    <partial name="_AdminPageHeader" model='new { 
        Tabs = new[] {
            new { Name = "资讯列表", Url = Url.Page("Index"), IsActive = false },
            new { Name = "发布资讯", Url = Url.Page("Create"), IsActive = true }
        }
    }' />

    <form method="post" enctype="multipart/form-data" class="p-8 space-y-10">
        <!-- Section 1: Core Info -->

            <div class="space-y-8">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">文章标题 <span class="text-red-500">*</span></label>
                    <input type="text" asp-for="News.Title" maxlength="60"
                           class="w-full px-6 py-4 bg-gray-50 border-none rounded-2xl text-lg font-bold focus:ring-2 focus:ring-brand/20 transition-all" required />
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-3">文章分类 <span class="text-red-500">*</span></label>
                    <div class="flex flex-wrap gap-6 p-4 bg-gray-50 rounded-2xl border border-gray-100">
                        @foreach (var cat in Model.NewsCategories)
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="News.NewsCategory" value="@cat.Name" class="w-5 h-5 text-brand border-gray-300 focus:ring-brand" />
                                <span class="text-sm font-medium text-gray-600 group-hover:text-brand">@cat.Name</span>
                            </label>
                        }
                        @if (!Model.NewsCategories.Any())
                        {
                            <span class="text-xs text-gray-400 italic">请先在“综合管理 > 类别热词”中添加勾选了“资讯类别”的词条</span>
                        }
                    </div>
                </div>
            </div>


        <!-- Section 2: Content & Media -->

            <div class="grid grid-cols-1 gap-8">
                <div class="md:col-span-2 space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-3">正文内容 <span class="text-red-500">*</span></label>
                        <textarea id="editor" asp-for="News.Content"></textarea>
                    </div>
                </div>

                <div class="md:col-span-1 space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-3">焦点图</label>
                        <div class="relative w-full aspect-video rounded-2xl overflow-hidden bg-gray-50 border-2 border-dashed border-gray-200 group hover:border-brand transition-all cursor-pointer"
                             @@click="$refs.fileInput.click()">
                            <template x-if="imageUrl">
                                <img :src="imageUrl" class="w-full h-full object-cover" />
                            </template>
                            <template x-if="!imageUrl">
                                <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-300">
                                    <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    <span class="text-xs font-medium text-gray-400">点击上传焦点图</span>
                                </div>
                            </template>
                            <input type="file" asp-for="MainImageFile" x-ref="fileInput" class="hidden" 
                                   x-on:change="if($event.target.files[0]) imageUrl = URL.createObjectURL($event.target.files[0])" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">文章概述</label>
                        <textarea asp-for="News.Summary" rows="6" maxlength="120"
                                  class="w-full px-4 py-3 bg-gray-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-brand/20 transition-all"></textarea>
                    </div>
                </div>
            </div>


        <!-- Section 3: Metadata -->

            <div class="grid grid-cols-1 gap-8">
                <div class="grid grid-cols-1 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">文章作者</label>
                        <input type="text" asp-for="News.Author" class="w-full px-4 py-3 bg-gray-50 border-none rounded-xl text-sm focus:ring-2 focus:ring-brand/20" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">文章来源</label>
                        <input type="text" asp-for="News.Source" class="w-full px-4 py-3 bg-gray-50 border-none rounded-xl text-sm focus:ring-2 focus:ring-brand/20" />
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <label class="text-sm font-bold text-gray-700">排序</label>
                    <input type="number" asp-for="News.SortOrder" class="w-24 px-3 py-1.5 rounded-lg border-gray-200 focus:ring-brand focus:border-brand text-sm font-mono" />
                    <span class="text-[10px] text-gray-400">数字越小越靠前</span>
                </div>
            </div>


        <!-- Actions -->
        <div class="pt-10 flex justify-end space-x-4 border-t border-gray-50">
            <button type="submit" class="px-12 py-4 bg-brand text-white rounded-2xl text-sm font-bold shadow-xl shadow-brand/30 hover:scale-105 active:scale-95 transition-all">
                提交
            </button>
            <button type="reset" class="px-12 py-4 bg-gray-100 text-gray-500 hover:text-gray-700 hover:bg-gray-200 rounded-2xl text-sm font-bold hover:scale-105 active:scale-95 transition-all">
                重置
            </button>
        </div>
    </form>
</div>

<partial name="_TinyMCE" model='new { Selector = "#editor", Height = 600 }' />

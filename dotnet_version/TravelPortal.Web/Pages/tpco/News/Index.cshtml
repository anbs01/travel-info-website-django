@page
@model TravelPortal.Web.Pages.tpco.News.IndexModel
@{
    ViewData["Title"] = "行业资讯";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]">
    <partial name="_AdminPageHeader" model='new { 
        Title = "行业资讯", 
        Subtitle = "Industry News & Information Management",
        Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z\"/></svg>",
        Tabs = new[] {
            new { Name = "资讯列表", Url = Url.Page("Index"), IsActive = true },
            new { Name = "发布资讯", Url = Url.Page("Create"), IsActive = false }
        }
    }' />

    <!-- 筛选栏 (GET form) -->
    <form method="get" id="filterForm" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white border-b border-gray-50">
        <div class="flex items-center space-x-3">
            <select asp-for="Category" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                <option value="">全部类别</option>
                @foreach (var cat in Model.NewsCategories)
                {
                    <option value="@cat.Name">@cat.Name</option>
                }
            </select>
            
            <div class="relative">
                <input type="text" asp-for="Keyword" placeholder="标题关键字" class="pl-4 pr-10 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs w-48 focus:ring-1 focus:ring-brand/20" />
                <button type="submit" class="absolute right-2 top-1.5 text-gray-400 hover:text-brand transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>
            
            <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:bg-brand/90 hover:scale-105 transition-all">查询</button>
        </div>
    </form>

    <!-- 操作按钮 + 数据列表 (POST form) -->
    <form method="post" id="batchForm">
        <partial name="_AdminTableToolbar" model='new { 
            TotalCount = Model.NewsList.Items.Count(),
            Buttons = new List<dynamic> {
                new { Id = "Sticky", Text = "置顶", Handler = "ToggleSticky", ActionType = "submit" },
                new { Id = "Edit", Text = "编辑", ActionType = "redirect", IsSingleSelectOnly = true },
                new { Id = "Delete", Text = "删除", Handler = "Delete", ActionType = "delete" }
            }
        }' />

        <!-- 数据列表 -->
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                <tr>
                    <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded text-brand border-gray-200" /></th>
                    <th class="px-6 py-4">资讯标题</th>
                    <th class="px-6 py-4">类别</th>
                    <th class="px-6 py-4">状态</th>
                    <th class="px-6 py-4">发布时间</th>
                    <th class="px-6 py-4 text-right">操作</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var item in Model.NewsList.Items)
                {
                    <tr class="hover:bg-gray-50/50 transition-colors group" data-url="@Url.Page("Edit", new { id = item.Id })">
                        <td class="px-8 py-4"><input type="checkbox" name="ids" value="@item.Id" class="rounded text-brand border-gray-200" /></td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <span class="font-bold text-gray-700 group-hover:text-brand transition-colors">@item.Title</span>
                                @if (item.IsSticky)
                                {
                                    <span class="px-1.5 py-0.5 bg-orange-50 text-orange-500 text-[10px] font-bold rounded border border-orange-100">置顶</span>
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4 text-gray-500 text-xs">@item.NewsCategory</td>
                        <td class="px-6 py-4">
                            @if (item.IsHidden)
                            {
                                <span class="flex items-center gap-1.5 text-gray-400 text-xs">
                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-300"></span>
                                    已隐藏
                                </span>
                            }
                            else
                            {
                                <span class="flex items-center gap-1.5 text-green-500 text-xs font-medium">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                    正常
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 text-gray-400 text-xs font-mono">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="px-6 py-4 text-right">
                            <a href="@Url.Page("Edit", new { id = item.Id })" class="text-brand hover:underline font-bold text-xs">编辑</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 分页 -->
    <div class="p-6 bg-white border-t border-gray-100 flex items-center justify-between">
        <div class="text-xs text-gray-400">
            共 <span class="font-bold text-gray-600">@Model.NewsList.Metadata.TotalCount</span> 条记录
        </div>
        <div class="flex items-center gap-2">
            @if (Model.NewsList.Metadata.HasPreviousPage)
            {
                <a href="?PageIndex=@(Model.PageIndex - 1)&Keyword=@Model.Keyword&Category=@Model.Category" class="p-2 border border-gray-100 rounded-lg hover:bg-gray-50 transition-colors">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
            }
            <span class="px-4 py-1.5 bg-brand/5 text-brand rounded-lg text-xs font-bold border border-brand/10">@Model.PageIndex</span>
            @if (Model.NewsList.Metadata.HasNextPage)
            {
                <a href="?PageIndex=@(Model.PageIndex + 1)&Keyword=@Model.Keyword&Category=@Model.Category" class="p-2 border border-gray-100 rounded-lg hover:bg-gray-50 transition-colors">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
            }
        </div>
    </div>
    </form>
</div>

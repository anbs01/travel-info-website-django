    <script>
        $(document).ready(function() {
            // 封装：自动展开并激活当前菜单项
            function updateActiveMenu() {
                const currentFull = window.location.pathname + window.location.search;
                const currentPath = window.location.pathname;
                const params = new URLSearchParams(window.location.search);

                // 1. 清除所有旧的高亮和状态
                $('.menu-content a').removeClass('active bg-white/15');
                $('.menu-trigger').removeClass('active');
                
                let matchedLink = null;
                const $menuLinks = $('.menu-content a');

                // 2. 匹配逻辑
                $menuLinks.each(function() {
                    const href = $(this).attr('href');
                    if (href === currentFull) {
                        matchedLink = $(this);
                        return false;
                    }
                });

                if (!matchedLink) {
                    $menuLinks.each(function() {
                        const href = $(this).attr('href').split('?')[0];
                        if (href === currentPath) {
                            matchedLink = $(this);
                            return false;
                        }
                    });
                }

                if (!matchedLink && currentPath.includes('/tpco/NotFound')) {
                    const moduleParam = params.get('module');
                    if (moduleParam) {
                        $menuLinks.each(function() {
                            if ($(this).text().trim().includes(moduleParam)) {
                                matchedLink = $(this);
                                return false;
                            }
                        });
                    }
                }

                // 3. 应用状态
                if (matchedLink) {
                    matchedLink.addClass('active bg-white/15');
                    const $content = matchedLink.closest('.menu-content');
                    if ($content.length) {
                        $content.addClass('show'); // 改用 show 类触发高度动画
                        const $trigger = $content.prev('.menu-trigger');
                        $trigger.addClass('active');
                        $trigger.children('svg').css('transform', 'rotate(180deg)');
                    }
                }
            }

            // Unpoly 全局配置：拦截所有后台链接实现局部加载
            up.link.config.followSelectors.push('a[href^="/tpco"]');
            up.link.config.target = 'main';
            
            // 初始运行
            updateActiveMenu();

            // 监听 Unpoly 导航事件
            // --- 全局字数统计功能 ---
            function initCharCounter() {
                $('input[maxlength], textarea[maxlength]').each(function() {
                    const $input = $(this);
                    if ($input.next('.char-counter').length) return; // 避免重复初始化

                    const max = $input.attr('maxlength');
                    const $counter = $(`<div class="char-counter text-[10px] text-gray-400 text-right mt-1 font-mono">0 / ${max}</div>`);
                    $input.after($counter);

                    const update = () => {
                        const len = $input.val().length;
                        $counter.text(`${len} / ${max}`);
                        if (len >= max) {
                            $counter.removeClass('text-gray-400').addClass('text-red-500 font-bold');
                        } else if (len > max * 0.9) {
                            $counter.removeClass('text-gray-400 text-red-500').addClass('text-orange-400');
                        } else {
                            $counter.removeClass('text-red-500 text-orange-400 font-bold').addClass('text-gray-400');
                        }
                    };

                    $input.on('input focus', update);
                    update(); // 初始化显示
                });
            }

            initCharCounter();
            // 使用 fragment:inserted 确保在新内容插入 DOM 后立即运行
            up.on('up:fragment:inserted', function() {
                initCharCounter();
                updateActiveMenu(); // 顺便确保菜单高亮也在这里更新
            });
        });

        function toggleMenu(button) {
            const $btn = $(button);
            const $content = $btn.next('.menu-content');
            const $arrow = $btn.children('svg');
            const isOpening = !$content.hasClass('show');
            
            // 互斥逻辑：收起其他
            $('.menu-content').not($content).removeClass('show');
            $('.menu-trigger').not($btn).children('svg').css('transform', 'rotate(0deg)');

            // 切换当前
            $content.toggleClass('show');
            $arrow.css('transform', isOpening ? 'rotate(180deg)' : 'rotate(0deg)');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

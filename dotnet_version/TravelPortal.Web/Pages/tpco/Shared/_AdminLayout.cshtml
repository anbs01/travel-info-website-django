    <style>
        body { font-family: 'Microsoft YaHei', '微软雅黑', sans-serif; }
        .custom-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .custom-scrollbar::-webkit-scrollbar { display: none; }
        .menu-trigger { position: relative; z-index: 10; height: 48px; padding-left: 15px !important; font-size: 14px; border-radius: 0; }
        .menu-trigger .icon-circle { 
            width: 32px; height: 32px; background: #ffffff; border-radius: 50%; 
            display: flex; align-items: center; justify-content: center; margin-right: 12px;
        }
        .menu-trigger .icon-circle svg { color: #B97348 !important; width: 18px; height: 18px; }
        .menu-trigger.active { background-color: #B97348 !important; color: #ffffff !important; }
        /* 手风琴动效 */
        .menu-content { 
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows 0.3s ease-out;
            overflow: hidden;
        }
        .menu-content.show { 
            grid-template-rows: 1fr;
        }
        .menu-content > div {
            min-height: 0;
        }
        .menu-content a { font-size: 13px; line-height: 40px; padding-left: 60px !important; display: block; color: white; transition: all 0.2s; }
        .menu-content a.active { background-color: rgba(255, 255, 255, 0.15); color: #ffffff !important; }
    </style>

    <script>
        $(document).ready(function() {
            // 封装：自动展开并激活当前菜单项
            function updateActiveMenu() {
                const currentFull = window.location.pathname + window.location.search;
                const currentPath = window.location.pathname;
                const params = new URLSearchParams(window.location.search);

                // 1. 清除所有旧的高亮和状态
                $('.menu-content a').removeClass('active bg-white/15');
                $('.menu-trigger').removeClass('active');
                
                let matchedLink = null;
                const $menuLinks = $('.menu-content a');

                // 2. 匹配逻辑
                $menuLinks.each(function() {
                    const href = $(this).attr('href');
                    if (href === currentFull) {
                        matchedLink = $(this);
                        return false;
                    }
                });

                if (!matchedLink) {
                    $menuLinks.each(function() {
                        const href = $(this).attr('href').split('?')[0];
                        if (href === currentPath) {
                            matchedLink = $(this);
                            return false;
                        }
                    });
                }

                if (!matchedLink && currentPath.includes('/tpco/NotFound')) {
                    const moduleParam = params.get('module');
                    if (moduleParam) {
                        $menuLinks.each(function() {
                            if ($(this).text().trim().includes(moduleParam)) {
                                matchedLink = $(this);
                                return false;
                            }
                        });
                    }
                }

                // 3. 应用状态
                if (matchedLink) {
                    matchedLink.addClass('active bg-white/15');
                    const $content = matchedLink.closest('.menu-content');
                    if ($content.length) {
                        $content.addClass('show'); // 改用 show 类触发高度动画
                        const $trigger = $content.prev('.menu-trigger');
                        $trigger.addClass('active');
                        $trigger.children('svg').css('transform', 'rotate(180deg)');
                    }
                }
            }

            // Unpoly 全局配置：拦截所有后台链接实现局部加载
            up.link.config.followSelectors.push('a[href^="/tpco"]');
            up.link.config.target = 'main';
            
            // 初始运行
            updateActiveMenu();

            // 监听 Unpoly 导航事件
            up.on('up:location:changed', function() {
                updateActiveMenu();
            });
        });

        function toggleMenu(button) {
            const $btn = $(button);
            const $content = $btn.next('.menu-content');
            const $arrow = $btn.children('svg');
            const isOpening = !$content.hasClass('show');
            
            // 互斥逻辑：收起其他
            $('.menu-content').not($content).removeClass('show');
            $('.menu-trigger').not($btn).children('svg').css('transform', 'rotate(0deg)');

            // 切换当前
            $content.toggleClass('show');
            $arrow.css('transform', isOpening ? 'rotate(180deg)' : 'rotate(0deg)');
        }
    </script>

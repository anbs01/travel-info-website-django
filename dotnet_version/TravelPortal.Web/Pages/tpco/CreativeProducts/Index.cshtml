@page
@model TravelPortal.Web.Pages.tpco.CreativeProducts.IndexModel
@{
    ViewData["Title"] = "文创商品管理";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]"
     x-data="{ selectedIds: [] }">
<partial name="_AdminPageHeader" model='new { 
    Title = "文创商品管理", 
    Subtitle = "Cultural & Creative Product Management",
    Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z\"></path></svg>",
    Tabs = new[] {
        new { Name = "产品列表", Url = Url.Page("Index"), IsActive = true },
        new { Name = "发布产品", Url = Url.Page("Create"), IsActive = false }
    }
}' />

    <!-- 筛选栏 (GET form) -->
    <form method="get" id="filterForm" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white border-b border-gray-50">
        <div class="flex items-center space-x-3">
            <select asp-for="Category" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                <option value="">全部类别</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat">@cat</option>
                }
            </select>

            <div class="relative">
                <input type="text" asp-for="Search" placeholder="产品名称关键字" class="pl-4 pr-10 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs w-48 focus:ring-1 focus:ring-brand/20" />
                <button type="submit" class="absolute right-2 top-1.5 text-gray-400 hover:text-brand transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>

            <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 transition-all">搜索</button>
        </div>
    </form>

    <!-- 操作按钮 + 数据列表 (POST form) -->
    <form method="post" id="batchForm">
        <partial name="_AdminTableToolbar" model='new { 
            TotalCount = Model.Products.Items.Count(),
            Buttons = new List<dynamic> {
                new { Id = "Sticky", Text = "置顶", Handler = "ToggleSticky", ActionType = "submit" },
                new { Id = "Hide", Text = "屏蔽", Handler = "ToggleHidden", ActionType = "submit" },
                new { Id = "Edit", Text = "编辑", ActionType = "redirect", IsSingleSelectOnly = true },
                new { Id = "Delete", Text = "删除", Handler = "Delete", ActionType = "delete" }
            }
        }' />

        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" class="rounded text-brand border-gray-200" /></th>
                        <th class="px-6 py-4">产品名称</th>
                        <th class="px-6 py-4 w-28">类别</th>
                        <th class="px-6 py-4 w-28">非遗级别</th>
                        <th class="px-6 py-4 w-20 text-center">浏览</th>
                        <th class="px-8 py-4 w-40 text-center">添加日期</th>
                        <th class="px-6 py-4">排序</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.Products.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group cursor-pointer"
                            :class="selectedIds.includes('@item.Id') ? 'bg-brand/5' : ''"
                            data-url="@Url.Page("./Edit", new { id = item.Id })"
                            @@click="if($event.target.type !== 'checkbox' && $event.target.tagName !== 'A') { 
                                if(selectedIds.includes('@item.Id')) { selectedIds = selectedIds.filter(id => id !== '@item.Id') }
                                else { selectedIds.push('@item.Id') }
                            }">
                            <td class="px-8 py-4">
                                <input type="checkbox" name="ids" value="@item.Id" x-model="selectedIds"
                                       class="rounded text-brand border-gray-200 focus:ring-brand" 
                                       @@click.stop />
                            </td>
                            <td class="px-6 py-4">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="flex items-center space-x-2 group/title">
                                    <span class="text-gray-700 font-medium group-hover/title:text-brand transition-colors">@item.Title</span>
                                    @if (item.IsSticky) { <span class="px-1.5 py-0.5 bg-orange-50 text-orange-500 text-[10px] font-bold rounded border border-orange-100">置顶</span> }
                                    @if (item.IsHidden) { <span class="px-1.5 py-0.5 bg-gray-50 text-[10px] text-gray-400 font-bold rounded border border-gray-200">已屏蔽</span> }
                                    <svg class="w-3 h-3 text-gray-300 opacity-0 group-hover/title:opacity-100 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                </a>
                            </td>
                            <td class="px-6 py-4 text-xs text-gray-500">@item.Classification</td>
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(item.NonLegacyLevel))
                                {
                                    <span class="px-2 py-0.5 bg-brand/5 text-brand text-[10px] font-bold rounded border border-brand/10">@item.NonLegacyLevel</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center text-gray-400 font-mono text-xs">@item.Views</td>
                            <td class="px-8 py-4 text-center text-xs text-gray-400 font-mono">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="px-6 py-4">
                                <span class="text-gray-400 text-xs font-mono">@item.SortOrder</span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Products.Items.Any())
                    {
                        <tr><td colspan="8" class="px-8 py-16 text-center text-gray-400 text-sm">暂无数据</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model.Products.Metadata" />
    </form>
</div>

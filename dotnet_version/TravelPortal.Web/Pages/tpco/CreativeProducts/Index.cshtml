@page
@model TravelPortal.Web.Pages.tpco.CreativeProducts.IndexModel
@{
    ViewData["Title"] = "文创商品管理";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]"
     x-data="{ 
        selectedIds: [], 
        toggleAll(checked) {
            this.selectedIds = checked ? Array.from(document.querySelectorAll('input[name=ids]')).map(el => el.value) : [];
        }
     }">
<partial name="_AdminPageHeader" model='new { 
    Tabs = new[] {
        new { Name = "好物文创", Url = Url.Page("Index"), IsActive = true },
        new { Name = "发布产品", Url = Url.Page("Create"), IsActive = false }
    }
}' />

    <!-- 筛选栏 (GET form) -->
    <form method="get" id="filterForm" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white border-b border-gray-50">
        <div class="flex items-center space-x-3">
            <select asp-for="Category" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                <option value="">全部类别</option>
                @foreach (var cat in Model.Categories)
                {
                        <option value="@cat">@cat</option>
                }
            </select>

            <div class="relative">
                <input type="text" asp-for="Search" placeholder="产品名称关键字" class="pl-4 pr-10 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs w-48 focus:ring-1 focus:ring-brand/20" />
                <button type="submit" class="absolute right-2 top-1.5 text-gray-400 hover:text-brand transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>

            <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 transition-all">搜索</button>
        </div>
    </form>

    <!-- 操作按钮 + 数据列表 (POST form) -->
    <form method="post" id="batchForm">
        <div class="px-8 py-4 flex items-center justify-between bg-white border-b border-gray-100">
            <div class="flex items-center gap-3">
                <button type="button" 
                        @@click="if(selectedIds.length > 0) confirmAndPost('警告：确定要批量删除已选中的产品吗？操作不可恢复！', 'Delete', selectedIds.join(','))"
                        class="bg-brand text-white border-brand/80 px-4 py-1.5 rounded-sm border-b-2 text-xs font-bold tracking-widest transition-all flex items-center gap-2"
                        :class="selectedIds.length > 0 ? 'opacity-100 hover:bg-brand/90 active:translate-y-[1px] active:border-b-0' : 'opacity-50 cursor-not-allowed'">
                    <span>批量删除</span>
                </button>
            </div>

            <div class="text-[10px] text-gray-400 font-medium bg-gray-50 px-3 py-1 rounded-full border border-gray-100">
                已选 <span class="text-brand font-bold font-mono" x-text="selectedIds.length">0</span> / @Model.Products.Items.Count()
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12">
                            <input type="checkbox" @@change="toggleAll($el.checked)" :checked="selectedIds.length > 0 && selectedIds.length === document.querySelectorAll('input[name=ids]').length" class="rounded text-brand border-gray-200" />
                        </th>
                        <th class="px-6 py-4">产品名称</th>
                        <th class="px-6 py-4 w-28">类别</th>
                        <th class="px-6 py-4 w-28">非遗级别</th>
                        <th class="px-6 py-4 w-20 text-center">浏览</th>
                        <th class="px-8 py-4 w-56 text-center">添加时间</th>
                        <th class="px-6 py-4 w-20">排序</th>
                        <th class="px-6 py-4 text-center w-32">操作</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.Products.Items)
                    {
                            <tr class="hover:bg-gray-50/50 transition-colors group"
                                :class="selectedIds.includes('@item.Id') ? 'bg-brand/5' : ''">
                                <td class="px-8 py-4">
                                    <input type="checkbox" name="ids" value="@item.Id" x-model="selectedIds"
                                           class="rounded text-brand border-gray-200 focus:ring-brand" />
                                </td>
                                <td class="px-6 py-4">
                                @if (item.IsHidden)
                                {
                                            <div class="flex items-center space-x-2 opacity-40 cursor-not-allowed" title="已屏蔽的内容无法预览">
                                                <span class="text-gray-700 font-medium">@item.Title</span>
                                                <span class="text-[10px] px-1.5 py-0.5 bg-gray-100 text-gray-400 rounded">已屏蔽</span>
                                            </div>
                                }
                                else
                                {
                                            <a href="/Goods/Details/@item.Id" target="_blank" class="flex items-center space-x-2 group/title">
                                                <span class="text-gray-700 font-medium group-hover/title:text-brand transition-colors">@item.Title</span>
                                                <svg class="w-3 h-3 text-gray-300 opacity-0 group-hover/title:opacity-100 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                            </a>
                                }
                                </td>
                                <td class="px-6 py-4 text-xs text-gray-500">@item.Classification</td>
                                <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(item.NonLegacyLevel))
                                {
                                            <span class="px-2 py-0.5 bg-brand/5 text-brand text-[10px] font-bold rounded border border-brand/10">@item.NonLegacyLevel</span>
                                }
                                </td>
                                <td class="px-6 py-4 text-center text-gray-400 font-mono text-xs">@item.Views</td>
                                <td class="px-8 py-4 text-center text-xs text-gray-400 font-mono whitespace-nowrap">
                                @item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-gray-400 text-xs font-mono">@item.SortOrder</span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex items-center justify-center space-x-2">
                                    @* 置顶按钮 *@
                                        <button type="button" 
                                                onclick="confirmAndPost('确定要@(item.IsSticky ? "取消置顶" : "设置置顶")该产品吗？', 'ToggleSticky', '@item.Id')"
                                                class="p-1.5 rounded-lg transition-colors @(item.IsSticky ? "text-yellow-500 bg-yellow-50" : "text-gray-300 hover:bg-gray-50 hover:text-yellow-500")" 
                                                title="@(item.IsSticky ? "取消置顶" : "置顶")">
                                            <svg class="w-5 h-5" fill="@(item.IsSticky ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.783-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                                        </button>

                                    @* 屏蔽按钮 *@
                                        <button type="button" 
                                                onclick="confirmAndPost('确定要@(item.IsHidden ? "取消屏蔽" : "屏蔽")该产品吗？', 'ToggleHidden', '@item.Id')"
                                                class="p-1.5 rounded-lg transition-colors @(item.IsHidden ? "text-gray-400 bg-gray-50" : "text-blue-500 bg-blue-50 hover:text-blue-600")" 
                                                title="@(item.IsHidden ? "取消屏蔽" : "屏蔽")">
                                        @if (item.IsHidden)
                                        {
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path></svg>
                                        }
                                        else
                                        {
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                        }
                                        </button>

                                    @* 编辑按钮 *@
                                        <a asp-page="./Edit" asp-route-id="@item.Id" 
                                           class="p-1.5 text-brand hover:bg-brand/10 rounded-lg transition-colors" 
                                           title="编辑">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                        </a>

                                    @* 删除按钮 *@
                                        <button type="button" 
                                                onclick="confirmAndPost('警告：确定要彻底删除该产品吗？操作不可恢复！', 'Delete', '@item.Id')"
                                                class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg transition-colors" 
                                                title="删除">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                    }
                    @if (!Model.Products.Items.Any())
                    {
                            <tr><td colspan="8" class="px-8 py-16 text-center text-gray-400 text-sm">暂无数据</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model.Products.Metadata" />
    </form>
</div>


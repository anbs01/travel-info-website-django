@page
@model TravelPortal.Web.Pages.tpco.Foods.CreateModel
@{
    ViewData["Title"] = "发布特色美食";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]" x-data="foodForm()">
    <partial name="_AdminPageHeader" model='new { 
        Tabs = new[] {
            new { Name = "美食列表", Url = Url.Page("Index"), IsActive = false },
            new { Name = "发布产品", Url = Url.Page("Create"), IsActive = true }
        }
    }' />

    <form method="post" enctype="multipart/form-data" class="p-8 space-y-10">
        <!-- Basic Info Section -->
        <div class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">产品名称 <span class="text-red-400">*</span></label>
                <div class="flex-1">
                    <input type="text" asp-for="Food.Title" required maxlength="60"
                           class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">选择类别 <span class="text-red-400">*</span></label>
                <div class="flex-1">
                    <div class="flex items-center space-x-8 p-4 bg-gray-50 rounded-xl border border-gray-100">
                        @foreach (var cat in new[] { "美食", "特产" })
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Food.ProductType" value="@cat" x-model="category"
                                       class="w-5 h-5 text-brand border-gray-300 focus:ring-brand transition-all">
                                <span class="text-sm font-medium text-gray-600 group-hover:text-brand transition-colors">@cat</span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <!-- 美食菜系 (仅美食) -->
            <div x-show="category === '美食'" x-cloak x-transition class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">美食菜系</label>
                <div class="flex-1">
                    <div class="flex flex-wrap gap-4 p-4 bg-blue-50/30 rounded-xl border border-blue-100">
                        @foreach (var cat in Model.CuisineCategories)
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Food.Classification" value="@cat"
                                       class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500">
                                <span class="text-sm text-gray-600 group-hover:text-blue-600">@cat</span>
                            </label>
                        }
                        @if (!Model.CuisineCategories.Any())
                        {
                            <span class="text-xs text-gray-400 italic">请在“综合管理”中添加“美食菜系”热词</span>
                        }
                    </div>
                </div>
            </div>

            <!-- 特产分类 (仅特产) -->
            <div x-show="category === '特产'" x-cloak x-transition class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">特产分类</label>
                <div class="flex-1">
                    <div class="flex flex-wrap gap-4 p-4 bg-orange-50/30 rounded-xl border border-orange-100">
                        @foreach (var cat in Model.SpecialtyCategories)
                        {
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" asp-for="Food.Classification" value="@cat"
                                       class="w-4 h-4 text-orange-600 border-gray-300 focus:ring-orange-500">
                                <span class="text-sm text-gray-600 group-hover:text-orange-600">@cat</span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <!-- 特产级别 (仅特产) -->
            <div x-show="category === '特产'" x-cloak x-transition class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">特产级别</label>
                <div class="flex-1">
                    <div class="flex flex-wrap gap-3">
                        @foreach (var level in new[] { "无公害产品", "绿色产品", "有机产品", "地理标志产品" })
                        {
                            <label class="relative flex items-center group cursor-pointer">
                                <input type="radio" asp-for="Food.SpecialtyLevel" value="@level" class="peer sr-only">
                                <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-orange-50 peer-checked:border-orange-600 peer-checked:text-orange-700 transition-all group-hover:border-orange-300">
                                    @level
                                </div>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <!-- 非遗级别 -->
            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">非遗级别</label>
                <div class="flex-1">
                    <div class="flex flex-wrap gap-3">
                        @foreach (var level in new[] { "国家级非遗", "省级非遗", "市级非遗", "县级非遗" })
                        {
                            <label class="relative flex items-center group cursor-pointer">
                                <input type="radio" asp-for="Food.NonLegacyLevel" value="@level" class="peer sr-only">
                                <div class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 peer-checked:bg-brand peer-checked:border-indigo-600 peer-checked:text-brand transition-all group-hover:border-indigo-300">
                                    @level
                                </div>
                            </label>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">焦点图</label>
                <div class="flex-1">
                    <div class="relative w-full max-w-sm aspect-[4/3] rounded-2xl overflow-hidden bg-gray-50 border-2 border-dashed border-gray-200 group hover:border-brand transition-all cursor-pointer"
                         @@click="$refs.fileInput.click()">
                        <template x-if="imageUrl">
                            <img :src="imageUrl" class="w-full h-full object-cover" />
                        </template>
                        <template x-if="!imageUrl">
                            <div class="absolute inset-0 flex flex-col items-center justify-center text-gray-400">
                                <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
                                <span class="text-xs font-medium">上传封面图</span>
                            </div>
                        </template>
                        <input type="file" x-ref="fileInput" name="MainImageFile" class="hidden" @@change="previewImage" accept="image/*">
                    </div>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">口味特色 <span class="text-red-400">*</span></label>
                <div class="flex-1">
                    <textarea asp-for="Food.Summary" rows="6" maxlength="120" x-ref="tasteText"
                              class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium" required></textarea>
                </div>
            </div>
        </div>

        <!-- Content Section -->
        <div class="flex flex-col md:flex-row md:items-start gap-4 border-b border-gray-50 pb-4 pt-1">
            <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0 pt-2">详细介绍 <span class="text-red-400">*</span></label>
            <div class="flex-1 rounded-xl overflow-hidden border border-gray-100">
                <textarea id="editor" asp-for="Food.Content"></textarea>
            </div>
        </div>
        <partial name="_TinyMCE" model='new { Selector = "#editor", Height = 600 }' />

        <!-- Extra Info Section -->
        <div class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">选择地区 <span class="text-red-400">*</span></label>
                <div class="flex-1">
                    <partial name="_GeoPicker" model='new { FieldName = "Food.GeoId", CurrentId = (int?)null, CurrentName = (string?)null }' />
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">文章作者</label>
                <div class="flex-1">
                    <input type="text" asp-for="Food.Author" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">文章来源</label>
                <div class="flex-1">
                    <input type="text" asp-for="Food.Source" class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">原文链接</label>
                <div class="flex-1">
                    <input type="url" asp-for="Food.OriginUrl"
                           class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">跳转链接</label>
                <div class="flex-1">
                    <input type="url" asp-for="Food.RedirectUrl"
                           class="w-full px-4 py-3 bg-gray-50 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-brand/20 focus:border-brand transition-all text-sm font-medium">
                </div>
            </div>
        </div>

        <!-- Settings Section -->
        <div class="space-y-6">
            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <div class="w-32 shrink-0">
                    <div class="text-xs font-bold text-gray-700">图片水印</div>
                    <div class="text-[10px] text-gray-400">正文图片是否带水印</div>
                </div>
                <div class="flex-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="Food.ShowWatermark" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                    </label>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">水印位置</label>
                <div class="flex-1">
                    <div class="flex items-center gap-4 bg-gray-50 px-4 py-3 rounded-xl border border-gray-100 max-w-md">
                        @foreach (var pos in new[] { (v:"Center", n:"中正"), (v:"Bottom", n:"中下"), (v:"BottomRight", n:"右下") })
                        {
                            <label class="flex items-center gap-1.5 cursor-pointer">
                                <input type="radio" asp-for="Food.WatermarkPos" value="@pos.v" class="w-4 h-4 text-brand border-gray-300 focus:ring-brand">
                                <span class="text-xs text-gray-500 font-medium">@pos.n</span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <div class="w-32 shrink-0">
                    <div class="text-xs font-bold text-gray-700">推荐到首页</div>
                    <div class="text-[10px] text-gray-400">是否在首页展示</div>
                </div>
                <div class="flex-1">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="Food.IsHome" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand"></div>
                    </label>
                </div>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-gray-50 pb-4">
                <label class="w-32 text-xs font-bold text-gray-500 uppercase tracking-widest shrink-0">排序</label>
                <div class="flex-1 flex items-center gap-3">
                    <input type="number" asp-for="Food.SortOrder" class="w-24 px-3 py-1.5 rounded-lg border-gray-200 focus:ring-brand focus:border-brand text-xs font-mono" />
                    <span class="text-[10px] text-gray-400">数字越小越靠前</span>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="pt-10 flex justify-end space-x-4">
            <button type="submit" class="px-12 py-4 bg-brand text-white rounded-2xl text-sm font-bold shadow-xl shadow-brand/30 hover:scale-105 active:scale-95 transition-all">
                提交
            </button>
            <button type="reset" class="px-12 py-4 bg-gray-100 text-gray-500 hover:text-gray-700 hover:bg-gray-200 rounded-2xl text-sm font-bold hover:scale-105 active:scale-95 transition-all">
                重置
            </button>
        </div>
    </form>
    
    <script>
        function foodForm() {
            return {
                category: '美食',
                imageUrl: '',
                previewImage(e) {
                    const file = e.target.files[0];
                    if (file) {
                        this.imageUrl = URL.createObjectURL(file);
                    }
                }
            }
        }
    </script>
</div>

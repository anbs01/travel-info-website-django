@page "{handler?}"
@{
    Layout = "Shared/_AdminLayout";
    ViewData["Title"] = "页面开发中";
    var moduleName = Request.Query["module"].ToString() ?? "当前功能";
}

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="mb-10">
        <!-- 404 大数字：加深颜色，移除重叠干扰 -->
        <h1 class="text-[140px] font-black text-gray-200 leading-none select-none tracking-tight">404</h1>
    </div>

    <h2 class="text-2xl font-bold text-gray-800 mb-2">【@moduleName】功能暂未开放</h2>
    <p class="text-gray-500 max-w-md mb-8">
        该功能模块目前处于系统维护或版本升级阶段，暂不对外提供访问。如需紧急操作，请联系系统管理员。
    </p>

    <div class="flex space-x-4">
        <a href="/tpco" class="px-8 py-3 bg-brand text-white rounded-xl text-sm font-bold shadow-xl shadow-brand/20 hover:-translate-y-0.5 transition-all">
            返回首页
        </a>
        <button onclick="history.back()" class="px-8 py-3 bg-white text-gray-600 border border-gray-200 rounded-xl text-sm font-bold hover:bg-gray-50 transition-all">
            返回上一页
        </button>
    </div>

    <!-- 底部装饰条 -->
    <div class="mt-16 flex justify-center gap-2 opacity-20">
        <div class="h-1.5 w-12 bg-gray-300 rounded-full"></div>
        <div class="h-1.5 w-6 bg-gray-300 rounded-full"></div>
        <div class="h-1.5 w-24 bg-gray-300 rounded-full"></div>
    </div>
</div>

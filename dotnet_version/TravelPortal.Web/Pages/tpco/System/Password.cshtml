@page
@model TravelPortal.Web.Pages.tpco.System.PasswordModel
@{
    ViewData["Title"] = "修改密码";
    Layout = "Shared/_AdminLayout";
}

<div class="max-w-2xl mx-auto" x-data="passwordForm()">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-800">安全设置</h1>
        <p class="text-gray-500 text-sm mt-1">请定期修改密码以保护账号安全。密码至少 8 位，包含大小写字母、数字。</p>
    </div>

    @* 全局成功提示 *@
    <div x-show="successMsg" x-transition x-cloak class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 rounded-r-xl text-green-700 flex items-center gap-3">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-medium" x-text="successMsg"></span>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-8 space-y-7">

            @* 原密码 *@
            <div class="space-y-1.5">
                <label class="block text-sm font-semibold text-gray-700">当前密码</label>
                <div class="relative">
                    <input x-bind:type="showOld ? 'text' : 'password'"
                           x-model="oldPassword"
                           x-on:blur="validateOld"
                           x-on:input="oldError = ''"
                           class="w-full px-4 py-3 pr-12 rounded-xl border transition-all outline-none"
                           x-bind:class="oldError ? 'border-red-400 ring-2 ring-red-100 bg-red-50' : 'border-gray-200 focus:border-brand focus:ring-2 focus:ring-brand/20'"
                           placeholder="请输入当前密码" />
                    <button type="button" x-on:click="showOld = !showOld"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                        <svg x-show="!showOld" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        <svg x-show="showOld" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                    </button>
                </div>
                <p x-show="oldError" x-cloak x-transition class="text-xs text-red-500 flex items-center gap-1 mt-1">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    <span x-text="oldError"></span>
                </p>
            </div>

            @* 新密码 *@
            <div class="space-y-1.5">
                <label class="block text-sm font-semibold text-gray-700">新密码</label>
                <div class="relative">
                    <input x-bind:type="showNew ? 'text' : 'password'"
                           x-model="newPassword"
                           x-on:input="calcStrength"
                           x-on:blur="validateNew"
                           class="w-full px-4 py-3 pr-12 rounded-xl border transition-all outline-none"
                           x-bind:class="newError ? 'border-red-400 ring-2 ring-red-100 bg-red-50' : 'border-gray-200 focus:border-brand focus:ring-2 focus:ring-brand/20'"
                           placeholder="至少 8 位，包含大小写字母和数字" />
                    <button type="button" x-on:click="showNew = !showNew"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                        <svg x-show="!showNew" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        <svg x-show="showNew" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                    </button>
                </div>

                @* 密码强度和规范提示 *@
                <div x-show="newPassword.length > 0" x-transition class="space-y-2 pt-1">
                    <div class="flex gap-1.5 h-1.5">
                        <div class="flex-1 rounded-full transition-all duration-300" x-bind:class="strength >= 1 ? strengthColor : 'bg-gray-200'"></div>
                        <div class="flex-1 rounded-full transition-all duration-300" x-bind:class="strength >= 2 ? strengthColor : 'bg-gray-200'"></div>
                        <div class="flex-1 rounded-full transition-all duration-300" x-bind:class="strength >= 3 ? strengthColor : 'bg-gray-200'"></div>
                        <div class="flex-1 rounded-full transition-all duration-300" x-bind:class="strength >= 4 ? strengthColor : 'bg-gray-200'"></div>
                    </div>
                    <p class="text-xs font-medium" x-bind:class="strengthTextColor" x-text="strengthLabel"></p>
                    
                    <div class="grid grid-cols-2 gap-x-4 gap-y-1.5">
                        <template x-for="(val, key) in ruleConfig" :key="key">
                            <div class="flex items-center gap-1.5 text-[11px]" x-bind:class="rules[key] ? 'text-green-600' : 'text-gray-400'">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path x-show="rules[key]" stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                    <circle x-show="!rules[key]" cx="12" cy="12" r="9" stroke-width="2"></circle>
                                </svg>
                                <span x-text="val"></span>
                            </div>
                        </template>
                    </div>
                </div>

                <p x-show="newError" x-cloak x-transition class="text-xs text-red-500 flex items-center gap-1 mt-1">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    <span x-text="newError"></span>
                </p>
            </div>

            @* 确认密码 *@
            <div class="space-y-1.5">
                <label class="block text-sm font-semibold text-gray-700">确认新密码</label>
                <div class="relative">
                    <input x-bind:type="showConfirm ? 'text' : 'password'"
                           x-model="confirmPassword"
                           x-on:input="checkConfirm"
                           x-on:blur="validateConfirm"
                           class="w-full px-4 py-3 pr-12 rounded-xl border transition-all outline-none"
                           x-bind:class="confirmError ? 'border-red-400 ring-2 ring-red-100 bg-red-50' : (confirmOk ? 'border-green-400 bg-green-50' : 'border-gray-200 focus:border-brand focus:ring-2 focus:ring-brand/20')"
                           placeholder="再次输入新密码" />
                    <button type="button" x-on:click="showConfirm = !showConfirm"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                        <svg x-show="!showConfirm" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        <svg x-show="showConfirm" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                    </button>
                </div>
                <p x-show="confirmOk" x-cloak x-transition class="text-xs text-green-600 flex items-center gap-1 mt-1 font-medium">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    两次密码输入一致
                </p>
                <p x-show="confirmError" x-cloak x-transition class="text-xs text-red-500 flex items-center gap-1 mt-1">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    确认密码与新密码不匹配
                </p>
            </div>
        </div>

        <div class="px-8 py-6 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
            <p class="text-xs text-gray-400">修改成功后当前 Session 保持，下次登录使用新密码。</p>
            <button type="button"
                    x-on:click="submitForm"
                    x-bind:disabled="submitting"
                    x-bind:class="submitting ? 'bg-gray-300 cursor-not-allowed' : 'bg-brand hover:bg-brand/90 shadow-lg shadow-brand/20 cursor-pointer'"
                    class="text-white px-8 py-3 rounded-xl font-bold transition-all flex items-center gap-2">
                <svg x-show="submitting" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                <span x-text="submitting ? '提交中...' : '更新密码'"></span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function passwordForm() {
        return {
            showOld: false, showNew: false, showConfirm: false,
            oldPassword: '', newPassword: '', confirmPassword: '',
            oldError: '', newError: '', confirmError: '', confirmOk: false,
            successMsg: '', submitting: false,
            strength: 0, strengthLabel: '', strengthColor: 'bg-gray-300', strengthTextColor: 'text-gray-400',
            rules: { length: false, upper: false, lower: false, number: false },
            ruleConfig: { length: '至少 8 个字符', upper: '大写字母', lower: '小写字母', number: '数字' },

            // 1. 实时原密码校验
            validateOld() {
                if (!this.oldPassword) {
                    this.oldError = '请输入当前密码以验证身份';
                } else {
                    this.oldError = '';
                }
            },

            // 2. 实时新密码强度计算
            calcStrength() {
                const p = this.newPassword;
                this.rules.length = p.length >= 8;
                this.rules.upper  = /[A-Z]/.test(p);
                this.rules.lower  = /[a-z]/.test(p);
                this.rules.number = /[0-9]/.test(p);
                
                const score = Object.values(this.rules).filter(Boolean).length;
                this.strength = score;
                
                const levels = [
                    { label: '强度：弱',   color: 'bg-red-400',    text: 'text-red-400' },
                    { label: '强度：一般', color: 'bg-orange-400', text: 'text-orange-400' },
                    { label: '强度：良好', color: 'bg-yellow-400', text: 'text-yellow-400' },
                    { label: '强度：强',   color: 'bg-green-500',  text: 'text-green-500' },
                ];
                const lv = levels[score - 1] || { label: '强度：太弱', color: 'bg-gray-300', text: 'text-gray-400' };
                this.strengthLabel = lv.label;
                this.strengthColor = lv.color;
                this.strengthTextColor = lv.text;
                
                if (score === 4) this.newError = '';
                this.checkConfirm();
            },

            validateNew() {
                if (!this.newPassword) {
                    this.newError = '新密码不能为空';
                } else if (this.strength < 4) {
                    this.newError = '请确保满足所有密码复杂度要求';
                } else {
                    this.newError = '';
                }
            },

            // 3. 实时一致性校验
            checkConfirm() {
                if (!this.confirmPassword) {
                    this.confirmOk = false;
                    return;
                }
                this.confirmOk = (this.confirmPassword === this.newPassword);
                if (this.confirmOk) this.confirmError = '';
            },

            validateConfirm() {
                if (!this.confirmPassword) {
                    this.confirmError = '请再次输入新密码进行确认';
                    this.confirmOk = false;
                } else if (!this.confirmOk) {
                    this.confirmError = '确认密码与新密码不匹配';
                } else {
                    this.confirmError = '';
                }
            },

            // 4. 表单提交（永远可点击，点击时做最终汇总校验）
            async submitForm() {
                // 触发所有实时校验
                this.validateOld();
                this.validateNew();
                this.validateConfirm();

                // 如果有任何红色错误，阻断提交
                if (this.oldError || this.newError || this.confirmError) {
                    // 平滑滚动到第一个错误（可选）
                    return;
                }

                if (this.submitting) return;

                this.successMsg = '';
                this.submitting = true;

                try {
                    const res = await fetch('/tpco/System/Password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            oldPassword: this.oldPassword,
                            newPassword: this.newPassword,
                            confirmPassword: this.confirmPassword
                        })
                    });

                    const data = await res.json();

                    if (data.ok) {
                        this.successMsg = data.msg;
                        // 重置表单
                        this.oldPassword = ''; this.newPassword = ''; this.confirmPassword = '';
                        this.strength = 0; this.confirmOk = false;
                        this.rules = { length: false, upper: false, lower: false, number: false };
                    } else {
                        if (data.field === 'old') this.oldError = data.msg;
                        else if (data.field === 'new') this.newError = data.msg;
                        else if (data.field === 'confirm') this.confirmError = data.msg;
                    }
                } catch (e) {
                    this.oldError = '服务请求失败，请检查网络。';
                } finally {
                    this.submitting = false;
                }
            }
        };
    }
</script>
<style> [x-cloak] { display: none !important; } </style>
}

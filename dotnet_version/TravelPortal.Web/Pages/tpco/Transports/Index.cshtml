@page
@model TravelPortal.Web.Pages.tpco.Transports.IndexModel
@{
    ViewData["Title"] = "交通管理";
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden min-h-[calc(100vh-120px)]"
     x-data="{ 
        selectedIds: [], 
        toggleAll(checked) {
            this.selectedIds = checked ? Array.from(document.querySelectorAll('input[name=ids]')).map(el => el.value) : [];
        }
     }">
    <partial name="_AdminPageHeader" model='new { 
        Title = "交通设施管理", 
        Subtitle = "Transportation Facilities Management",
        Icon = "<svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4\"></path></svg>",
        Tabs = new[] {
            new { Name = "交通设施", Url = Url.Page("Index"), IsActive = true },
            new { Name = "发布交通点", Url = Url.Page("Create"), IsActive = false }
        }
    }' />

    <!-- 筛选栏 (GET form) -->
    <form method="get" id="filterForm" class="p-6 flex flex-wrap items-center justify-between gap-4 bg-white border-b border-gray-50">
        <div class="flex items-center space-x-3">
            <select asp-for="GeoId" asp-items="Model.GeoList" class="px-3 py-1.5 bg-gray-50 border-gray-100 rounded-lg text-xs focus:ring-1 focus:ring-brand/20">
                <option value="">全部城镇</option>
            </select>
            <button type="submit" class="px-6 py-1.5 bg-brand text-white rounded-lg text-xs font-bold shadow-lg shadow-brand/20 hover:scale-105 transition-all">筛选</button>
        </div>
    </form>

    <!-- 操作按钮 + 数据列表 (POST form) -->
    <form method="post" id="batchForm">
        <div class="px-8 py-4 flex items-center justify-between bg-white border-b border-gray-100">
            <div class="flex items-center gap-3">
                <button type="button" 
                        @@click="if(selectedIds.length > 0) confirmAndPost('警告：确定要批量删除已选中的交通点吗？操作不可恢复！', 'Delete', selectedIds.join(','))"
                        class="bg-brand text-white border-brand/80 px-4 py-1.5 rounded-sm border-b-2 text-xs font-bold tracking-widest transition-all flex items-center gap-2"
                        :class="selectedIds.length > 0 ? 'opacity-100 hover:bg-brand/90 active:translate-y-[1px] active:border-b-0' : 'opacity-50 cursor-not-allowed'">
                    <span>批量删除</span>
                </button>
            </div>

            <div class="text-[10px] text-gray-400 font-medium bg-gray-50 px-3 py-1 rounded-full border border-gray-100">
                已选 <span class="text-brand font-bold font-mono" x-text="selectedIds.length">0</span> / @Model.TransportList.Items.Count()
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50/50 text-gray-400 font-bold uppercase tracking-wider text-[10px]">
                    <tr>
                        <th class="px-8 py-4 w-12">
                            <input type="checkbox" @@change="toggleAll($el.checked)" :checked="selectedIds.length > 0 && selectedIds.length === document.querySelectorAll('input[name=ids]').length" class="rounded text-brand border-gray-200" />
                        </th>
                        <th class="px-6 py-4">名称</th>
                        <th class="px-6 py-4 w-48">城乡名称</th>
                        <th class="px-6 py-4 w-32">交通类型</th>
                        <th class="px-6 py-4 w-20 text-center">浏览</th>
                        <th class="px-8 py-4 w-48 text-center">添加时间</th>
                        <th class="px-6 py-4 w-20">排序</th>
                        <th class="px-8 py-4 text-center w-36">操作</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.TransportList.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group"
                            :class="selectedIds.includes('@item.Id') ? 'bg-brand/5' : ''">
                            <td class="px-8 py-4">
                                <input type="checkbox" name="ids" value="@item.Id" x-model="selectedIds"
                                       class="rounded text-brand border-gray-200 focus:ring-brand" />
                            </td>
                            <td class="px-6 py-4">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="flex items-center space-x-2 group/title">
                                    <span class="text-gray-700 font-medium group-hover/title:text-brand transition-colors">@item.Title</span>
                                    @if (item.IsHidden) 
                                    { 
                                        <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-50 text-red-600 border border-red-100">已屏蔽</span> 
                                    }
                                    <svg class="w-3 h-3 text-gray-300 opacity-0 group-hover/title:opacity-100 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                </a>
                            </td>
                            <td class="px-6 py-4 text-xs text-gray-500">
                                @(item.Geo?.GeoTag != null ? $"{item.Geo.GeoTag}{item.Geo.Title}" : item.Geo?.Title ?? "-")
                            </td>
                            <td class="px-6 py-4 text-xs">
                                <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-blue-50 text-blue-600 whitespace-nowrap">
                                    @GetTypeName(item.TransportType)
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center text-gray-400 font-mono text-xs">
                                @item.Views
                            </td>
                            <td class="px-8 py-4 text-center text-xs text-gray-400 font-mono whitespace-nowrap">
                                @item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-gray-400 text-xs font-mono">@item.SortOrder</span>
                            </td>
                            <td class="px-8 py-4 text-center">
                                <div class="flex items-center justify-center space-x-2">
                                    @* 屏蔽/取消屏蔽按钮 *@
                                    <button type="button" 
                                            onclick="confirmAndPost('确定要@(item.IsHidden ? "取消屏蔽" : "屏蔽")该交通点吗？', 'ToggleHidden', '@item.Id')"
                                            class="p-1.5 rounded-lg transition-colors @(item.IsHidden ? "text-gray-400 bg-gray-50" : "text-blue-500 bg-blue-50 hover:text-blue-600")" 
                                            title="@(item.IsHidden ? "取消屏蔽" : "屏蔽")">
                                        @if (item.IsHidden)
                                        {
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"></path></svg>
                                        }
                                        else
                                        {
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                        }
                                    </button>

                                    @* 编辑链接 *@
                                    <a asp-page="./Edit" asp-route-id="@item.Id" 
                                       class="p-1.5 text-brand hover:bg-brand/10 rounded-lg transition-colors" 
                                       title="编辑">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>

                                    @* 删除按钮 *@
                                    <button type="button" 
                                            onclick="confirmAndPost('警告：确定要彻底删除该交通点吗？操作不可恢复！', 'Delete', '@item.Id')"
                                            class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg transition-colors" 
                                            title="删除">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.TransportList.Items.Any())
                    {
                        <tr><td colspan="8" class="px-8 py-16 text-center text-gray-400 text-sm">暂无数据</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="Model.TransportList.Metadata" />
    </form>
</div>

@functions {
    string GetTypeName(string type) => type switch
    {
        "Airport" => "机场",
        "Railway" => "火车站",
        "Bus" => "汽车站",
        "Pier" => "水上交通",
        "Subway" => "轨道交通",
        "PublicBus" => "地面公交",
        _ => "其他"
    };
}

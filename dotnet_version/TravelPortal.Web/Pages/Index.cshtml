@page
@model IndexModel
@{
    ViewData["Title"] = "首页";
    var firstCarousel = Model.CarouselItems.FirstOrDefault();
}

<style>
    /* 首页响应式补丁 */
    @@media (max-width: 1199px) {
        .index-search-wrap { width: 95% !important; height: auto !important; flex-direction: column !important; gap: 10px; }
        .index-search-wrap > * { width: 100% !important; margin: 0 !important; }
        #categoryMenu { width: 100% !important; }
        
        .recommend-section .container-1200 > div { flex-direction: column !important; align-items: center; }
        .recommend-carousel { width: 100% !important; margin: 0 !important; }
        .recommend-carousel > div { width: 100% !important; height: auto !important; aspect-ratio: 484/324; }
        .recommend-list { margin: 20px 0 0 0 !important; width: 90% !important; }
    }
</style>

<div style="padding-bottom: 80px;">

    <!-- 1. 搜索区域 -->
    <div class="container-1200" style="margin-top: 50px;">
        <div style="display: flex; justify-content: center;">
            <div class="index-search-wrap" style="display: flex; height: 45px; width: 944px; align-items: center;">
                <input type="text" id="searchInput" style="width: 725px; height: 100%; border: 1px solid #ebe2cf; padding: 0 24px; outline: none; font-size: 12px; box-sizing: border-box; margin-right: 7px;" />
                <div style="width: 110px; height: 100%; border: 1px solid #ebe2cf; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; background: #fff; font-size: 12px; box-sizing: border-box; cursor: pointer; position: relative;" id="categoryDropdown">
                    <span id="categoryLabel">纪行 · 攻略</span>
                    <span style="font-size: 10px; color: #ccc;">▼</span>
                    <div id="categoryMenu" style="display:none; position:absolute; top:100%; left:-1px; right:-1px; background:#fff; border:1px solid #ebe2cf; border-top:none; z-index:10; font-size:12px;">
                        <div data-val="travelogue" data-label="纪行 · 攻略" style="padding:8px 16px; cursor:pointer;">纪行 · 攻略</div>
                        <div data-val="places" data-label="城乡 · 街巷" style="padding:8px 16px; cursor:pointer;">城乡 · 街巷</div>
                        <div data-val="foods" data-label="特产 · 美食" style="padding:8px 16px; cursor:pointer;">特产 · 美食</div>
                        <div data-val="goods" data-label="好物 · 文创" style="padding:8px 16px; cursor:pointer;">好物 · 文创</div>
                        <div data-val="news" data-label="资讯 · 动态" style="padding:8px 16px; cursor:pointer;">资讯 · 动态</div>
                    </div>
                </div>
                <div style="width: 6px;"></div>
                <button id="searchBtn" style="width: 96px; height: 100%; border: none; background: #b58c5e; color: #fff; font-weight: bold; font-size: 14px; cursor: pointer;">搜 索</button>
            </div>
        </div>

        <!-- 搜索热词 -->
        @if (Model.HomeKeywords.Any())
        {
            <div style="margin-top: 20px; padding: 0 30px; font-size: 12px; color: #666; line-height: 2.2;">
                <div style="display: flex; flex-wrap: wrap; gap: 0 28px;">
                    @foreach (var kw in Model.HomeKeywords)
                    {
                        <a href="/Travelogues?keyword=@Uri.EscapeDataString(kw)"
                           style="color: #666; text-decoration: none; white-space: nowrap;">@kw</a>
                    }
                </div>
            </div>
        }
    </div>

    <!-- 2. 推荐板块 -->
    <div class="recommend-section" style="background: #fbf7f1; margin-top: 50px; padding: 30px 0;">
        <div class="container-1200">
            <div style="display: flex;">

                <!-- 左侧轮播图 -->
                <div class="recommend-carousel" style="margin-left: 30px; width: 484px; flex-shrink: 0;">
                    @if (Model.CarouselItems.Any())
                    {
                        <div style="position: relative; width: 484px; height: 324px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                            @for (int i = 0; i < Model.CarouselItems.Count; i++)
                            {
                                var slide = Model.CarouselItems[i];
                                <div class="carousel-slide" style="position: absolute; inset: 0; opacity: @(i == 0 ? "1" : "0"); transition: opacity 0.6s ease;">
                                    <a href="@slide.LinkUrl" target="_blank" style="display: block; width: 100%; height: 100%;">
                                        <img src="@slide.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" alt="@slide.Title" />
                                    </a>
                                    <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 44px; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: space-between; padding: 0 14px; color: #fff; font-size: 12px;">
                                        <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 380px;">@slide.Title</span>
                                    </div>
                                </div>
                            }
                            <!-- 轮播指示点 -->
                            @if (Model.CarouselItems.Count > 1)
                            {
                                <div style="position: absolute; bottom: 12px; right: 14px; display: flex; gap: 6px;">
                                    @for (int i = 0; i < Model.CarouselItems.Count; i++)
                                    {
                                        <span class="carousel-dot" data-index="@i"
                                              style="width: 10px; height: 10px; border-radius: 50%; cursor: pointer; background: @(i == 0 ? "#b58c5e" : "rgba(255,255,255,0.5)");"></span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div style="width: 484px; height: 324px; background: #eee; display: flex; align-items: center; justify-content: center; color: #999; font-size: 12px;">
                            暂无推荐图片
                        </div>
                    }
                </div>

                <!-- 右侧列表 -->
                <div class="recommend-list" style="margin-left: 60px; flex: 1; padding-top: 4px;">
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        @foreach (var item in Model.ListItems)
                        {
                            <li style="display: flex; align-items: center; font-size: 12px; margin-bottom: @(item.SourceType == "推荐" ? "16px" : "13px"); position: relative;">
                                <span style="width: @(item.SourceType == "推荐" ? "8px" : "6px"); height: @(item.SourceType == "推荐" ? "8px" : "6px"); background: @(item.SourceType == "推荐" ? "#b58c5e" : "#ccc"); margin-right: 12px; border-radius: @(item.SourceType == "推荐" ? "2px" : "50%"); flex-shrink: 0;"></span>
                                <a href="@item.Url" target="_blank"
                                   title="@item.Title"
                                   style="color: @(item.SourceType == "推荐" ? "#000" : "#444"); font-weight: normal; text-decoration: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 360px; flex: 1;">@item.Title</a>

                                <span style="position: absolute; right: 0; color: #999; font-size: 11px; white-space: nowrap; pointer-events: none;">[@item.SourceType]</span>

                            </li>
                        }
                        @if (!Model.ListItems.Any())
                        {
                            <li style="font-size: 12px; color: #999; padding-top: 20px;">暂无推荐内容</li>
                        }
                    </ul>
                </div>

            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    // 搜索分类下拉
    var categoryVal = 'travelogue';
    var dropdown = document.getElementById('categoryDropdown');
    var menu = document.getElementById('categoryMenu');
    var label = document.getElementById('categoryLabel');

    dropdown.addEventListener('click', function(e) {
        menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        e.stopPropagation();
    });
    menu.querySelectorAll('[data-val]').forEach(function(item) {
        item.addEventListener('mouseenter', function() { this.style.background = '#f5f0e8'; });
        item.addEventListener('mouseleave', function() { this.style.background = ''; });
        item.addEventListener('click', function(e) {
            categoryVal = this.dataset.val;
            label.textContent = this.dataset.label;
            menu.style.display = 'none';
            e.stopPropagation();
        });
    });
    document.addEventListener('click', function() { menu.style.display = 'none'; });

    // 搜索跳转
    document.getElementById('searchBtn').addEventListener('click', function() {
        var kw = document.getElementById('searchInput').value.trim();
        var urlMap = {
            travelogue: '/Travelogues',
            places: '/Places',
            foods: '/Foods',
            goods: '/Goods',
            news: '/News'
        };
        var base = urlMap[categoryVal] || '/Travelogues';
        window.location.href = kw ? base + '?keyword=' + encodeURIComponent(kw) : base;
    });
    document.getElementById('searchInput').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') document.getElementById('searchBtn').click();
    });

    // 轮播逻辑
    var slides = document.querySelectorAll('.carousel-slide');
    var dots = document.querySelectorAll('.carousel-dot');
    var current = 0;

    function goTo(idx) {
        slides[current].style.opacity = '0';
        dots[current] && (dots[current].style.background = 'rgba(255,255,255,0.5)');
        current = idx;
        slides[current].style.opacity = '1';
        dots[current] && (dots[current].style.background = '#b58c5e');
    }

    if (slides.length > 1) {
        dots.forEach(function(dot, i) {
            dot.addEventListener('click', function() { goTo(i); });
        });
        setInterval(function() { goTo((current + 1) % slides.length); }, 4000);
    }
</script>
}

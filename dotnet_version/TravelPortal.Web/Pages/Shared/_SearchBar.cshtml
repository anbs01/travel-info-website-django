@*
    公共顶部搜索栏
    参数：
      CurrentModule - 当前栏目值（travelogue/foods/goods/news/scenic）
      Keyword       - 当前关键字
*@
@model dynamic
@{
    string currentModule = (string)(Model.CurrentModule ?? "travelogue");
    string keyword = (string)(Model.Keyword ?? "");
    var modules = new[]
    {
        (val: "travelogue", label: "纪行 · 攻略", url: "/Travelogues"),
        (val: "places",     label: "城乡 · 街巷", url: "/Places"),
        (val: "foods",      label: "特产 · 美食", url: "/Foods"),
        (val: "goods",      label: "好物 · 文创", url: "/Goods"),
        (val: "news",       label: "资讯 · 动态", url: "/News"),
    };
    var current = modules.FirstOrDefault(m => m.val == currentModule);
    string currentLabel = current.label ?? "纪行 · 攻略";
}

<style>
    @@media (max-width: 1199px) {
        #searchBarWrap { width: 100% !important; height: 45px !important; margin: 0 0 20px 0 !important; flex-direction: row !important; }
        #sbKeyword { padding: 0 10px !important; font-size: 14px !important; }
        #sbBtn { width: 60px !important; height: 45px !important; }
    }
</style>

<div style="display: flex; align-items: center; width: 274px; height: 28px; margin-left: auto; margin-right: 2px;" id="searchBarWrap">
    <input type="text" id="sbKeyword" value="@keyword" placeholder="输入关键字..."
           style="width: 220px; height: 28px; border: 1px solid #ddd; border-radius: 2px; outline: none; padding: 0 10px; font-size: 12px; background: #fff;" />
    
    <div style="width: 15px; flex-shrink: 0;"></div> @* 15px 间距 *@

    <button id="sbBtn" style="width: 39px; height: 28px; border: none; border-radius: 2px; background: #b58c5e; color: #fff; cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
    </button>
</div>

<script>
(function(){
    var selectedUrl = '@(current.url)';
    var btn = document.getElementById('sbBtn');
    var input = document.getElementById('sbKeyword');

    btn.addEventListener('click', function(){
        var kw = input.value.trim();
        window.location.href = kw ? selectedUrl + '?keyword=' + encodeURIComponent(kw) : selectedUrl;
    });

    input.addEventListener('keydown', function(e){
        if(e.key === 'Enter') btn.click();
    });
})();
</script>

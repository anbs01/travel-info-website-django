@*
    公共顶部搜索栏
    参数：
      CurrentModule - 当前栏目值（travelogue/foods/goods/news/scenic）
      Keyword       - 当前关键字
*@
@model dynamic
@{
    string currentModule = (string)(Model.CurrentModule ?? "travelogue");
    string keyword = (string)(Model.Keyword ?? "");
    var modules = new[]
    {
        (val: "travelogue", label: "纪行 · 攻略", url: "/Travelogues"),
        (val: "places",     label: "城乡 · 街巷", url: "/Places"),
        (val: "foods",      label: "特产 · 美食", url: "/Foods"),
        (val: "goods",      label: "好物 · 文创", url: "/Goods"),
        (val: "news",       label: "资讯 · 动态", url: "/News"),
    };
    var current = modules.FirstOrDefault(m => m.val == currentModule);
    string currentLabel = current.label ?? "纪行 · 攻略";
}

<style>
    @@media (max-width: 1199px) {
        #searchBarWrap { height: auto !important; flex-direction: column !important; border: none !important; }
        #searchBarWrap > * { width: 100% !important; border: 1px solid #ddd !important; margin-bottom: 5px; border-radius: 2px; }
        #sbKeyword { height: 45px !important; }
    }
</style>

<div style="display: flex; height: 45px; border: 1px solid #ddd; border-radius: 2px; overflow: hidden; position: relative;" id="searchBarWrap">
    <input type="text" id="sbKeyword" value="@keyword" placeholder="搜索本栏目内容..."
           style="flex: 1; border: none; outline: none; padding: 0 15px; font-size: 13px;" />
    <button id="sbBtn" style="width: 70px; height: 45px; border: none; border-left: 1px solid #ddd; background: #b58c5e; color: #fff; font-size: 14px; font-weight: bold; cursor: pointer; flex-shrink: 0;">搜索</button>
</div>

<script>
(function(){
    var selectedUrl = '@(current.url)';
    var btn = document.getElementById('sbBtn');
    var input = document.getElementById('sbKeyword');

    btn.addEventListener('click', function(){
        var kw = input.value.trim();
        window.location.href = kw ? selectedUrl + '?keyword=' + encodeURIComponent(kw) : selectedUrl;
    });
    
    input.addEventListener('keydown', function(e){
        if(e.key === 'Enter') btn.click();
    });
})();
</script>

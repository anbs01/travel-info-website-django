@*
    地区选择弹窗组件 (多级联动面板极简版)
    参数：
      FieldName   - 表单字段名，如 "Food.GeoId"
      CurrentId   - 当前已选 ID（int? 或 null）
      CurrentName - 当前已选名称（string 或 null）
*@
@model dynamic

@{
    string fieldName = (string)Model.FieldName;
    string alpineId = fieldName.Replace(".", "_").Replace("[", "_").Replace("]", "_");
    int? currentId = Model.CurrentId as int?;
    string currentName = (string)(Model.CurrentName ?? "");
}

<div x-data="geoPicker('@alpineId', @(currentId.HasValue ? currentId.Value.ToString() : "null"), '@Html.Raw(currentName.Replace("'", "\\'"))')"
     class="relative">

    <!-- 触发按钮 -->
    <button type="button" @@click="open = true"
            class="w-full flex items-center justify-between px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 hover:bg-white hover:border-brand focus:ring-2 focus:ring-brand/20 transition-all text-sm font-medium">
        <span :class="selectedName ? 'text-gray-800 font-bold' : 'text-gray-400'"
              x-text="selectedName || '点击选择地区...'"></span>
        <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform duration-200" :class="open ? 'rotate-180 text-brand' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
    </button>

    <!-- 隐藏 input，提交表单用 -->
    <input type="hidden" name="@fieldName" :value="selectedId ?? ''" />

    <!-- 弹窗遮罩 -->
    <div x-show="open"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4"
         @@click.self="open = false"
         style="display:none">

        <!-- 弹窗主体 -->
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-3xl max-h-[85vh] flex flex-col overflow-hidden transform transition-all"
             @@click.stop>

            <!-- 头部 Tab 与搜索 -->
            <div class="px-6 py-5 border-b border-gray-100 flex-shrink-0 space-y-4">
                <div class="flex items-center justify-between">
                    <div class="flex gap-1 bg-gray-100 rounded-xl p-1">
                        <button type="button" @@click="tab = 'domestic'"
                                :class="tab === 'domestic' ? 'bg-brand text-white shadow-sm' : 'text-gray-500 hover:text-gray-700'"
                                class="px-5 py-2 rounded-lg text-xs font-black tracking-wider transition-all">国内城乡</button>
                        <button type="button" @@click="tab = 'overseas'"
                                :class="tab === 'overseas' ? 'bg-brand text-white shadow-sm' : 'text-gray-500 hover:text-gray-700'"
                                class="px-5 py-2 rounded-lg text-xs font-black tracking-wider transition-all">境外城乡</button>
                    </div>
                    <button type="button" @@click="open = false"
                            class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-xl transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                <!-- 搜索框 -->
                <div class="relative">
                    <input type="text" x-model="searchQuery" @@input.debounce.300ms="search()"
                           placeholder="输入地名拼音首字母或汉字快速检索..."
                           class="w-full pl-10 pr-4 py-3 bg-gray-50 border-none rounded-xl text-xs focus:ring-2 focus:ring-brand/20 transition-all font-medium">
                    <svg class="absolute left-3.5 top-3.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <button x-show="searchQuery" @@click="searchQuery = ''; search()" 
                            class="absolute right-3.5 top-3.5 text-gray-400 hover:text-gray-600">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                    </button>
                </div>
            </div>

            <!-- 内容区 -->
            <div class="flex-1 flex overflow-hidden">
                <!-- 地区列表主体 -->
                <div class="flex-1 overflow-y-auto p-6 custom-scrollbar relative bg-white" id="geoListContainer">
                    
                    <!-- 加载中遮罩 -->
                    <div x-show="loading" class="absolute inset-0 bg-white/70 flex items-center justify-center z-10" style="display:none">
                        <div class="flex flex-col items-center gap-2">
                            <svg class="animate-spin w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                            <span class="text-[10px] text-gray-400 font-bold tracking-widest uppercase">正在联动加载...</span>
                        </div>
                    </div>

                    <!-- 1. 级联联动选择模式 (无搜索时展示) -->
                    <div x-show="!searchQuery" class="space-y-6">
                        
                        <!-- 第一行：省份/国家 -->
                        <div class="space-y-2">
                            <div class="flex items-center gap-2">
                                <div class="w-1 h-3 bg-brand rounded-full"></div>
                                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest" x-text="tab === 'domestic' ? '选择省份' : '选择国家'"></span>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <template x-for="item in (tab === 'domestic' ? provinces : countries)" :key="item.id">
                                    <button type="button" 
                                            @@click="selectNode(item, 1)"
                                            @@dblclick="selectNode(item, 1); confirmSelection()"
                                            :class="isActive(item, 1) ? 'bg-brand text-white border-brand shadow-md shadow-brand/10 font-bold' : 'bg-gray-50 text-gray-700 border-gray-100 hover:border-brand hover:text-brand hover:bg-brand/5'"
                                            class="px-3.5 py-1.5 rounded-lg border text-xs transition-all transform hover:scale-[1.03] active:scale-95 duration-100"
                                            x-text="item.title"></button>
                                </template>
                            </div>
                        </div>

                        <!-- 第二行：地级市 / 境外城市 -->
                        <div x-show="tab === 'domestic' ? cities.length > 0 : overseasTowns.length > 0"
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 translate-y-2"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             class="space-y-2 pt-4 border-t border-dashed border-gray-100" style="display:none">
                            <div class="flex items-center gap-2">
                                <div class="w-1 h-3 bg-brand rounded-full"></div>
                                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest" x-text="tab === 'domestic' ? '选择地级市' : '选择城镇'"></span>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <template x-for="item in (tab === 'domestic' ? cities : overseasTowns)" :key="item.id">
                                    <button type="button" 
                                            @@click="selectNode(item, 2)"
                                            @@dblclick="selectNode(item, 2); confirmSelection()"
                                            :class="isActive(item, 2) ? 'bg-brand text-white border-brand shadow-md shadow-brand/10 font-bold' : 'bg-gray-50 text-gray-700 border-gray-100 hover:border-brand hover:text-brand hover:bg-brand/5'"
                                            class="px-3.5 py-1.5 rounded-lg border text-xs transition-all transform hover:scale-[1.03] active:scale-95 duration-100"
                                            x-text="item.title"></button>
                                </template>
                            </div>
                        </div>

                        <!-- 第三行：县级市/区 -->
                        <div x-show="tab === 'domestic' && counties.length > 0"
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 translate-y-2"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             class="space-y-2 pt-4 border-t border-dashed border-gray-100" style="display:none">
                            <div class="flex items-center gap-2">
                                <div class="w-1 h-3 bg-brand rounded-full"></div>
                                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">选择县级市 / 辖区</span>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <template x-for="item in counties" :key="item.id">
                                    <button type="button" 
                                            @@click="selectNode(item, 3)"
                                            @@dblclick="selectNode(item, 3); confirmSelection()"
                                            :class="isActive(item, 3) ? 'bg-brand text-white border-brand shadow-md shadow-brand/10 font-bold' : 'bg-gray-50 text-gray-700 border-gray-100 hover:border-brand hover:text-brand hover:bg-brand/5'"
                                            class="px-3.5 py-1.5 rounded-lg border text-xs transition-all transform hover:scale-[1.03] active:scale-95 duration-100"
                                            x-text="item.title"></button>
                                </template>
                            </div>
                        </div>

                        <!-- 第四行：乡镇 -->
                        <div x-show="tab === 'domestic' && towns.length > 0"
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 translate-y-2"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             class="space-y-2 pt-4 border-t border-dashed border-gray-100" style="display:none">
                            <div class="flex items-center gap-2">
                                <div class="w-1 h-3 bg-brand rounded-full"></div>
                                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">选择乡镇 / 街道</span>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <template x-for="item in towns" :key="item.id">
                                    <button type="button" 
                                            @@click="selectNode(item, 4)"
                                            @@dblclick="selectNode(item, 4); confirmSelection()"
                                            :class="isActive(item, 4) ? 'bg-brand text-white border-brand shadow-md shadow-brand/10 font-bold' : 'bg-gray-50 text-gray-700 border-gray-100 hover:border-brand hover:text-brand hover:bg-brand/5'"
                                            class="px-3.5 py-1.5 rounded-lg border text-xs transition-all transform hover:scale-[1.03] active:scale-95 duration-100"
                                            x-text="item.title"></button>
                                </template>
                            </div>
                        </div>

                        <!-- 第五行：村庄 -->
                        <div x-show="tab === 'domestic' && villages.length > 0"
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 translate-y-2"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             class="space-y-2 pt-4 border-t border-dashed border-gray-100" style="display:none">
                            <div class="flex items-center gap-2">
                                <div class="w-1 h-3 bg-brand rounded-full"></div>
                                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">选择村庄 / 社区</span>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <template x-for="item in villages" :key="item.id">
                                    <button type="button" 
                                            @@click="selectNode(item, 5)"
                                            @@dblclick="selectNode(item, 5); confirmSelection()"
                                            :class="isActive(item, 5) ? 'bg-brand text-white border-brand shadow-md shadow-brand/10 font-bold' : 'bg-gray-50 text-gray-700 border-gray-100 hover:border-brand hover:text-brand hover:bg-brand/5'"
                                            class="px-3.5 py-1.5 rounded-lg border text-xs transition-all transform hover:scale-[1.03] active:scale-95 duration-100"
                                            x-text="item.title"></button>
                                </template>
                            </div>
                        </div>
                    </div>

                    <!-- 2. 全局搜索结果扁平平铺列表 (搜索时展示) -->
                    <div x-show="searchQuery" class="space-y-6" style="display:none">
                        <template x-for="group in groupedItems" :key="group.letter">
                            <div :id="'group-' + group.letter">
                                <div class="text-brand font-bold text-sm mb-3 border-b border-brand/10 pb-1" x-text="group.letter"></div>
                                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                                    <template x-for="item in group.items" :key="item.id">
                                        <button type="button" 
                                                @@click="selectSearchItem(item)"
                                                @@dblclick="selectSearchItem(item); confirmSelection()"
                                                :class="tempSelectedId == item.id ? 'bg-brand text-white border-brand shadow-md shadow-brand/10' : 'bg-gray-50 text-gray-700 border-gray-100 hover:border-brand hover:text-brand hover:bg-brand/5'"
                                                class="w-full px-4 py-2.5 text-left rounded-xl border text-xs transition-all flex flex-col gap-1 relative overflow-hidden">
                                            <div class="flex items-center gap-1.5 w-full">
                                                <span class="font-bold truncate max-w-[80px]" x-text="item.title"></span>
                                                <!-- 行政级别徽章 -->
                                                <span class="px-1 py-0.5 rounded text-[8px] font-black uppercase flex-shrink-0"
                                                      :class="{
                                                          'bg-blue-100 text-blue-600': item.level == 1,
                                                          'bg-green-100 text-green-600': item.level == 2,
                                                          'bg-amber-100 text-amber-600': item.level == 3,
                                                          'bg-rose-100 text-rose-600': item.level == 4,
                                                          'bg-purple-100 text-purple-600': item.level == 5,
                                                          'bg-gray-200 text-gray-500': item.level >= 6
                                                      }"
                                                      x-text="item.level == 1 ? '国家' : (item.level == 2 ? '省份' : (item.level == 3 ? '城市' : (item.level == 4 ? '区县' : (item.level == 5 ? '乡镇' : '村庄'))))"></span>
                                            </div>
                                            <!-- 上层路径导航提示 -->
                                            <div class="text-[9px] text-gray-400 truncate w-full"
                                                 :class="tempSelectedId == item.id ? 'text-white/80' : 'text-gray-400'"
                                                 x-text="item.parentTitle ? (item.parentTitle + ' / ' + item.title) : item.title"></div>
                                        </button>
                                    </template>
                                </div>
                            </div>
                        </template>

                        <!-- 无搜索结果提示 -->
                        <div x-show="!loading && groupedItems.length === 0" class="flex flex-col items-center justify-center py-16 text-gray-400" style="display:none">
                            <svg class="w-12 h-12 mx-auto mb-2 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                            <p class="text-xs font-bold text-gray-400">未找到与“<span class="text-brand font-black" x-text="searchQuery"></span>”匹配的任何城乡地区</p>
                        </div>
                    </div>
                </div>

                <!-- 搜索模式下的 A-Z 快速索引栏 -->
                <div x-show="searchQuery && groupedItems.length > 0" 
                     class="w-8 flex flex-col items-center justify-center bg-gray-50 border-l border-gray-100 py-4 flex-shrink-0"
                     style="display:none">
                    <template x-for="group in groupedItems" :key="group.letter">
                        <button type="button" 
                                @@click="scrollToGroup(group.letter)"
                                class="w-full text-brand font-black cursor-pointer hover:scale-150 active:text-brand/60 text-[10px] leading-tight transition-all py-0.5 text-center transform"
                                x-text="group.letter"></button>
                    </template>
                </div>
            </div>

            <!-- 底部操作栏 -->
            <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between bg-gray-50 flex-shrink-0">
                <div class="flex flex-col">
                    <span class="text-[9px] text-gray-400 uppercase tracking-widest font-black mb-1">当前已选</span>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full transition-colors duration-200" :class="tempSelectedId ? 'bg-emerald-500' : 'bg-gray-300'"></div>
                        <span class="text-xs font-black" :class="tempSelectedId ? 'text-gray-900' : 'text-gray-400'"
                              x-text="tempSelectedName || '未选中任何地区'"></span>
                    </div>
                </div>
                <div class="flex gap-3">
                    <button type="button" @@click="clear()"
                            class="px-5 py-2.5 text-xs font-black text-gray-500 hover:bg-gray-200 hover:text-gray-700 rounded-xl transition-all">清除选择</button>
                    <button type="button" @@click="confirmSelection()"
                            class="px-8 py-2.5 text-xs font-black bg-brand text-white rounded-xl shadow-lg shadow-brand/20 hover:-translate-y-0.5 active:scale-95 transition-all">确认选择</button>
                </div>
            </div>
        </div>
    </div>
</div>

@model TravelPortal.Web.Models.PaginationMetadata
@{
    // 获取当前路由参数，排除 pageIndex 以便重新设置
    var routeData = ViewContext.RouteData.Values;
    var queryData = Context.Request.Query;
}

@if (Model.TotalPages > 1)
{
    <div class="px-6 py-4 flex items-center justify-between border-t border-gray-50 bg-white">
        <div class="flex-1 flex justify-between sm:hidden">
            <a asp-all-route-data='new Dictionary<string, string>(queryData.Select(q => new KeyValuePair<string, string>(q.Key, q.Value)))' 
               asp-route-pageIndex="@(Model.PageIndex - 1)"
               class="@(!Model.HasPreviousPage ? "pointer-events-none opacity-50" : "") relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                上一页
            </a>
            <a asp-all-route-data='new Dictionary<string, string>(queryData.Select(q => new KeyValuePair<string, string>(q.Key, q.Value)))' 
               asp-route-pageIndex="@(Model.PageIndex + 1)"
               class="@(!Model.HasNextPage ? "pointer-events-none opacity-50" : "") ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                下一页
            </a>
        </div>
        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
                <p class="text-xs text-gray-500">
                    显示第 <span class="font-bold text-brand">@(((Model.PageIndex - 1) * Model.PageSize) + 1)</span> 到第 <span class="font-bold text-brand">@(Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount))</span> 条记录，共 <span class="font-bold text-gray-700">@Model.TotalCount</span> 条
                </p>
            </div>
            <div>
                <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                    <!-- 上一页 -->
                    <a asp-all-route-data='new Dictionary<string, string>(queryData.Select(q => new KeyValuePair<string, string>(q.Key, q.Value)))' 
                       asp-route-pageIndex="@(Model.PageIndex - 1)"
                       class="@(!Model.HasPreviousPage ? "pointer-events-none opacity-30" : "hover:bg-gray-50") relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-100 bg-white text-sm font-medium text-gray-500">
                        <span class="sr-only">Previous</span>
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </a>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == 1 || i == Model.TotalPages || (i >= Model.PageIndex - 2 && i <= Model.PageIndex + 2))
                        {
                            <a asp-all-route-data='new Dictionary<string, string>(queryData.Select(q => new KeyValuePair<string, string>(q.Key, q.Value)))' 
                               asp-route-pageIndex="@i"
                               class="relative inline-flex items-center px-4 py-2 border border-gray-100 bg-white text-sm font-bold @(i == Model.PageIndex ? "z-10 bg-brand/10 border-brand text-brand" : "text-gray-400 hover:bg-gray-50")">
                                @i
                            </a>
                        }
                        else if (i == 2 || i == Model.TotalPages - 1)
                        {
                            <span class="relative inline-flex items-center px-4 py-2 border border-gray-100 bg-gray-50 text-sm font-medium text-gray-700">...</span>
                        }
                    }

                    <!-- 下一页 -->
                    <a asp-all-route-data='new Dictionary<string, string>(queryData.Select(q => new KeyValuePair<string, string>(q.Key, q.Value)))' 
                       asp-route-pageIndex="@(Model.PageIndex + 1)"
                       class="@(!Model.HasNextPage ? "pointer-events-none opacity-30" : "hover:bg-gray-50") relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-100 bg-white text-sm font-medium text-gray-500">
                        <span class="sr-only">Next</span>
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </nav>
            </div>
        </div>
    </div>
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 旅游门户</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <style>
        body { font-family: 'Microsoft YaHei', '微软雅黑', sans-serif; margin: 0; padding: 0; }
        .container-1200 { max-width: 1200px; width: 100%; margin: 0 auto; position: relative; }
        .nav-link { font-size: 12px; color: #000; text-decoration: none; margin-right: 48px; }
        .nav-link:last-child { margin-right: 0; }
        .nav-link:hover { color: #b58c5e; }
        .nav-link.active { font-weight: bold; }
        .search-input { width: 772px; height: 50px; border: 1px solid #ddd; padding: 0 15px; font-size: 14px; outline: none; }
        .search-dropdown { width: 110px; height: 50px; border: 1px solid #ddd; background: #fff; display: flex; align-items: center; justify-content: space-between; padding: 0 12px; font-size: 12px; cursor: pointer; }
        .search-btn { width: 96px; height: 48px; background: #b58c5e; color: #fff; border: none; font-size: 14px; font-weight: bold; cursor: pointer; }

        /* 移动端自适应逻辑 */
        .container-1200 { box-sizing: border-box; }
        @@media (max-width: 1199px) {
            .container-1200 { padding: 0 15px !important; }
            .list-header { flex-direction: column !important; gap: 15px; align-items: flex-start !important; }
            header { height: auto !important; padding: 20px 0; }
            .header-container { height: auto !important; display: flex; flex-direction: column; align-items: center; gap: 20px; }
            .header-container > * { position: static !important; width: 90% !important; margin: 0 auto !important; height: auto !important; }
            .nav-links { flex-wrap: wrap; justify-content: center; gap: 10px; height: auto !important; }
            .search-group { flex-direction: column; align-items: stretch; gap: 10px; }
            .search-input { width: 100% !important; }
            .search-dropdown, .search-btn { width: 100% !important; position: static !important; height: 45px !important; }
            .user-area, .qr-code { display: none; }
        }
    </style>
</head>
<body class="bg-white">

    <!-- 1. 统一分页顶部 (Sub-Page Header) - 1200px 居中容器 -->
    <header style="height: 150px; background: linear-gradient(to bottom, #f7e18d, #ffffff); border-bottom: 1px solid #c4a188; position: relative;">
        <div class="header-container container-1200" style="height: 100%;">

            <!-- Logo (PSD x:361 -> Rel x:1) -->
            <div style="position: absolute; left: 1px; top: 47px; width: 170px; height: 50px; border: 1px solid #c3a277; display: flex; align-items: center; justify-content: center; background: #fff;">
                <h1 style="font-size: 20px; font-weight: bold; color: #6f4e37; margin: 0; letter-spacing: 2px;">网站LOGO</h1>
            </div>

            <!-- 导航链接 (PSD x:574 -> Rel x:214) -->
            <nav class="nav-links" style="position: absolute; left: 214px; top: 44px; width: 588px; height: 14px; display: flex; align-items: center; justify-content: space-between;">
                <a href="/" class="nav-link" style="margin: 0;">首页</a>
                <a href="/Travelogues" class="nav-link" style="margin: 0;">纪行 · 攻略</a>
                <a href="/Places" class="nav-link" style="margin: 0;">城乡 · 街巷</a>
                <a href="/Foods" class="nav-link" style="margin: 0;">特产 · 美食</a>
                <a href="/Goods" class="nav-link" style="margin: 0;">好物 · 文创</a>
                <a href="/News" class="nav-link" style="margin: 0;">资讯 · 动态</a>
            </nav>

            <!-- 登录注册 (PSD x:1447 -> Rel x:1087) -->
            <div class="user-area" style="position: absolute; left: 1087px; top: 15px; width: 66px; height: 13px; display: flex; align-items: center; font-size: 12px; color: #000;">
                <a href="/Account/Login" style="color: inherit; text-decoration: none; margin-right: 15px;">登录</a>
                <a href="/Account/Register" style="color: inherit; text-decoration: none;">注册</a>
            </div>

            <!-- 二维码 (PSD x:1542 -> Rel x:1182) -->
            <div class="qr-code" style="position: absolute; left: 1182px; top: 15px; width: 15px; height: 14px; color: #999;">
                <svg fill="currentColor" viewBox="0 0 24 24"><path d="M3 11h8V3H3v8zm2-6h4v4H5V5zM3 21h8v-8H3v8zm2-6h4v4H5v-4zM13 3v8h8V3h-8zm6 6h-4V5h4v4zM13 13h2v2h-2v-2zm2 2h2v2h-2v-2zm2-2h2v2h-2v-2zm2 2h2v2h-2v-2zm-2 2h2v2h-2v-2zm0 2h2v2h-2v-2zm-2-2h2v2h-2v-2zm0 2h2v2h-2v-2zm-2-2h2v2h-2v-2z"/></svg>
            </div>

            <!-- 搜索组 (PSD x:573 -> Rel x:213) -->
            <div class="search-group" style="position: absolute; left: 213px; top: 68px; display: flex; align-items: flex-start;">
                <!-- 输入框 (w: 770) -->
                <input type="text" class="search-input" style="width: 770px; height: 45px; margin: 0; border: 1px solid #ebe2cf; padding: 0 24px; outline: none; font-size: 12px; box-sizing: border-box;" />

                <!-- 下拉框 (PSD x:1351 -> Rel offset 778 from group start) -->
                <div class="search-dropdown" id="searchCategory" style="position: absolute; left: 778px; top: 0; width: 108px; height: 45px; margin: 0; display: flex; align-items: center; justify-content: center; background: #fff; border: 1px solid #ebe2cf; border-left: none; box-sizing: border-box; cursor: pointer;">
                    <span id="selectedCategoryLabel">纪行 · 攻略</span>
                    <span style="font-size: 10px; transform: scale(0.8); margin-left: 4px; color: #ccc;">▼</span>
                    <input type="hidden" name="module" id="currentModule" value="travelogue" />

                    <div id="categoryMenu" style="display:none; position:absolute; top:100%; left:-1px; right:-1px; background:#fff; border:1px solid #ebe2cf; border-top:none; z-index:10; font-size:12px;">
                        <div data-val="travelogue" data-label="纪行 · 攻略" style="padding:8px 16px; cursor:pointer; color:#333;">纪行 · 攻略</div>
                        <div data-val="places" data-label="城乡 · 街巷" style="padding:8px 16px; cursor:pointer; color:#333;">城乡 · 街巷</div>
                        <div data-val="foods" data-label="特产 · 美食" style="padding:8px 16px; cursor:pointer; color:#333;">特产 · 美食</div>
                        <div data-val="goods" data-label="好物 · 文创" style="padding:8px 16px; cursor:pointer; color:#333;">好物 · 文创</div>
                        <div data-val="news" data-label="资讯 · 动态" style="padding:8px 16px; cursor:pointer; color:#333;">资讯 · 动态</div>
                    </div>
                </div>

                <!-- 搜索按钮 (PSD x:1467 -> Rel offset 894 from group start) -->
                <button class="search-btn" style="position: absolute; left: 894px; top: 0; width: 92px; height: 45px; margin: 0; background: #b58c5e; border: none; color: #fff; font-size: 20px; font-weight: normal; font-family: 'Microsoft YaHei', sans-serif; cursor: pointer;">搜 索</button>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <!-- 页脚 -->
    <footer style="margin-top: 80px; padding: 40px 0; border-top: 1px solid #eee; background: #fff;">
        <div class="container-1200" style="text-align: center;">
            <div style="display: flex; justify-content: center; gap: 30px; font-size: 12px; color: #666; margin-bottom: 15px;">
                <a href="/About" style="color: inherit; text-decoration: none;">关于我们</a>
                <span>服务协议</span>
                <span>合作事宜</span>
                <span>意见建议</span>
                <span>联系我们</span>
            </div>
            <p style="font-size: 12px; color: #999; margin: 5px 0;">Copyright © 2026-2027 NAME.COM All Rights Reserved</p>
            <p style="font-size: 12px; color: #999; margin: 5px 0;">版权所有：网站名称　鲁ICP备123456789号</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        (function() {
            var path = window.location.pathname.toLowerCase();
            document.querySelectorAll('.nav-link').forEach(function(a) {
                var href = a.getAttribute('href').toLowerCase();
                if (href === '/' ? path === '/' : path.startsWith(href)) {
                    a.classList.add('active');
                }
            });
        })();
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $(function() {
            // 下拉菜单交互
            $('#searchCategory').click(function(e) {
                e.stopPropagation();
                $('#categoryMenu').toggle();
            });

            $('#categoryMenu div').click(function(e) {
                e.stopPropagation();
                var val = $(this).data('val');
                var label = $(this).data('label');
                $('#selectedCategoryLabel').text(label);
                $('#currentModule').val(val);
                $('#categoryMenu').hide();
            });

            $(document).click(function() {
                $('#categoryMenu').hide();
            });

            // 搜索跳转逻辑
            $('.search-btn').click(function() {
                var keyword = $('.search-input').val();
                var module = $('#currentModule').val();
                var baseUrl = "/" + (module.charAt(0).toUpperCase() + module.slice(1));
                if (module === 'travelogue') baseUrl = "/Travelogues";
                if (module === 'places') baseUrl = "/Places";
                if (module === 'foods') baseUrl = "/Foods";
                if (module === 'goods') baseUrl = "/Goods";
                if (module === 'news') baseUrl = "/News";

                window.location.href = baseUrl + "?keyword=" + encodeURIComponent(keyword);
            });

            // 回车搜索
            $('.search-input').on('keypress', function(e) {
                if (e.which === 13) {
                    $('.search-btn').click();
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
